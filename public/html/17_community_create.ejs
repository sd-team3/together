<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('partials/navbar') %>
<!-- ═══════ MAIN ═══════ -->

<div class="main">

<!-- ──────── COMMUNITY CREATE ──────── -->
<%- include('partials/head', { title: '✏️ 게시글 작성', pageId: 'page-community-create', active: '' }) %>

  <div class="form-page">
    <div class="form-max">

      <!-- 카테고리 -->
      <div class="form-section">
        <div class="form-section-title">카테고리</div>
        <div class="field">
          <label class="label">게시판 선택</label>
          <div class="chip-group">
            <div class="chip on" onclick="singleChip(this)" data-cat="question">❓ 질문</div>
            <div class="chip" onclick="singleChip(this)" data-cat="tip">💡 팁/정보</div>
            <div class="chip" onclick="singleChip(this)" data-cat="free">💬 자유</div>
          </div>
        </div>

      <!-- 본문 -->
      <div class="form-section">
        <div class="field">
          <label class="label">제목</label>
          <input class="input" id="post-title" placeholder="제목을 입력해주세요" maxlength="20" oninput="updateTitleCount()">
          <div style="text-align:right;font-size:11px;color:var(--text-3);margin-top:4px;font-family:'DM Mono',monospace">
            <span id="title-count">0</span>/20
          </div>
        </div>
        <div class="field">
          <label class="label">내용</label>
          <textarea class="input" id="post-body" placeholder="내용을 자유롭게 작성해주세요." style="min-height:220px;resize:vertical;line-height:1.6" maxlength="3000" oninput="updateBodyCount()"></textarea>
          <div style="text-align:right;font-size:11px;color:var(--text-3);margin-top:4px;font-family:'DM Mono',monospace">
            <span id="body-count">0</span>/3000
          </div>
        </div>
      </div>

      <!-- 태그 -->
      <div class="form-section">
        <div class="form-section-title">태그 <span style="color:var(--text-3);font-size:12px;font-weight:400">(선택 · 최대 5개)</span></div>
        <div class="field">
          <div style="display:flex;gap:8px;align-items:center">
            <input class="input" id="tag-input" placeholder="태그 입력 후 Enter (예: 초보질문, 장비추천)" style="flex:1" onkeydown="addTag(event)">
            <button class="btn btn-outline btn-sm" onclick="addTag({key:'Enter'})">추가</button>
          </div>
          <div class="chip-group" id="tag-list" style="margin-top:10px"></div>
        </div>

      <!-- 이미지 첨부 -->
      <div class="form-section">
        <div class="form-section-title">이미지 첨부 <span style="color:var(--text-3);font-size:12px;font-weight:400">(선택 · 최대 4장)</span></div>
        <div class="field">
          <div id="image-upload-area" onclick="document.getElementById('img-input').click()" style="border:2px dashed var(--border);border-radius:12px;padding:32px;text-align:center;cursor:pointer;transition:border-color .2s" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
            <div style="font-size:28px;margin-bottom:8px">📷</div>
            <div style="font-size:13px;color:var(--text-2);font-weight:500">클릭하여 이미지 추가</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">JPG, PNG, GIF · 각 10MB 이하</div>
          </div>
          <input type="file" id="img-input" accept="image/*" multiple style="display:none" onchange="previewImages(event)">
          <div id="image-preview-list" class="chip-group" style="margin-top:10px;flex-wrap:wrap;gap:8px"></div>
        </div>
      </div>

      <!-- 버튼 -->
      <div style="display:flex;gap:10px;justify-content:flex-end;padding-bottom:24px">
        <button class="btn btn-outline" onclick="goPage('community')">취소</button>
        <button class="btn btn-primary btn-lg" onclick="submitPost()">게시글 등록</button>
      </div>

    </div>
  </div>
</div>


</div><!-- /main -->

<div class="map-popup-overlay" id="map-popup" onclick="if(event.target===this)closeMapPopup()">
  <div class="map-popup">
    <button class="popup-close" onclick="closeMapPopup()">✕</button>
    <div class="popup-sport" id="pp-sport">⚽</div>
    <div class="popup-title" id="pp-title">강남 풋살파크 5:5 매칭</div>
    <div class="popup-meta">
      <span id="pp-loc">📍 강남구 역삼동</span>
      <span id="pp-time">⏰ 오늘 19:30</span>
      <span id="pp-members">👥 6/10명</span>
      <span>💰 <span id="pp-price">10,000원</span></span>
    </div>
    <div class="flex gap-6 mb-16">
      <span class="tag tag-outline" id="pp-level">중급</span>
      <span class="tag tag-green">실내</span>
    </div>
    <div class="popup-host">
      <div class="popup-host-av">K</div>
      <div><div class="popup-host-name">강남킬러 <span style="color:var(--text-3);font-weight:400">⭐ 4.9</span></div><div class="popup-host-sub">47경기 · 매너 우수</div></div>
    </div>
    <div class="popup-btns">
      <button class="btn btn-primary flex-1" onclick="closeMapPopup();showModal('🎉 참가 신청 완료!','매칭에 참가 신청이 완료되었습니다!<br>당일 30분 전 알림을 드립니다.',null)">참가 신청</button>
      <button class="btn btn-outline" onclick="closeMapPopup()">공유 🔗</button>
    </div>
  </div>
</div>

<!-- ═══════ AUTH MODALS ═══════ -->
<!-- Login Modal -->
<div class="auth-modal-overlay" id="modal-login" onclick="if(event.target===this)closeAuthModal('login')">
  <div class="auth-modal-box">
    <button class="auth-close" onclick="closeAuthModal('login')">✕</button>
    <div class="auth-header">
      <div class="auth-title">다시 만나서 반가워요! 👋</div>
      <div class="auth-sub">SPORTMATCH에 오신 것을 환영합니다.</div>
    </div>
    <div class="social-login">
      <button class="social-btn kakao" onclick="handleAuthSuccess('로그인')">💬 카카오로 시작하기</button>
      <button class="social-btn" onclick="handleAuthSuccess('로그인')">🌐 구글로 시작하기</button>
    </div>
    <div class="field">
      <label class="label">이메일</label>
      <input type="email" class="input" placeholder="example@sportmatch.com">
    </div>
    <div class="field">
      <label class="label">비밀번호</label>
      <input type="password" class="input" placeholder="••••••••">
    </div>
    <button class="btn btn-primary btn-full btn-lg" style="margin-top:10px" onclick="handleAuthSuccess('로그인')">로그인</button>
    <div class="auth-footer">
      아직 회원이 아니신가요? <span class="auth-link" onclick="switchAuthModal('login', 'signup')">회원가입</span>
    </div>
  </div>
</div>

<!-- Signup Modal -->
<div class="auth-modal-overlay" id="modal-signup" onclick="if(event.target===this)closeAuthModal('signup')">
  <div class="auth-modal-box">
    <button class="auth-close" onclick="closeAuthModal('signup')">✕</button>
    <div class="auth-header">
      <div class="auth-title">환영합니다! 🏅</div>
      <div class="auth-sub">지금 가입하고 내 주변 매칭을 찾아보세요.</div>
    </div>
    <div class="social-login">
      <button class="social-btn kakao" onclick="handleAuthSuccess('회원가입')">💬 카카오로 시작하기</button>
      <button class="social-btn" onclick="handleAuthSuccess('회원가입')">🌐 구글로 시작하기</button>
    </div>
    <div class="field">
      <label class="label">이름</label>
      <input type="text" class="input" placeholder="홍길동">
    </div>
    <div class="field">
      <label class="label">이메일</label>
      <input type="email" class="input" placeholder="example@sportmatch.com">
    </div>
    <div class="field">
      <label class="label">비밀번호</label>
      <input type="password" class="input" placeholder="8자 이상 입력해주세요">
    </div>
    <button class="btn btn-primary btn-full btn-lg" style="margin-top:10px" onclick="handleAuthSuccess('회원가입')">회원가입 완료</button>
    <div class="auth-footer">
      이미 계정이 있으신가요? <span class="auth-link" onclick="switchAuthModal('signup', 'login')">로그인</span>
    </div>
  </div>
</div>

<!-- ═══════ MODAL ═══════ -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <div class="modal-icon" id="modal-icon">🎉</div>
    <div class="modal-title" id="modal-title">완료!</div>
    <div class="modal-msg" id="modal-msg">처리가 완료되었습니다.</div>
    <div class="modal-btns">
      <button class="btn btn-outline flex-1" onclick="closeModal()">닫기</button>
      <button class="btn btn-primary flex-1" id="modal-ok" onclick="closeModal()">확인</button>
    </div>
  </div>
</div>

<script>
// ── 글자 수 카운트 ──
function updateTitleCount() {
  document.getElementById('title-count').textContent = document.getElementById('post-title').value.length;
}
function updateBodyCount() {
  document.getElementById('body-count').textContent = document.getElementById('post-body').value.length;
}

// ── 태그 ──
const tags = [];
function addTag(e) {
  if (e.key !== 'Enter') return;
  const input = document.getElementById('tag-input');
  const val = input.value.trim().replace(/^#/, '');
  if (!val || tags.includes(val) || tags.length >= 5) {
    input.value = '';
    return;
  }
  tags.push(val);
  renderTags();
  input.value = '';
}

function removeTag(val) {
  const idx = tags.indexOf(val);
  if (idx > -1) tags.splice(idx, 1);
  renderTags();
}

function renderTags() {
  const list = document.getElementById('tag-list');
  list.innerHTML = tags.map(t =>
    `<div class="chip on" style="display:flex;align-items:center;gap:5px">
      #${t}
      <span onclick="removeTag('${t}')" style="cursor:pointer;font-size:12px;opacity:.7;margin-left:2px">✕</span>
    </div>`
  ).join('');
}

// ── 이미지 미리보기 ──
function previewImages(e) {
  const files = Array.from(e.target.files);
  const list = document.getElementById('image-preview-list');
  const current = list.querySelectorAll('.img-preview-item').length;
  const remaining = 4 - current;
  files.slice(0, remaining).forEach(file => {
    const reader = new FileReader();
    reader.onload = ev => {
      const div = document.createElement('div');
      div.className = 'img-preview-item';
      div.style.cssText = 'position:relative;display:inline-block';
      div.innerHTML = `
        <img src="${ev.target.result}" style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid var(--border)">
        <button onclick="this.parentElement.remove()" style="position:absolute;top:-6px;right:-6px;width:20px;height:20px;background:var(--text-1);color:var(--bg);border:none;border-radius:50%;font-size:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1">✕</button>
      `;
      list.appendChild(div);
    };
    reader.readAsDataURL(file);
  });
}

// ── 등록 ──
function submitPost() {
  const title = document.getElementById('post-title').value.trim();
  const body = document.getElementById('post-body').value.trim();
  if (!title) { alert('제목을 입력해주세요.'); return; }
  if (!body)  { alert('내용을 입력해주세요.'); return; }
  showModal('🎉 게시글 등록 완료!', '게시글이 커뮤니티에 등록되었습니다!<br>댓글이 달리면 알림을 드립니다.', () => goPage('community'));
}

// ── INIT ──
document.addEventListener('DOMContentLoaded', () => {
  goPage('community-create');
});
</script>
</body>
</html>
