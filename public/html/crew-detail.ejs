<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 모임 상세</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('partials/navbar') %>

<div class="main">
<%- include('partials/head', { title: '', pageId: 'page-crew-detail', active: '' }) %>

  <div class="page-body">
    <div class="detail-wrap">

      <!-- 뒤로가기 -->
      <button class="back-btn" onclick="history.back()">← 목록으로</button>

      <div class="detail-group">

      <!-- 헤더 -->
      <div class="detail-header">
        <div class="detail-sport-icon">⚽</div>
        <div class="detail-header-info">
          <div class="detail-title">성수 풋살 나이트</div>
          <div class="detail-sub">화·목 · 성동구 · 매주</div>
        </div>
        <!-- 좋아요 버튼 -->
        <button class="detail-like-btn" id="like-btn" onclick="toggleLike()">
          <span class="like-icon">🤍</span>
          <span class="like-count" id="like-count">24</span>
        </button>
      </div>

      <!-- 모임장 -->
      <div class="detail-section">
        <div class="detail-section-title">모임장</div>
        <div class="host-card">
          <div class="host-avatar">김</div>
          <div>
            <div class="host-name">김성수</div>
          </div>
        </div>
      </div>

      <!-- 소개글 -->
      <div class="detail-section">
        <div class="detail-section-title">모임 소개</div>
        <div class="detail-intro">성수동 실내 풋살장에서 매주 화·목요일 저녁 함께 뛰실 분들을 모집합니다!

        초중급 수준으로 즐겁게 운동하는 것을 목표로 하며, 승부보다는 화합을 중시하는 팀입니다. 운동 후 뒷풀이도 자주 합니다 🍺

        실력보다 매너와 성실함을 중요하게 생각합니다. 많은 참여 부탁드립니다!</div>
      </div>

      <!-- 가입 조건 -->
      <div class="detail-section">
        <div class="detail-section-title">가입 조건</div>
        <div class="condition-list">
          <div class="condition-item">
            <span class="cond-label">경기 종목</span>
            <span class="cond-value">축구, 풋살, 농구</span>
          </div>
          <div class="condition-item">
            <span class="cond-label">연령대</span>
            <span class="cond-value">20대 · 30대</span>
          </div>
          <div class="condition-item">
            <span class="cond-label">실력</span>
            <span class="cond-value">초급 · 중급</span>
          </div>
          <div class="condition-item">
            <span class="cond-label">참가비</span>
            <span class="cond-value">8,000원/회</span>
          </div>
          <div class="condition-item">
            <span class="cond-label">승인</span>
            <span class="cond-value">모임장 승인 후 참가 가능</span>
          </div>
        </div>
      </div>

      <!-- 멤버 현황 -->
      <div class="detail-section">
        <div class="detail-section-title">멤버 수</div>
        <div class="member-status">
          <div class="member-status-row">
            <span class="member-count">12 / 16명</span>
          </div>
        </div>
      </div>

      </div>

      <!-- 하단 가입 버튼 -->
      <div class="detail-footer">
        <button class="join-btn" id="join-btn" onclick="confirmJoin()">가입 신청하기</button>
      </div>
    </div>
  </div>
</div>

<!-- 가입 확인 모달 -->
<div class="modal-overlay" id="modal-join" onclick="if(event.target===this)closeJoinModal()">
  <div class="modal-box">
    <div class="modal-icon">⚽</div>
    <div class="modal-title">가입 신청</div>
    <div class="modal-msg">성수 풋살 나이트에<br>가입 신청하시겠습니까?<br><br>모임장 승인 후 참가가 확정됩니다.</div>
    <div class="modal-btns">
      <button class="btn btn-outline flex-1" onclick="closeJoinModal()">취소</button>
      <button class="btn btn-primary flex-1" onclick="doJoin()">신청하기</button>
    </div>
  </div>
</div>

<!-- 신청 완료 모달 -->
<div class="modal-overlay" id="modal-done" onclick="if(event.target===this)closeDoneModal()">
  <div class="modal-box">
    <div class="modal-icon">✅</div>
    <div class="modal-title">신청 완료!</div>
    <div class="modal-msg">가입 신청이 완료되었습니다.<br>모임장이 수락하면 알림을 드립니다.</div>
    <div class="modal-btns">
      <button class="btn btn-primary flex-1" onclick="closeDoneModal()">확인</button>
    </div>
  </div>
</div>

<script>

// ── 좋아요 ──
let liked = false;
let likeCount = 24;

function toggleLike() {
  liked = !liked;
  likeCount += liked ? 1 : -1;

  const btn = document.getElementById('like-btn');
  const icon = btn.querySelector('.like-icon');
  const count = document.getElementById('like-count');

  icon.textContent = liked ? '❤️' : '🤍';
  count.textContent = likeCount;
  btn.classList.toggle('liked', liked);
}

// ── 가입 신청 ──
function confirmJoin() {
  document.getElementById('modal-join').classList.add('show');
}

function closeJoinModal() {
  document.getElementById('modal-join').classList.remove('show');
}

function doJoin() {
  closeJoinModal();
  // 버튼 비활성화
  const joinBtn = document.getElementById('join-btn');
  joinBtn.disabled = true;
  joinBtn.textContent = '신청 완료';
  // 완료 모달
  setTimeout(() => {
    document.getElementById('modal-done').classList.add('show');
  }, 200);
}

function closeDoneModal() {
  document.getElementById('modal-done').classList.remove('show');
}
</script>
</body>
</html>
