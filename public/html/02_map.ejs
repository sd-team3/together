  badminton:[
    {type:'date',text:'오늘'},
    {from:'주최자',color:'#16a34a',init:'주',text:'이번 주 목요일 코트 예약 완료됐어요! ✅',time:'11:20'},
    {from:'홍다인',color:'#7c3aed',init:'홍',text:'감사합니다 🙏 라켓 가져가야 하나요?',time:'11:25'},
    {from:'주최자',color:'#16a34a',init:'주',text:'네, 라켓은 개인 지참 부탁드려요. 셔틀콕은 제공됩니다!',time:'11:28'},
    {mine:true,text:'저도 참석할게요!',time:'11:45'}
  ],
  running:[
    {type:'date',text:'오늘'},
    {from:'박수아',color:'#f97316',init:'박',text:'오늘 비 올 것 같은데 진행하나요?',time:'17:10'},
    {from:'크루장',color:'#1A5CFF',init:'크',text:'소나기 예보라 8시 이후엔 괜찮을 것 같아요!',time:'17:22'},
    {mine:true,text:'저는 갑니다 💪',time:'17:35'}
