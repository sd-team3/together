<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
<%- include('partials/navbar') %>
<!-- ═══════ MAIN ═══════ -->

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<!-- ──────── MAP PAGE ──────── -->
<%- include('partials/head', { title: '📍 지도 매칭', pageId: 'page-map', active: '' }) %>

  <div class="page-body-wide" style="flex:1;min-height:0">
    <div class="map-container" style="flex:1">
      <!-- Map Area (Leaflet) -->
      <div class="map-area" style="position:relative">
        <div id="leaflet-map" style="width:100%; height:350px;"></div>
        <!-- Filter bar -->
        <div class="map-filter-bar" style="z-index:1000">
          <div class="map-filter-chip on" onclick="leafletFilterToggle(this,'all')">전체</div>
          <div class="map-filter-chip" onclick="leafletFilterToggle(this,'⚽')">⚽ 풋살</div>
          <div class="map-filter-chip" onclick="leafletFilterToggle(this,'🏀')">🏀 농구</div>
          <div class="map-filter-chip" onclick="leafletFilterToggle(this,'🏸')">🏸 배드민턴</div>
          <div class="map-filter-chip" onclick="leafletFilterToggle(this,'🏃')">🏃 러닝</div>
          <div class="map-filter-chip" onclick="leafletFilterToggle(this,'🎾')">🎾 테니스</div>
        </div>
        <!--<button class="map-fab" onclick="goPage('map-create')" style="z-index:1000">＋</button>-->
      </div>
      <!-- List Panel -->
      <div class="map-list">
        <div class="map-list-header">
          <div class="map-list-title">5개의 매칭</div>
          <div class="map-sort-tabs">
            <button class="map-sort-tab on" onclick="setSortTab(this)">거리순</button>
            <button class="map-sort-tab" onclick="setSortTab(this)">시간순</button>
            <button class="map-sort-tab" onclick="setSortTab(this)">인원순</button>
          </div>
        </div>
        <div class="map-list-items">
          <div class="map-item sel" onclick="showMapPopup('강남 풋살파크 5:5','강남구 역삼동','오늘 19:30','6/10명','⚽','중급','10,000원')">
            <div class="mi-top"><div class="mi-sport">⚽</div><div><div class="mi-title">강남 풋살파크 5:5 매칭</div><div class="mi-meta"><span>📍 역삼동 · 1.2km</span></div></div></div>
            <div class="mi-meta"><span>⏰ 오늘 19:30</span><span>👥 6/10명</span><span>💰 10,000원</span></div>
            <div class="mi-bottom"><span class="pill pill-warn">마감임박</span><span class="tag tag-outline">중급</span></div>
          </div>
          <div class="map-item" onclick="showMapPopup('뚝섬 3on3 농구','성동구 뚝섬','오늘 18:00','5/6명','🏀','중급','무료')">
            <div class="mi-top"><div class="mi-sport">🏀</div><div><div class="mi-title">뚝섬 3on3 농구 스크림</div><div class="mi-meta"><span>📍 뚝섬 · 2.0km</span></div></div></div>
            <div class="mi-meta"><span>⏰ 오늘 18:00</span><span>👥 5/6명</span><span>💰 무료</span></div>
            <div class="mi-bottom"><span class="pill pill-warn">마감임박</span><span class="tag tag-outline">중급</span></div>
          </div>
          <div class="map-item" onclick="showMapPopup('홍대 배드민턴','마포구 홍대입구','내일 20:00','3/8명','🏸','입문','5,000원')">
            <div class="mi-top"><div class="mi-sport">🏸</div><div><div class="mi-title">홍대 배드민턴 나이트</div><div class="mi-meta"><span>📍 홍대입구 · 3.4km</span></div></div></div>
            <div class="mi-meta"><span>⏰ 내일 20:00</span><span>👥 3/8명</span><span>💰 5,000원</span></div>
            <div class="mi-bottom"><span class="pill pill-open">참가가능</span><span class="tag tag-outline">입문</span></div>
          </div>
          <div class="map-item" onclick="showMapPopup('성수 러닝크루','성동구 성수역','오늘 21:00','28/40명','🏃','전레벨','무료')">
            <div class="mi-top"><div class="mi-sport">🏃</div><div><div class="mi-title">성동 나이트 러닝 크루</div><div class="mi-meta"><span>📍 성수역 · 0.8km</span></div></div></div>
            <div class="mi-meta"><span>⏰ 오늘 21:00</span><span>👥 28/40명</span><span>💰 무료</span></div>
            <div class="mi-bottom"><span class="pill pill-open">참가가능</span><span class="tag tag-outline">전레벨</span></div>
          </div>
          <div class="map-item" onclick="showMapPopup('왕십리 테니스','성동구 왕십리','일 09:30','3/4명','🎾','초급','15,000원')">
            <div class="mi-top"><div class="mi-sport">🎾</div><div><div class="mi-title">왕십리 테니스 브런치</div><div class="mi-meta"><span>📍 왕십리 · 1.6km</span></div></div></div>
            <div class="mi-meta"><span>⏰ 일 09:30</span><span>👥 3/4명</span><span>💰 15,000원</span></div>
            <div class="mi-bottom"><span class="pill pill-warn">마감임박</span><span class="tag tag-outline">초급</span></div>
          </div>
        </div>
        <div style="padding: 10px; display: flex; justify-content: flex-end; background: #fff; border-top: 1px solid #eee;">
        <button class="btn btn-primary" onclick="goPage('map_create')" style="padding: 8px 20px; font-size: 14px; border-radius: 8px;">매칭 만들기</button>
        </div>
        </div>
      </div>
    </div>
  </div>
</div>


</div><!-- /main -->

<div class="map-popup-overlay" id="map-popup" onclick="if(event.target===this)closeMapPopup()">
  <div class="map-popup">
    <button class="popup-close" onclick="closeMapPopup()">✕</button>
    <div class="popup-sport" id="pp-sport">⚽</div>
    <div class="popup-title" id="pp-title">강남 풋살파크 5:5 매칭</div>
    <div class="popup-meta">
      <span id="pp-loc">📍 강남구 역삼동</span>
      <span id="pp-time">⏰ 오늘 19:30</span>
      <span id="pp-members">👥 6/10명</span>
      <span>💰 <span id="pp-price">10,000원</span></span>
    </div>
    <div class="flex gap-6 mb-16">
      <span class="tag tag-outline" id="pp-level">중급</span>
      <span class="tag tag-green">실내</span>
    </div>
    <div class="popup-host">
      <div class="popup-host-av">K</div>
      <div><div class="popup-host-name">강남킬러 <span style="color:var(--text-3);font-weight:400">⭐ 4.9</span></div><div class="popup-host-sub">47경기 · 매너 우수</div></div>
    </div>
    <div class="popup-btns">
      <button class="btn btn-primary flex-1" onclick="closeMapPopup();showModal('🎉 참가 신청 완료!','매칭에 참가 신청이 완료되었습니다!<br>당일 30분 전 알림을 드립니다.',null)">참가 신청</button>
      <button class="btn btn-outline" onclick="closeMapPopup()">공유 🔗</button>
    </div>
  </div>
</div>

<!-- ═══════ AUTH MODALS ═══════ -->
<!-- Login Modal -->
<div class="auth-modal-overlay" id="modal-login" onclick="if(event.target===this)closeAuthModal('login')">
  <div class="auth-modal-box">
    <button class="auth-close" onclick="closeAuthModal('login')">✕</button>
    <div class="auth-header">
      <div class="auth-title">다시 만나서 반가워요! 👋</div>
      <div class="auth-sub">SPORTMATCH에 오신 것을 환영합니다.</div>
    </div>
    <div class="social-login">
      <button class="social-btn kakao" onclick="handleAuthSuccess('로그인')">💬 카카오로 시작하기</button>
      <button class="social-btn" onclick="handleAuthSuccess('로그인')">🌐 구글로 시작하기</button>
    </div>
    <div class="field">
      <label class="label">이메일</label>
      <input type="email" class="input" placeholder="example@sportmatch.com">
    </div>
    <div class="field">
      <label class="label">비밀번호</label>
      <input type="password" class="input" placeholder="••••••••">
    </div>
    <button class="btn btn-primary btn-full btn-lg" style="margin-top:10px" onclick="handleAuthSuccess('로그인')">로그인</button>
    <div class="auth-footer">
      아직 회원이 아니신가요? <span class="auth-link" onclick="switchAuthModal('login', 'signup')">회원가입</span>
    </div>
  </div>
</div>

<!-- Signup Modal -->
<div class="auth-modal-overlay" id="modal-signup" onclick="if(event.target===this)closeAuthModal('signup')">
  <div class="auth-modal-box">
    <button class="auth-close" onclick="closeAuthModal('signup')">✕</button>
    <div class="auth-header">
      <div class="auth-title">환영합니다! 🏅</div>
      <div class="auth-sub">지금 가입하고 내 주변 매칭을 찾아보세요.</div>
    </div>
    <div class="social-login">
      <button class="social-btn kakao" onclick="handleAuthSuccess('회원가입')">💬 카카오로 시작하기</button>
      <button class="social-btn" onclick="handleAuthSuccess('회원가입')">🌐 구글로 시작하기</button>
    </div>
    <div class="field">
      <label class="label">이름</label>
      <input type="text" class="input" placeholder="홍길동">
    </div>
    <div class="field">
      <label class="label">이메일</label>
      <input type="email" class="input" placeholder="example@sportmatch.com">
    </div>
    <div class="field">
      <label class="label">비밀번호</label>
      <input type="password" class="input" placeholder="8자 이상 입력해주세요">
    </div>
    <button class="btn btn-primary btn-full btn-lg" style="margin-top:10px" onclick="handleAuthSuccess('회원가입')">회원가입 완료</button>
    <div class="auth-footer">
      이미 계정이 있으신가요? <span class="auth-link" onclick="switchAuthModal('signup', 'login')">로그인</span>
    </div>
  </div>
</div>

<!-- ═══════ MODAL ═══════ -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <div class="modal-icon" id="modal-icon">🎉</div>
    <div class="modal-title" id="modal-title">완료!</div>
    <div class="modal-msg" id="modal-msg">처리가 완료되었습니다.</div>
    <div class="modal-btns">
      <button class="btn btn-outline flex-1" onclick="closeModal()">닫기</button>
      <button class="btn btn-primary flex-1" id="modal-ok" onclick="closeModal()">확인</button>
    </div>
  </div>
</div>

<script>
// ── AUTH STATE ──
let isLoggedIn = false;

// ── PAGE NAVIGATION ──
function goPage(p) {
  // 로그인이 필요한 페이지 접근 시 로그인 체크
  const authRequired = ['mypage', 'chat', 'notifications'];
  if (!isLoggedIn && authRequired.includes(p)) {
    openAuthModal('login');
    return;
  }
  document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
  const pg = document.getElementById('page-' + p);
  if (pg) { pg.classList.add('active'); }
  document.querySelector('.main').scrollTo(0, 0);
  // Update nav — data-page 속성 기반으로 정확히 매칭
  const pageGroup = { 'map-create':'map', 'regular-create':'regular', 'trade-sell':'trade' };
  const activeKey = pageGroup[p] || p;
  document.querySelectorAll('.nav-item').forEach(el => {
    el.classList.toggle('active', el.dataset.page === activeKey);
  });
  if (p === 'home') {
    const msgs = document.getElementById('chatMessages');
    if (msgs) setTimeout(() => { msgs.scrollTop = msgs.scrollHeight; }, 100);
  }
  // Leaflet 지도 초기화
  if (p === 'map') {
    setTimeout(() => {
      initLeafletMap();
      if (leafletMap) leafletMap.invalidateSize();
    }, 50);
  }
}

// ── FILTER FUNCTIONS ──
function toggleFilter(el) {
  document.querySelectorAll('.map-filter-chip').forEach(c => c.classList.remove('on'));
  el.classList.add('on');
}
function setSortTab(el) {
  el.closest('.map-sort-tabs').querySelectorAll('.map-sort-tab').forEach(t => t.classList.remove('on'));
  el.classList.add('on');
}
function setFilter(el) {
  el.closest('.filter-section').querySelectorAll('.filter-item').forEach(i => i.classList.remove('active'));
  el.classList.add('active');
}
function singleChip(el) {
  el.closest('.chip-group, .topbar-actions, .flex').querySelectorAll('.chip').forEach(c => c.classList.remove('on'));
  el.classList.add('on');
}
function filterSport(el) {
  document.querySelectorAll('.sport-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
}
function singleLv(el) {
  el.closest('.level-row').querySelectorAll('.lv-btn').forEach(b => b.classList.remove('on'));
  el.classList.add('on');
}

// ── MAP POPUP ──
function showMapPopup(title, loc, time, members, sport, level, price) {
  document.getElementById('pp-sport').textContent = sport;
  document.getElementById('pp-title').textContent = title;
  document.getElementById('pp-loc').textContent = '📍 ' + loc;
  document.getElementById('pp-time').textContent = '⏰ ' + time;
  document.getElementById('pp-members').textContent = '👥 ' + members;
  document.getElementById('pp-level').textContent = level;
  document.getElementById('pp-price').textContent = price;
  document.getElementById('map-popup').classList.add('show');
}
function closeMapPopup() { document.getElementById('map-popup').classList.remove('show'); }

// ── MODAL ──
let _modalCb = null;
function showModal(title, msg, cb) {
  const emojiMatch = title.match(/^(\p{Emoji})/u);
  const emoji = emojiMatch ? emojiMatch[1] : '💡';
  const rest = title.replace(/^(\p{Emoji}\s*)/u, '');
  document.getElementById('modal-icon').textContent = emoji;
  document.getElementById('modal-title').textContent = rest;
  document.getElementById('modal-msg').innerHTML = msg;
  _modalCb = cb;
  const okBtn = document.getElementById('modal-ok');
  okBtn.onclick = cb ? () => { closeModal(); cb(); } : closeModal;
  document.getElementById('modal').classList.add('show');
}
function closeModal() { document.getElementById('modal').classList.remove('show'); }

// ── AUTH MODALS ──
function openAuthModal(type) {
  document.getElementById('modal-' + type).classList.add('show');
}
function closeAuthModal(type) {
  document.getElementById('modal-' + type).classList.remove('show');
}
function switchAuthModal(from, to) {
  closeAuthModal(from);
  setTimeout(() => openAuthModal(to), 100);
}
function handleAuthSuccess(action) {
  const type = action === '로그인' ? 'login' : 'signup';
  closeAuthModal(type);
  isLoggedIn = true;
  setLoginState(true);
  showModal('🎉 ' + action + ' 완료!', action + '에 성공하였습니다.<br>SPORTMATCH의 모든 기능을 자유롭게 이용해보세요.', null);
}

function setLoginState(loggedIn) {
  // 모든 페이지 topbar의 auth-state-btns 전환
  document.querySelectorAll('.auth-state-btns[data-state="guest"]').forEach(el => {
    el.style.display = loggedIn ? 'none' : 'inline-flex';
  });
  document.querySelectorAll('.auth-state-btns[data-state="user"]').forEach(el => {
    el.style.display = loggedIn ? 'inline-flex' : 'none';
  });
  // 사이드바 하단 전환
  const navGuest = document.getElementById('nav-guest');
  const navUser  = document.getElementById('nav-user');
  if (navGuest) navGuest.style.display = loggedIn ? 'none' : 'flex';
  if (navUser)  navUser.style.display  = loggedIn ? 'block' : 'none';
}

function doLogout() {
  isLoggedIn = false;
  setLoginState(false);
  goPage('home');
  showModal('👋 로그아웃', '로그아웃 되었습니다.<br>다음에 또 만나요!', null);
}

// ── COMMUNITY TABS ──
document.querySelectorAll('.comm-tab').forEach(tab => {
  tab.addEventListener('click', function() {
    // 같은 탭 그룹(부모 컨테이너) 안에서만 active 토글
    const group = this.closest('.comm-tabs');
    if (group) group.querySelectorAll('.comm-tab').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
  });
});

// ── NOTIFICATIONS ──
function filterNotif(btn, type) {
  // 탭 active
  const group = btn.closest('.comm-tabs');
  if (group) group.querySelectorAll('.comm-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  // 항목 필터
  document.querySelectorAll('#notif-list .notif-item').forEach(el => {
    el.style.display = (type === 'all' || el.dataset.type === type) ? '' : 'none';
  });
}

function markAllRead() {
  document.querySelectorAll('.notif-item.unread').forEach(el => {
    el.classList.remove('unread');
    const dot = el.querySelector('.notif-dot');
    if (dot) dot.remove();
  });
  const badge = document.getElementById('notif-badge');
  if (badge) badge.style.display = 'none';
}

// ── CHAT ──
const chatData = {
  futsal:    { name:'성수 풋살 나이트', icon:'⚽', meta:'멤버 12명 · 오늘 20:00 성수 실내풋살장' },
  badminton: { name:'건대 배드민턴 믹스', icon:'🏸', meta:'멤버 6명 · 목요일 19:30 건대 실내체육관' },
  running:   { name:'성동 나이트 러닝 크루', icon:'🏃', meta:'멤버 41명 · 평일 21:00 성수역 집합' },
  basketball:{ name:'뚝섬 농구 스크림', icon:'🏀', meta:'멤버 10명 · 주말 18:00 뚝섬한강공원' },
  training:  { name:'퍼포먼스 트레이닝', icon:'💪', meta:'멤버 16명 · 수요일 20:00 왕십리' }
};
