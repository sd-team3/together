let leafletFilterActive = 'all';

function makeLeafletIcon(emoji, color) {
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="44" height="52" viewBox="0 0 44 52">
    <path d="M22 0C10 0 1 9 1 21c0 16 21 31 21 31s21-15 21-31C43 9 34 0 22 0z" fill="${color}" stroke="rgba(255,255,255,0.7)" stroke-width="2"/>
    <text x="22" y="27" text-anchor="middle" dominant-baseline="middle" font-size="18">${emoji}</text>
  </svg>`;
  return L.divIcon({
    html: svg,
    iconSize: [44, 52],
    iconAnchor: [22, 52],
    popupAnchor: [0, -54],
    className: ''
  });
}

function initLeafletMap() {
  if (leafletMap) return;

  leafletMap = L.map('leaflet-map', { zoomControl: false }).setView([37.5350, 127.0050], 13);

  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> © <a href="https://carto.com/">CARTO</a>',
    subdomains: 'abcd',
    maxZoom: 19
  }).addTo(leafletMap);

  // 내 위치 마커 (성수동 기준)
  const myIcon = L.divIcon({
    html: `<div style="width:14px;height:14px;background:#C8FF00;border:2px solid #111;border-radius:50%;box-shadow:0 0 0 8px rgba(200,255,0,.25)"></div>`,
    iconSize: [14,14], iconAnchor: [7,7], className: ''
  });
  L.marker([37.5447, 127.0461], { icon: myIcon }).addTo(leafletMap)
    .bindTooltip('📍 내 위치', { permanent: false });

  // 줌 컨트롤 (우측 상단)
  L.control.zoom({ position: 'topright' }).addTo(leafletMap);

  leafletMatches.forEach(m => {
    const marker = L.marker([m.lat, m.lng], { icon: makeLeafletIcon(m.emoji, m.color) })
      .addTo(leafletMap)
      .bindPopup(`
        <div style="font-family:'DM Sans',sans-serif;min-width:200px;padding:4px 0">
          <div style="font-size:15px;font-weight:700;margin-bottom:6px">${m.emoji} ${m.title}</div>
          <div style="font-size:12px;color:#666;margin-bottom:3px">📍 ${m.addr}</div>
          <div style="font-size:12px;color:#666;margin-bottom:3px">⏰ ${m.time}</div>
          <div style="font-size:12px;color:#666;margin-bottom:3px">👥 ${m.members} · ${m.level}</div>
          <div style="font-size:13px;font-weight:700;color:${m.color};margin-top:8px">💰 ${m.fee}</div>
          <button onclick="showMapPopup('${m.title}','${m.addr}','${m.time}','${m.members}','${m.emoji}','${m.level}','${m.fee}')"
            style="margin-top:10px;width:100%;padding:7px;background:#111;color:#fff;border:none;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer">
            참가 신청하기
          </button>
        </div>
      `, { maxWidth: 240 });
    marker._sportEmoji = m.emoji;
    leafletMarkers.push(marker);
  });
}

// ── COMMUNITY FILTERS ──
let currentCommCat = 'all';
let currentCommPeriod = 'daily';

const periodLabels = {
  daily: '📅 오늘의 인기글',
  weekly: '📅 이번 주 인기글',
  monthly: '📅 이번 달 인기글'
};

// Simulated like counts by period (multiplier for demo)
const periodMultiplier = { daily: 1, weekly: 5, monthly: 20 };

function filterCommTab(btn, cat) {
  document.querySelectorAll('.comm-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  currentCommCat = cat;
  applyCommFilter();
}

function filterCommPeriod(btn, period) {
  document.querySelectorAll('.comm-period-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentCommPeriod = period;
  document.getElementById('comm-period-label').textContent = periodLabels[period];
  applyCommFilter();
}

function applyCommFilter() {
  const posts = document.querySelectorAll('#comm-posts .post-item');
  const mul = periodMultiplier[currentCommPeriod];

  // Filter by category
  posts.forEach(p => {
    const cat = p.dataset.cat;
    const show = currentCommCat === 'all' || cat === currentCommCat;
    p.style.display = show ? '' : 'none';
  });

  // Sort visible posts by likes * period multiplier
  const container = document.getElementById('comm-posts');
  const visible = [...posts].filter(p => p.style.display !== 'none');
  visible.sort((a, b) => {
    const la = parseInt(a.dataset.likes || 0) * mul;
    const lb = parseInt(b.dataset.likes || 0) * mul;
    return lb - la;
  });
  visible.forEach(p => container.appendChild(p));
}

// ── REGULAR MEETING FILTER ──
function regFilter(btn, type) {
  document.querySelectorAll('.reg-filter-chip').forEach(c => c.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('.reg-card').forEach(card => {
    if (type === 'all') {
      card.style.display = '';
    } else {
      const f = card.dataset.filter || '';
      card.style.display = f.includes(type) ? '' : 'none';
    }
  });
}

function leafletFilterToggle(btn, type) {
  document.querySelectorAll('.map-filter-chip').forEach(c => c.classList.remove('on'));
  btn.classList.add('on');
  leafletFilterActive = type;
  leafletMarkers.forEach((marker, i) => {
    const m = leafletMatches[i];
    if (type === 'all' || m.emoji === type) {
      if (!leafletMap.hasLayer(marker)) marker.addTo(leafletMap);
    } else {
      if (leafletMap.hasLayer(marker)) leafletMap.removeLayer(marker);
    }
  });
}


