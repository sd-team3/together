  { title:'뚝섬 3on3 농구',    addr:'성동구 뚝섬',   time:'오늘 18:00', members:'5/6명',  emoji:'🏀', level:'중급', fee:'무료',    lat:37.5475, lng:127.0526, color:'#FF6B00', day:'D-0' },
  { title:'홍대 배드민턴',     addr:'마포구 홍대입구', time:'내일 20:00', members:'3/8명',  emoji:'🏸', level:'입문', fee:'5,000원', lat:37.5563, lng:126.9236, color:'#00C8D4', day:'D-1' },
