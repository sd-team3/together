    {mine:true,text:'저 가능해요!',time:'20:12'},
    {from:'이현',color:'#00C8D4',init:'이',text:'저도요!',time:'20:13'}
  ],
  training:[
    {type:'date',text:'2일 전'},
    {from:'트레이너',color:'#f59e0b',init:'트',text:'이번 주 루틴 공유드립니다 📋\n코어 20분 → 민첩성 드릴 15분 → 쿨다운 10분',time:'10:00'},
    {mine:true,text:'감사합니다! 혼자 연습해 볼게요',time:'10:30'}
  ]
};
const chatReplies = {
  futsal:[{from:'김민준',color:'#7c3aed',init:'민',texts:['ㅋㅋ 맞아요!','그럼 이따 봬요 👋','저도 지금 출발해요']}],
  badminton:[{from:'주최자',color:'#16a34a',init:'주',texts:['넵 환영합니다! 🙌','혹시 실력은 어느 정도이신가요?']}],
  running:[{from:'박수아',color:'#f97316',init:'박',texts:['오 진짜요?? 저도 갈게요!','같이 달려요 🏃']}],
  basketball:[{from:'김슬',color:'#ef4444',init:'김',texts:['좋아요! 확정이에요 ✅']}],
