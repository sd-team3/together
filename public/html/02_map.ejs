};
let currentRoom = 'futsal';

function openChatRoom(roomId, el) {
  currentRoom = roomId;
  document.querySelectorAll('.chat-room-item').forEach(r => r.classList.remove('active'));
  if (el) el.classList.add('active');
  const unread = el ? el.querySelector('.cr-unread') : null;
  if (unread) unread.remove();
  const room = chatData[roomId];
  if (!room) return;
  document.getElementById('chatRoomIcon').textContent = room.icon;
  document.getElementById('chatRoomName').textContent = room.name;
  document.getElementById('chatRoomMeta').textContent = room.meta;
  document.querySelector('.chat-icon-btn[title="모임 정보"]').onclick = () =>
    showModal(room.icon+' '+room.name, room.meta.replace(/·/g,'<br>'));

  if (roomId === 'futsal') {
    setTimeout(() => { document.getElementById('chatMessages').scrollTop = 99999; }, 50);
    return;
  }
  const msgs = document.getElementById('chatMessages');
  msgs.innerHTML = '';
  let lastFrom = null;
  (chatMsgs[roomId] || []).forEach(m => {
    if (m.type === 'date') {
      msgs.innerHTML += `<div class="chat-date-divider">${m.text}</div>`;
      lastFrom = null; return;
    }
    if (m.mine) {
      msgs.innerHTML += `<div class="msg-row mine"><div class="msg-content"><div class="msg-bubble mine">${m.text.replace(/\n/g,'<br>')}</div><div class="msg-time">${m.time}</div></div></div>`;
      lastFrom = 'mine';
    } else {
      const showAv = lastFrom !== m.from;
      msgs.innerHTML += `<div class="msg-row"><div class="msg-av ${showAv?'':'hidden'}" style="background:linear-gradient(135deg,${m.color},${m.color}bb)">${m.init}</div><div class="msg-content">${showAv?`<div class="msg-sender">${m.from}</div>`:''}<div class="msg-bubble theirs">${m.text.replace(/\n/g,'<br>')}</div><div class="msg-time">${m.time}</div></div></div>`;
      lastFrom = m.from;
    }
  });
  msgs.innerHTML += `<div id="typingRow" class="msg-row" style="display:none"><div class="msg-av" style="background:var(--border)">?</div><div class="msg-content"><div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div></div>`;
  setTimeout(() => { msgs.scrollTop = 99999; }, 50);
}

function sendChatMsg() {
  const input = document.getElementById('chatInput');
  const text = input.value.trim();
  if (!text) return;
  input.value = '';
  const msgs = document.getElementById('chatMessages');
  const typingRow = document.getElementById('typingRow');
  const now = new Date();
  const t = now.getHours() + ':' + String(now.getMinutes()).padStart(2,'0');
  const myMsg = document.createElement('div');
  myMsg.className = 'msg-row mine';
  myMsg.innerHTML = `<div class="msg-content"><div class="msg-bubble mine">${text}</div><div class="msg-time">${t}</div></div>`;
  msgs.insertBefore(myMsg, typingRow);
  msgs.scrollTop = 99999;
  setTimeout(() => { if (typingRow) typingRow.style.display = 'flex'; msgs.scrollTop = 99999; }, 600);
  const pool = chatReplies[currentRoom] || chatReplies.futsal;
  const replySet = pool[Math.floor(Math.random() * pool.length)];
  const replyText = replySet.texts[Math.floor(Math.random() * replySet.texts.length)];
  setTimeout(() => {
    if (typingRow) typingRow.style.display = 'none';
    const rMsg = document.createElement('div');
    rMsg.className = 'msg-row';
    rMsg.innerHTML = `<div class="msg-av" style="background:linear-gradient(135deg,${replySet.color},${replySet.color}bb)">${replySet.init}</div><div class="msg-content"><div class="msg-sender">${replySet.from}</div><div class="msg-bubble theirs">${replyText}</div><div class="msg-time">${t}</div></div>`;
    msgs.insertBefore(rMsg, typingRow);
    msgs.scrollTop = 99999;
  }, 1800);
}

