<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
<%- include('partials/navbar') %>
<!-- ═══════ MAIN ═══════ -->

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<!-- ──────── RANKING PAGE ──────── -->
<%- include('partials/head', { title: '🏆 랭킹', pageId: 'page-community', active: '' }) %>

  <div class="page-body-wide" style="flex:1">
    <div class="ranking-layout" style="flex:1">
      <div class="ranking-main">
        <!-- Podium -->
        <div class="podium">
          <div class="podium-item p2">
            <div class="podium-av">LJ</div>
            <div class="podium-name">이지환</div>
            <div class="podium-pts">2,180pt</div>
            <div class="podium-block">2</div>
          </div>
          <div class="podium-item p1">
            <div class="podium-av">KM</div>
            <div class="podium-name">김민준</div>
            <div class="podium-pts">2,640pt</div>
            <div class="podium-block">🏆</div>
          </div>
          <div class="podium-item p3">
            <div class="podium-av">PS</div>
            <div class="podium-name">박수아</div>
            <div class="podium-pts">1,950pt</div>
            <div class="podium-block">3</div>
          </div>
        </div>
        <!-- Rank list -->
        <div class="card" style="overflow:hidden">
          <div style="padding:14px 16px;border-bottom:1px solid var(--border)"><div style="font-size:12px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:1px">전체 순위</div></div>
          <div class="rank-row"><div class="rank-num gold">1</div><div class="rank-av" style="background:linear-gradient(135deg,#1A5CFF,#00C8D4);color:#fff">KM</div><div class="rank-info-col"><div class="rank-name">김민준</div><div class="rank-meta"><span>⚽ 풋살</span><span>47경기</span></div></div><div><div class="rank-pts">2,640</div><div class="rank-change up">↑2</div></div></div>
          <div class="rank-row"><div class="rank-num silver">2</div><div class="rank-av" style="background:#f3f4f6">LJ</div><div class="rank-info-col"><div class="rank-name">이지환</div><div class="rank-meta"><span>🏀 농구</span><span>38경기</span></div></div><div><div class="rank-pts">2,180</div><div class="rank-change same">–</div></div></div>
          <div class="rank-row"><div class="rank-num bronze">3</div><div class="rank-av" style="background:#f3f4f6">PS</div><div class="rank-info-col"><div class="rank-name">박수아</div><div class="rank-meta"><span>🏃 러닝</span><span>62경기</span></div></div><div><div class="rank-pts">1,950</div><div class="rank-change up">↑1</div></div></div>
          <div class="rank-row"><div class="rank-num">4</div><div class="rank-av" style="background:#f3f4f6">HD</div><div class="rank-info-col"><div class="rank-name">홍다인</div><div class="rank-meta"><span>🏸 배드민턴</span><span>29경기</span></div></div><div><div class="rank-pts">1,720</div><div class="rank-change down">↓1</div></div></div>
          <div class="rank-row"><div class="rank-num">5</div><div class="rank-av" style="background:#f3f4f6">JD</div><div class="rank-info-col"><div class="rank-name">정다은</div><div class="rank-meta"><span>🎾 테니스</span><span>31경기</span></div></div><div><div class="rank-pts">1,610</div><div class="rank-change up">↑3</div></div></div>
          <div class="rank-row"><div class="rank-num">6</div><div class="rank-av" style="background:#f3f4f6">CW</div><div class="rank-info-col"><div class="rank-name">최원준</div><div class="rank-meta"><span>⚽ 풋살</span><span>22경기</span></div></div><div><div class="rank-pts">1,480</div><div class="rank-change down">↓2</div></div></div>
          <div class="rank-row"><div class="rank-num">7</div><div class="rank-av" style="background:#f3f4f6">LH</div><div class="rank-info-col"><div class="rank-name">이현수</div><div class="rank-meta"><span>🏀 농구</span><span>18경기</span></div></div><div><div class="rank-pts">1,340</div><div class="rank-change same">–</div></div></div>
          <div class="rank-row me"><div class="rank-num" style="color:var(--text)">12</div><div class="rank-av" style="background:linear-gradient(135deg,#1A5CFF,#00C8D4);color:#fff">JH</div><div class="rank-info-col"><div class="rank-name">이준혁 <span style="font-size:10px;background:var(--accent);color:var(--text);padding:1px 6px;border-radius:3px;font-family:monospace">나</span></div><div class="rank-meta"><span>⚽ 풋살</span><span>47경기</span></div></div><div><div class="rank-pts">1,024</div><div class="rank-change up">↑4</div></div></div>
        </div>
      </div>
      <!-- Ranking Sidebar -->
      <div class="ranking-sidebar">
        <div class="section-title">내 랭킹</div>
        <div class="rank-info-box" style="margin-bottom:16px">
          <div style="font-size:10px;opacity:.6;margin-bottom:4px;font-family:'DM Mono',monospace;letter-spacing:1px">OVERALL RANK</div>
          <div style="font-family:'DM Mono',monospace;font-size:44px;font-weight:700;letter-spacing:-2px;line-height:1">12<span style="font-size:20px">위</span></div>
          <div style="font-size:12px;margin-top:8px;opacity:.75">성동구 · 이번 달 <span style="color:var(--accent)">↑4</span></div>
        </div>
        <div style="font-size:12.5px;color:var(--text-3);margin-bottom:10px">다음 순위까지 <strong style="color:var(--text)">96pt</strong></div>
        <div class="reg-progress mb-8"><div class="reg-progress-fill" style="width:54%"></div></div>
        <div class="reg-progress-label" style="margin-bottom:20px"><span>1,024 / 1,120pt</span></div>
        <div class="section-title">종목별 랭킹</div>
        <div style="display:flex;flex-direction:column;gap:10px">
          <div class="sport-bar"><div class="sport-bar-top"><span class="sport-bar-label">⚽ 풋살</span><span class="sport-bar-level">7위</span></div><div class="sport-bar-track"><div class="sport-bar-fill" style="width:82%"></div></div></div>
          <div class="sport-bar"><div class="sport-bar-top"><span class="sport-bar-label">🏸 배드민턴</span><span class="sport-bar-level">15위</span></div><div class="sport-bar-track"><div class="sport-bar-fill" style="width:56%"></div></div></div>
          <div class="sport-bar"><div class="sport-bar-top"><span class="sport-bar-label">🏃 러닝</span><span class="sport-bar-level">22위</span></div><div class="sport-bar-track"><div class="sport-bar-fill" style="width:38%"></div></div></div>
        </div>
        <div class="divider"></div>
        <div class="section-title">종목별 랭킹</div>
        <div class="chip-group">
        <div class="chip on" onclick="singleChip(this)">종합</div>
        <div class="chip" onclick="singleChip(this)">⚽ 풋살</div>
        <div class="chip" onclick="singleChip(this)">🏀 농구</div>
        <div class="chip" onclick="singleChip(this)">🏸 배드민턴</div>
      </div>
      </div>
    </div>
  </div>
</div>


</div><!-- /main -->

<div class="map-popup-overlay" id="map-popup" onclick="if(event.target===this)closeMapPopup()">
  <div class="map-popup">
    <button class="popup-close" onclick="closeMapPopup()">✕</button>
    <div class="popup-sport" id="pp-sport">⚽</div>
    <div class="popup-title" id="pp-title">강남 풋살파크 5:5 매칭</div>
    <div class="popup-meta">
      <span id="pp-loc">📍 강남구 역삼동</span>
      <span id="pp-time">⏰ 오늘 19:30</span>
      <span id="pp-members">👥 6/10명</span>
      <span>💰 <span id="pp-price">10,000원</span></span>
    </div>
    <div class="flex gap-6 mb-16">
      <span class="tag tag-outline" id="pp-level">중급</span>
      <span class="tag tag-green">실내</span>
    </div>
    <div class="popup-host">
      <div class="popup-host-av">K</div>
      <div><div class="popup-host-name">강남킬러 <span style="color:var(--text-3);font-weight:400">⭐ 4.9</span></div><div class="popup-host-sub">47경기 · 매너 우수</div></div>
    </div>
    <div class="popup-btns">
      <button class="btn btn-primary flex-1" onclick="closeMapPopup();showModal('🎉 참가 신청 완료!','매칭에 참가 신청이 완료되었습니다!<br>당일 30분 전 알림을 드립니다.',null)">참가 신청</button>
      <button class="btn btn-outline" onclick="closeMapPopup()">공유 🔗</button>
    </div>
  </div>
</div>

<!-- ═══════ AUTH MODALS ═══════ -->
<!-- Login Modal -->
<div class="auth-modal-overlay" id="modal-login" onclick="if(event.target===this)closeAuthModal('login')">
  <div class="auth-modal-box">
    <button class="auth-close" onclick="closeAuthModal('login')">✕</button>
    <div class="auth-header">
      <div class="auth-title">다시 만나서 반가워요! 👋</div>
      <div class="auth-sub">SPORTMATCH에 오신 것을 환영합니다.</div>
    </div>
    <div class="social-login">
      <button class="social-btn kakao" onclick="handleAuthSuccess('로그인')">💬 카카오로 시작하기</button>
      <button class="social-btn" onclick="handleAuthSuccess('로그인')">🌐 구글로 시작하기</button>
    </div>
    <div class="field">
      <label class="label">이메일</label>
      <input type="email" class="input" placeholder="example@sportmatch.com">
    </div>
    <div class="field">
      <label class="label">비밀번호</label>
      <input type="password" class="input" placeholder="••••••••">
    </div>
    <button class="btn btn-primary btn-full btn-lg" style="margin-top:10px" onclick="handleAuthSuccess('로그인')">로그인</button>
    <div class="auth-footer">
      아직 회원이 아니신가요? <span class="auth-link" onclick="switchAuthModal('login', 'signup')">회원가입</span>
    </div>
  </div>
</div>

<!-- Signup Modal -->
<div class="auth-modal-overlay" id="modal-signup" onclick="if(event.target===this)closeAuthModal('signup')">
  <div class="auth-modal-box">
    <button class="auth-close" onclick="closeAuthModal('signup')">✕</button>
    <div class="auth-header">
      <div class="auth-title">환영합니다! 🏅</div>
      <div class="auth-sub">지금 가입하고 내 주변 매칭을 찾아보세요.</div>
    </div>
    <div class="social-login">
      <button class="social-btn kakao" onclick="handleAuthSuccess('회원가입')">💬 카카오로 시작하기</button>
      <button class="social-btn" onclick="handleAuthSuccess('회원가입')">🌐 구글로 시작하기</button>
    </div>
    <div class="field">
      <label class="label">이름</label>
      <input type="text" class="input" placeholder="홍길동">
    </div>
    <div class="field">
      <label class="label">이메일</label>
      <input type="email" class="input" placeholder="example@sportmatch.com">
    </div>
    <div class="field">
      <label class="label">비밀번호</label>
      <input type="password" class="input" placeholder="8자 이상 입력해주세요">
    </div>
    <button class="btn btn-primary btn-full btn-lg" style="margin-top:10px" onclick="handleAuthSuccess('회원가입')">회원가입 완료</button>
    <div class="auth-footer">
      이미 계정이 있으신가요? <span class="auth-link" onclick="switchAuthModal('signup', 'login')">로그인</span>
    </div>
  </div>
</div>

<!-- ═══════ MODAL ═══════ -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <div class="modal-icon" id="modal-icon">🎉</div>
    <div class="modal-title" id="modal-title">완료!</div>
    <div class="modal-msg" id="modal-msg">처리가 완료되었습니다.</div>
    <div class="modal-btns">
      <button class="btn btn-outline flex-1" onclick="closeModal()">닫기</button>
      <button class="btn btn-primary flex-1" id="modal-ok" onclick="closeModal()">확인</button>
    </div>
  </div>
</div>

</body>
</html>
