<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

</head>
<body>
<!-- ═══════ SIDEBAR ═══════ -->
<nav class="sidenav">
  <div class="sidenav-logo">
    <div>
      <div class="logo-mark">SPORTMATCH <span style="display:inline-block;vertical-align:middle;width:7px;height:7px;border-radius:50%;background:var(--accent);margin-left:3px;margin-bottom:2px"></span></div>
      <div class="logo-sub">생활 스포츠 매칭</div>
    </div>
  </div>
  <div class="sidenav-menu">
    <div class="nav-section-label">홈</div>
    <button class="nav-item active" data-page="home" onclick="goPage('home')">
      <span class="nav-icon">🏠</span> 홈 피드
      <span class="nav-live"></span>
    </button>

    <div class="nav-section-label">매칭</div>
    <button class="nav-item" data-page="map" onclick="goPage('map')">
      <span class="nav-icon">📍</span> 지도 매칭
    </button>
    <button class="nav-item" data-page="regular" onclick="goPage('regular')">
      <span class="nav-icon">🔁</span> 정기 모임
    </button>

    <div class="nav-section-label">커뮤니티</div>
    <button class="nav-item" data-page="community" onclick="goPage('community')">
      <span class="nav-icon">💬</span> 커뮤니티
      <span class="nav-badge">3</span>
    </button>
    <button class="nav-item" data-page="ranking" onclick="goPage('ranking')">
      <span class="nav-icon">🏆</span> 랭킹
    </button>

    <div class="nav-section-label">기타</div>
    <button class="nav-item" data-page="notifications" onclick="goPage('notifications')">
      <span class="nav-icon">🔔</span> 알림
      <span class="nav-badge" id="notif-badge">4</span>
    </button>
    <button class="nav-item" data-page="trade" onclick="goPage('trade')">
      <span class="nav-icon">🛒</span> 중고 거래
    </button>
    <button class="nav-item" data-page="chat" onclick="goPage('chat')">
      <span class="nav-icon">✉️</span> 채팅
      <span class="nav-badge">5</span>
    </button>
    <button class="nav-item" onclick="showModal('⚙️ 설정','알림, 개인정보, 보안 설정 등을 변경합니다.')">
      <span class="nav-icon">⚙️</span> 설정
    </button>
  </div>
  <div class="sidenav-footer">
    <!-- 비로그인 상태 -->
    <div class="user-chip" id="nav-guest" onclick="openAuthModal('login')" style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm)">
      <div class="user-av" style="background:linear-gradient(135deg,var(--border-strong),var(--text-3));font-size:18px">👤</div>
      <div>
        <div class="user-name" style="color:var(--text-2);font-size:12.5px">로그인이 필요합니다</div>
        <div class="user-level" style="color:var(--primary);font-weight:600">탭하여 로그인 →</div>
      </div>
    </div>
    <!-- 로그인 상태 (숨김) -->
    <div id="nav-user" style="display:none">
      <div class="user-chip" onclick="goPage('mypage')">
        <div class="user-av">JH</div>
        <div>
          <div class="user-name">이준혁</div>
          <div class="user-level">⭐ 중급 · 47경기</div>
        </div>
      </div>
    </div>
  </div>
</nav>

<!-- ═══════ MAIN ═══════ -->

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<!-- ──────── MY PAGE ──────── -->
<div class="page" id="page-mypage" style="display:flex;flex-direction:column;flex:1">
  <div class="topbar">
    <div><div class="topbar-title">👤 마이페이지</div></div>
    <div class="topbar-actions">
      <span class="auth-state-btns" data-state="guest">
        <button class="btn btn-ghost btn-sm" onclick="openAuthModal('login')">로그인</button>
        <button class="btn btn-outline btn-sm" onclick="openAuthModal('signup')">회원가입</button>
      </span>
      <span class="auth-state-btns" data-state="user" style="display:none">
        <button class="btn btn-outline btn-sm" onclick="doLogout()">로그아웃</button>
      </span>
    </div>
  </div>
  <div class="page-body">
    <div class="mypage-layout">
      <!-- Profile Card -->
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="profile-card">
          <div class="profile-banner"></div>
          <div class="profile-av-wrap"><div class="profile-big-av">JH</div></div>
          <div class="profile-info">
            <div class="profile-name">이준혁</div>
            <div class="profile-handle">@junhyuk_runner</div>
            <div class="profile-badges">
              <div class="profile-badge">⭐ 매너 4.9</div>
              <div class="profile-badge">🏅 중급</div>
              <div class="profile-badge">🔥 연속 12주</div>
            </div>
          </div>
          <div class="profile-divider"></div>
          <div class="profile-stat-row">
            <div class="ps-item"><span class="ps-val">47</span><span class="ps-label">경기</span></div>
            <div class="ps-item"><span class="ps-val">3</span><span class="ps-label">클럽</span></div>
            <div class="ps-item"><span class="ps-val">12위</span><span class="ps-label">랭킹</span></div>
          </div>
          <div class="rank-info-box">
            <div style="font-size:10px;opacity:.6;font-family:'DM Mono',monospace;letter-spacing:1px;margin-bottom:3px">RANK</div>
            <div style="font-family:'DM Mono',monospace;font-size:36px;font-weight:700;letter-spacing:-2px;line-height:1">12위</div>
            <div style="font-size:11.5px;margin-top:7px;opacity:.75">성동구 · 이번 달 <span style="color:var(--accent)">↑4</span> 상승</div>
          </div>
        </div>
        <div class="card" style="overflow:hidden">
          <div class="mypage-nav">
            <button class="mypage-nav-item active"><span>📅</span> 참여 일정</button>
            <button class="mypage-nav-item"><span>🏅</span> 참여 이력</button>
            <button class="mypage-nav-item"><span>⭐</span> 작성 후기</button>
            <button class="mypage-nav-item" onclick="goPage('trade')"><span>🛒</span> 판매 목록</button>
            <button class="mypage-nav-item" onclick="showModal('⚙️ 프로필 수정','이름, 사진, 소개 등을 수정합니다.')"><span>✏️</span> 프로필 수정</button>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="mypage-main">
        <!-- Upcoming Schedule -->
        <div class="mypage-card">
          <div class="mypage-card-header"><div class="mypage-card-title">📅 예정된 일정</div><div class="mypage-card-action">전체보기</div></div>
          <div class="mypage-card-body">
            <div class="schedule-item"><div class="sched-time">오늘 20:00</div><div class="sched-dot" style="background:var(--primary)"></div><div class="sched-info"><div class="sched-title">성수 5:5 풋살 매칭</div><div class="sched-sub">📍 성수 실내풋살장</div></div><div class="sched-status" style="color:var(--orange)">D-0</div></div>
            <div class="schedule-item"><div class="sched-time">목 19:30</div><div class="sched-dot" style="background:var(--green)"></div><div class="sched-info"><div class="sched-title">건대 배드민턴 정기모임</div><div class="sched-sub">📍 건대입구 실내체육관</div></div><div class="sched-status" style="color:var(--text-3)">D-3</div></div>
            <div class="schedule-item"><div class="sched-time">토 18:00</div><div class="sched-dot" style="background:var(--orange)"></div><div class="sched-info"><div class="sched-title">뚝섬 농구 스크림</div><div class="sched-sub">📍 뚝섬한강공원</div></div><div class="sched-status" style="color:var(--text-3)">D-5</div></div>
            <div class="schedule-item"><div class="sched-time">일 09:30</div><div class="sched-dot" style="background:var(--cyan)"></div><div class="sched-info"><div class="sched-title">왕십리 테니스 브런치</div><div class="sched-sub">📍 왕십리 테니스장</div></div><div class="sched-status" style="color:var(--text-3)">D-6</div></div>
          </div>
        </div>
        <!-- Activity History -->
        <div class="mypage-card">
          <div class="mypage-card-header"><div class="mypage-card-title">🏅 최근 활동</div><div class="mypage-card-action">전체보기</div></div>
          <div class="mypage-card-body">
            <div class="history-item"><div class="hi-sport">⚽</div><div class="hi-info"><div class="hi-title">성수 풋살 나이트</div><div class="hi-meta"><span>4일 전</span><span>성수 실내풋살장</span></div></div><div class="hi-result win">승</div></div>
            <div class="history-item"><div class="hi-sport">🏸</div><div class="hi-info"><div class="hi-title">건대 배드민턴 믹스</div><div class="hi-meta"><span>1주 전</span><span>건대 실내체육관</span></div></div><div class="hi-result done">참가</div></div>
            <div class="history-item"><div class="hi-sport">🏃</div><div class="hi-info"><div class="hi-title">성동 나이트 러닝</div><div class="hi-meta"><span>1주 전</span><span>성수역 출발 10km</span></div></div><div class="hi-result done">완주</div></div>
            <div class="history-item"><div class="hi-sport">🏀</div><div class="hi-info"><div class="hi-title">뚝섬 3on3 스크림</div><div class="hi-meta"><span>2주 전</span><span>뚝섬한강공원</span></div></div><div class="hi-result draw">무</div></div>
          </div>
        </div>
        <!-- Player Traits & Manner Tags -->
        <div class="mypage-card">
          <div class="mypage-card-header"><div class="mypage-card-title">🎯 플레이어 성향</div></div>
          <div class="mypage-card-body">
            <div class="traits-grid">
              <div class="trait-item">
                <div class="trait-icon">🔥</div>
                <div class="trait-name">열정적인 응원왕</div>
                <div class="trait-desc">팀 분위기를 살리는 긍정 에너지</div>
              </div>
              <div class="trait-item">
                <div class="trait-icon">⚡</div>
                <div class="trait-name">냉정한 전략가</div>
                <div class="trait-desc">경기 분석과 팀 플레이 중심</div>
              </div>
              <div class="trait-item">
                <div class="trait-icon">🎪</div>
                <div class="trait-name">분위기 메이커</div>
                <div class="trait-desc">재미있고 편한 경기 분위기 조성</div>
              </div>
              <div class="trait-item">
                <div class="trait-icon">💪</div>
                <div class="trait-name">지치지 않는 체력</div>
                <div class="trait-desc">끝까지 집중력 유지하는 선수</div>
              </div>
              <div class="trait-item">
                <div class="trait-icon">🤝</div>
                <div class="trait-name">신뢰할 수 있는 팀원</div>
                <div class="trait-desc">약속 준수와 성실한 참여</div>
              </div>
              <div class="trait-item">
                <div class="trait-icon">🎓</div>
                <div class="trait-name">친절한 멘토</div>
                <div class="trait-desc">초보자 배려와 팁 공유</div>
              </div>
            </div>
          </div>
        </div>
        <!-- Manner Keywords -->
        <div class="mypage-card">
          <div class="mypage-card-header"><div class="mypage-card-title">⭐ 매너 키워드</div></div>
          <div class="mypage-card-body">
            <div class="manner-tags">
              <span class="manner-tag manner-tag-primary">시간 약속 철저 (47회)</span>
              <span class="manner-tag manner-tag-accent">긍정적인 태도 (32회)</span>
              <span class="manner-tag manner-tag-green">배려 있는 플레이 (28회)</span>
              <span class="manner-tag manner-tag-primary">팀 분위기 좋음 (24회)</span>
              <span class="manner-tag manner-tag-accent">초보자 친화적 (18회)</span>
              <span class="manner-tag manner-tag-green">성실한 참여 (15회)</span>
            </div>
            <div style="margin-top:14px;padding-top:14px;border-top:1px solid var(--border)">
              <div style="font-size:11px;color:var(--text-3);margin-bottom:8px">최근 매칭 후기 점수</div>
              <div style="display:flex;align-items:baseline;gap:8px">
                <div style="font-size:28px;font-weight:700;font-family:'DM Mono',monospace">4.9</div>
                <div style="font-size:14px;color:var(--green)">⭐⭐⭐⭐⭐</div>
                <div style="font-size:11px;color:var(--text-3);margin-left:auto">47명 평가</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


</div><!-- /main -->

<div class="map-popup-overlay" id="map-popup" onclick="if(event.target===this)closeMapPopup()">
  <div class="map-popup">
    <button class="popup-close" onclick="closeMapPopup()">✕</button>
    <div class="popup-sport" id="pp-sport">⚽</div>
    <div class="popup-title" id="pp-title">강남 풋살파크 5:5 매칭</div>
    <div class="popup-meta">
      <span id="pp-loc">📍 강남구 역삼동</span>
      <span id="pp-time">⏰ 오늘 19:30</span>
      <span id="pp-members">👥 6/10명</span>
      <span>💰 <span id="pp-price">10,000원</span></span>
    </div>
    <div class="flex gap-6 mb-16">
      <span class="tag tag-outline" id="pp-level">중급</span>
      <span class="tag tag-green">실내</span>
    </div>
    <div class="popup-host">
      <div class="popup-host-av">K</div>
      <div><div class="popup-host-name">강남킬러 <span style="color:var(--text-3);font-weight:400">⭐ 4.9</span></div><div class="popup-host-sub">47경기 · 매너 우수</div></div>
    </div>
    <div class="popup-btns">
      <button class="btn btn-primary flex-1" onclick="closeMapPopup();showModal('🎉 참가 신청 완료!','매칭에 참가 신청이 완료되었습니다!<br>당일 30분 전 알림을 드립니다.',null)">참가 신청</button>
      <button class="btn btn-outline" onclick="closeMapPopup()">공유 🔗</button>
    </div>
  </div>
</div>

<!-- ═══════ AUTH MODALS ═══════ -->
<!-- Login Modal -->
<div class="auth-modal-overlay" id="modal-login" onclick="if(event.target===this)closeAuthModal('login')">
  <div class="auth-modal-box">
    <button class="auth-close" onclick="closeAuthModal('login')">✕</button>
    <div class="auth-header">
      <div class="auth-title">다시 만나서 반가워요! 👋</div>
      <div class="auth-sub">SPORTMATCH에 오신 것을 환영합니다.</div>
    </div>
    <div class="social-login">
      <button class="social-btn kakao" onclick="handleAuthSuccess('로그인')">💬 카카오로 시작하기</button>
      <button class="social-btn" onclick="handleAuthSuccess('로그인')">🌐 구글로 시작하기</button>
    </div>
    <div class="field">
      <label class="label">이메일</label>
      <input type="email" class="input" placeholder="example@sportmatch.com">
    </div>
    <div class="field">
      <label class="label">비밀번호</label>
      <input type="password" class="input" placeholder="••••••••">
    </div>
    <button class="btn btn-primary btn-full btn-lg" style="margin-top:10px" onclick="handleAuthSuccess('로그인')">로그인</button>
    <div class="auth-footer">
      아직 회원이 아니신가요? <span class="auth-link" onclick="switchAuthModal('login', 'signup')">회원가입</span>
    </div>
  </div>
</div>

<!-- Signup Modal -->
<div class="auth-modal-overlay" id="modal-signup" onclick="if(event.target===this)closeAuthModal('signup')">
  <div class="auth-modal-box">
    <button class="auth-close" onclick="closeAuthModal('signup')">✕</button>
    <div class="auth-header">
      <div class="auth-title">환영합니다! 🏅</div>
      <div class="auth-sub">지금 가입하고 내 주변 매칭을 찾아보세요.</div>
    </div>
    <div class="social-login">
      <button class="social-btn kakao" onclick="handleAuthSuccess('회원가입')">💬 카카오로 시작하기</button>
      <button class="social-btn" onclick="handleAuthSuccess('회원가입')">🌐 구글로 시작하기</button>
    </div>
    <div class="field">
      <label class="label">이름</label>
      <input type="text" class="input" placeholder="홍길동">
    </div>
    <div class="field">
      <label class="label">이메일</label>
      <input type="email" class="input" placeholder="example@sportmatch.com">
    </div>
    <div class="field">
      <label class="label">비밀번호</label>
      <input type="password" class="input" placeholder="8자 이상 입력해주세요">
    </div>
    <button class="btn btn-primary btn-full btn-lg" style="margin-top:10px" onclick="handleAuthSuccess('회원가입')">회원가입 완료</button>
    <div class="auth-footer">
      이미 계정이 있으신가요? <span class="auth-link" onclick="switchAuthModal('signup', 'login')">로그인</span>
    </div>
  </div>
</div>

<!-- ═══════ MODAL ═══════ -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <div class="modal-icon" id="modal-icon">🎉</div>
    <div class="modal-title" id="modal-title">완료!</div>
    <div class="modal-msg" id="modal-msg">처리가 완료되었습니다.</div>
    <div class="modal-btns">
      <button class="btn btn-outline flex-1" onclick="closeModal()">닫기</button>
      <button class="btn btn-primary flex-1" id="modal-ok" onclick="closeModal()">확인</button>
    </div>
  </div>
</div>

</body>
</html>
