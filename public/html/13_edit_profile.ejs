<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 프로필 수정</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>

<%- include('../partials/navbar') %>

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<!-- head -->
<%- include('../partials/head', { 
  title: '✏️ 프로필 수정', 
  pageId: 'page-edit-profile', 
  active: '' 
}) %>

    <!-- 본문 -->
    <div class="page-body" style="overflow-y:auto">
      <div class="edit-wrap">

        <!-- ① 프로필 이미지 -->
        <div>
          <div class="edit-section-title">프로필 이미지</div>
          <div class="avatar-section">
            <div class="avatar-preview-wrap">
              <div class="avatar-preview" id="avatar-preview">
                JH
                <img id="avatar-img" src="" alt="프로필 이미지">
              </div>
              <label class="avatar-edit-label" for="avatar-file" title="이미지 변경">✏️</label>
              <input type="file" id="avatar-file" accept="image/*" style="display:none">
            </div>
            <div class="avatar-info">
              <div class="avatar-info-title">프로필 사진 변경</div>
              <div class="avatar-info-sub">JPG, PNG, GIF 형식 지원 · 최대 5MB<br>정사각형 이미지를 권장합니다.</div>
              <div class="avatar-btns">
                <label class="avatar-upload-label" for="avatar-file">📁 이미지 업로드</label>
                <button class="avatar-remove-btn" id="remove-btn" style="display:none">삭제</button>
              </div>
            </div>
          </div>
        </div>

        <!-- ② 기본 정보 -->
        <div>
          <div class="edit-section-title">기본 정보 <span class="change-badge" id="badge-basic">● 변경됨</span></div>
          <div class="edit-card">
            <div class="form-grid-2">
              <!-- 이메일 (읽기 전용) -->
              <div class="edit-field field-full">
                <label class="edit-label">
                  이메일
                  <span class="label-readonly">🔒 변경 불가</span>
                </label>
                <input
                  type="email"
                  class="edit-input readonly-field"
                  value="test@test.com"
                  readonly
                  tabindex="-1"
                >
                <div class="email-notice">ℹ️ 이메일은 보안상 이유로 변경할 수 없습니다. 변경이 필요하면 고객센터에 문의하세요.</div>
              </div>

              <!-- 이름 -->
              <div class="edit-field">
                <label class="edit-label">
                  이름
                  <span class="label-required">필수</span>
                </label>
                <input
                  type="text"
                  class="edit-input"
                  id="input-name"
                  value="홍길동"
                  placeholder="이름을 입력하세요"
                >
              </div>

              <!-- 나이 -->
              <div class="edit-field">
                <label class="edit-label">나이</label>
                <input
                  type="number"
                  class="edit-input"
                  id="input-age"
                  value="23"
                  placeholder="나이를 입력하세요"
                  min="1" max="120"
                >
              </div>

              <!-- 전화번호 -->
              <div class="edit-field field-full">
                <label class="edit-label">전화번호</label>
                <input
                  type="tel"
                  class="edit-input"
                  id="input-phone"
                  value="124124124"
                  placeholder="010-0000-0000"
                >
                <div class="input-hint">숫자만 입력하면 자동으로 서식이 적용됩니다.</div>
              </div>
            </div>
          </div>
        </div>

        <!-- ③ 주소 -->
        <div>
          <div class="edit-section-title">주소 <span class="change-badge" id="badge-addr">● 변경됨</span></div>
          <div class="edit-card">
            <div class="form-grid-2">
              <div class="edit-field field-full">
                <label class="edit-label">주소 검색</label>
                <div class="addr-row">
                  <input
                    type="text"
                    class="edit-input"
                    id="input-zipcode"
                    value="123456"
                    placeholder="우편번호"
                    readonly
                    style="max-width:130px;flex:none"
                  >
                  <button class="addr-search-btn" type="button" id="addr-search-btn">🔍 주소 검색</button>
                </div>
              </div>
              <div class="edit-field field-full">
                <label class="edit-label">기본 주소</label>
                <input
                  type="text"
                  class="edit-input"
                  id="input-addr1"
                  value="서울시 어딘가"
                  placeholder="기본 주소"
                  readonly
                >
              </div>
              <div class="edit-field field-full">
                <label class="edit-label">상세 주소</label>
                <input
                  type="text"
                  class="edit-input"
                  id="input-addr2"
                  value="동봉구"
                  placeholder="상세 주소를 입력하세요 (동, 호수 등)"
                >
              </div>
            </div>
          </div>
        </div>

        <!-- ④ 비밀번호 변경 -->
        <div>
          <div class="edit-section-title">비밀번호 변경 <span class="change-badge" id="badge-pw">● 변경됨</span></div>
          <div class="edit-card">
            <div class="form-grid-2">
              <!-- 현재 비밀번호 -->
              <div class="edit-field field-full">
                <label class="edit-label">현재 비밀번호</label>
                <div class="pw-input-wrap">
                  <input type="password" class="edit-input" id="input-pw-current" placeholder="현재 비밀번호 입력">
                  <button class="pw-eye-inline" type="button" id="tog1">👁️</button>
                </div>
              </div>
              <!-- 새 비밀번호 -->
              <div class="edit-field">
                <label class="edit-label">새 비밀번호</label>
                <div class="pw-input-wrap">
                  <input type="password" class="edit-input" id="input-pw-new" placeholder="8자 이상">
                  <button class="pw-eye-inline" type="button" id="tog2">👁️</button>
                </div>
                <div class="pw-strength-wrap" id="pw-strength-wrap">
                  <div class="pw-strength-bar-bg">
                    <div class="pw-strength-bar" id="pw-bar"></div>
                  </div>
                  <div class="pw-strength-text" id="pw-strength-text"></div>
                </div>
              </div>
              <!-- 새 비밀번호 확인 -->
              <div class="edit-field">
                <label class="edit-label">새 비밀번호 확인</label>
                <div class="pw-input-wrap">
                  <input type="password" class="edit-input" id="input-pw-confirm" placeholder="비밀번호 재입력">
                  <button class="pw-eye-inline" type="button" id="tog3">👁️</button>
                </div>
                <div class="input-hint" id="pw-match-hint"></div>
              </div>
            </div>
            <div class="edit-section-divider">
              ℹ️ 비밀번호를 변경하지 않으려면 위 칸을 비워두세요. 새 비밀번호는 8자 이상이어야 하며 영문·숫자 조합을 권장합니다.
            </div>
          </div>
        </div>

        <!-- ⑤ 저장 버튼 -->
        <div class="edit-actions">
          <button class="edit-cancel-btn" id="cancel-btn" type="button">취소</button>
          <button class="edit-save-btn" id="save-btn" type="button">💾 변경사항 저장</button>
        </div>

      </div>
    </div>
  </div>
</div><!-- /main -->

<!-- ═══════ MODAL ═══════ -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <div class="modal-icon" id="modal-icon">🎉</div>
    <div class="modal-title" id="modal-title">완료!</div>
    <div class="modal-msg" id="modal-msg">처리가 완료되었습니다.</div>
    <div class="modal-btns">
      <button class="btn btn-outline flex-1" id="modal-close">닫기</button>
      <button class="btn btn-primary flex-1" id="modal-ok">확인</button>
    </div>
  </div>
</div>

<!-- 토스트 -->
<div class="toast-notify" id="toast"></div>

</body>
</html>
