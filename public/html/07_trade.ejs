<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
<%- include('partials/navbar') %>
<!-- ═══════ MAIN ═══════ -->

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<!-- ──────── TRADE PAGE ──────── -->
<%- include('partials/head', { title: '🛒 중고 거래', pageId: 'page-trade', active: '' }) %>

  <div class="page-body-wide" style="flex:1">
    <div class="trade-layout" style="flex:1">
      <div class="trade-filter">
        <div class="trade-filter-scroll">
        <div class="section-title">카테고리</div>
          <div class="filter-section">
            <div class="filter-item active" onclick="filterTrade(this, 'all', 'type')">🏷️ 전체</div>
            <div class="filter-item" onclick="filterTrade(this, 'football', 'type')">⚽ 풋살/축구</div>
            <div class="filter-item" onclick="filterTrade(this, 'basketball', 'type')">🏀 농구</div>
            <div class="filter-item" onclick="filterTrade(this, 'badminton', 'type')">🏸 배드민턴</div>
            <div class="filter-item" onclick="filterTrade(this, 'tennis', 'type')">🎾 테니스</div>
            <div class="filter-item" onclick="filterTrade(this, 'running', 'type')">🏃 러닝</div>
            <div class="filter-item" onclick="filterTrade(this, 'training', 'type')">💪 헬스/트레이닝</div>
            <div class="filter-item" onclick="filterTrade(this, 'clothes', 'type')">👕 의류</div>
          </div>
          <div class="divider"></div>
          <div class="section-title">상태</div>
          <div class="filter-section">
            <div class="filter-item active" onclick="filterTrade(this, 'all', 'condition')">전체</div>
            <div class="filter-item" onclick="filterTrade(this, 'new', 'condition')">거의 새 것</div>
            <div class="filter-item" onclick="filterTrade(this, 'good', 'condition')">상태 좋음</div>
            <div class="filter-item" onclick="filterTrade(this, 'normal', 'condition')">보통</div>
          </div>
          <div class="divider"></div>
          <div class="section-title">가격대</div>
          <div class="filter-section">
            <div class="filter-item active" onclick="filterTrade(this, 'all', 'money')">전체</div>
            <div class="filter-item" onclick="filterTrade(this, 'under1', 'money')">1만원 미만</div>
            <div class="filter-item" onclick="filterTrade(this, '1to10', 'money')">1 ~ 10만원</div>
            <div class="filter-item" onclick="filterTrade(this, 'over10', 'money')">10만원 이상</div>
          </div>
        </div>
        <div class="sidenav-footer">
          <button class="btn btn-primary" onclick="" style="width:100%">+ 판매 등록</button>
        </div>
      </div>
      <div class="trade-main">
        <div class="flex items-center justify-between mb-16">
          <div class="section-title" style="margin-bottom:0">목록</div>
          <div class="flex gap-6">
            <select class="input" style="width:auto;padding:6px 10px;font-size:12.5px">
              <option>최신순</option><option>가격 낮은순</option><option>인기순</option>
            </select>
          </div>
        </div>
        <div id="trade-grid">
          <div class="trade-card" data-type="football" data-condition="new" data-money="1to10">
            <div class="trade-thumb">⚽<div class="trade-condition"><span class="tag tag-green">거의새것</span></div></div>
            <div class="trade-body">
              <div class="trade-title">나이키 풋살화 250 (3회 착용)</div>
              <div class="trade-price">45,000원</div>
              <div class="trade-meta"><span>📍 성동구</span><span>⏰ 1시간 전</span></div>
            </div>
          </div>
          <div class="trade-card" data-type="badminton" data-condition="good" data-money="1to10">
            <div class="trade-thumb">🏸<div class="trade-condition"><span class="tag tag-blue">상태좋음</span></div></div>
            <div class="trade-body">
              <div class="trade-title">요넥스 배드민턴 라켓 세트</div>
              <div class="trade-price">32,000원</div>
              <div class="trade-meta"><span>📍 광진구</span><span>⏰ 3시간 전</span></div>
            </div>
          </div>
          <div class="trade-card" data-type="basketball" data-condition="new" data-money="under1">
            <div class="trade-thumb">🏀<div class="trade-condition"><span class="tag tag-green">거의새것</span></div></div>
            <div class="trade-body">
              <div class="trade-title">나이키 농구공 Official Size 7</div>
              <div class="trade-price">8,000원</div>
              <div class="trade-meta"><span>📍 마포구</span><span>⏰ 5시간 전</span></div>
            </div>
          </div>
          <div class="trade-card" data-type="tennis" data-condition="normal" data-money="under1">
            <div class="trade-thumb">🎾<div class="trade-condition"><span class="tag tag-orange">보통</span></div></div>
            <div class="trade-body">
              <div class="trade-title">윌슨 테니스 라켓 + 케이스</div>
              <div class="trade-price">5,000원</div>
              <div class="trade-meta"><span>📍 성동구</span><span>⏰ 어제</span></div>
            </div>
          </div>
          <div class="trade-card" data-type="clothes" data-condition="new" data-money="over10">
            <div class="trade-thumb">👟<div class="trade-condition"><span class="tag tag-green">거의새것</span></div></div>
            <div class="trade-body">
              <div class="trade-title">아디다스 러닝화 260 (10회)</div>
              <div class="trade-price">138,000원</div>
              <div class="trade-meta"><span>📍 용산구</span><span>⏰ 어제</span></div>
            </div>
          </div>
          <div class="trade-card" data-type="training" data-condition="good" data-money="over10">
            <div class="trade-thumb">💪<div class="trade-condition"><span class="tag tag-blue">상태좋음</span></div></div>
            <div class="trade-body">
              <div class="trade-title">저항 밴드 세트 5종 (미사용)</div>
              <div class="trade-price">315,000원</div>
              <div class="trade-meta"><span>📍 성동구</span><span>⏰ 2일 전</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


</div><!-- /main -->

<div class="map-popup-overlay" id="map-popup" onclick="if(event.target===this)closeMapPopup()">
  <div class="map-popup">
    <button class="popup-close" onclick="closeMapPopup()">✕</button>
    <div class="popup-sport" id="pp-sport">⚽</div>
    <div class="popup-title" id="pp-title">강남 풋살파크 5:5 매칭</div>
    <div class="popup-meta">
      <span id="pp-loc">📍 강남구 역삼동</span>
      <span id="pp-time">⏰ 오늘 19:30</span>
      <span id="pp-members">👥 6/10명</span>
      <span>💰 <span id="pp-price">10,000원</span></span>
    </div>
    <div class="flex gap-6 mb-16">
      <span class="tag tag-outline" id="pp-level">중급</span>
      <span class="tag tag-green">실내</span>
    </div>
    <div class="popup-host">
      <div class="popup-host-av">K</div>
      <div><div class="popup-host-name">강남킬러 <span style="color:var(--text-3);font-weight:400">⭐ 4.9</span></div><div class="popup-host-sub">47경기 · 매너 우수</div></div>
    </div>
    <div class="popup-btns">
      <button class="btn btn-primary flex-1" onclick="closeMapPopup();showModal('🎉 참가 신청 완료!','매칭에 참가 신청이 완료되었습니다!<br>당일 30분 전 알림을 드립니다.',null)">참가 신청</button>
      <button class="btn btn-outline" onclick="closeMapPopup()">공유 🔗</button>
    </div>
  </div>
</div>

<script>

  let activeType = 'all';
  let activeCondition = 'all';
  let activeMoney = 'all';

  function moneyCheck(price, range) {
      const p = Number(price);
        if(range === 'under1') return p < 10000;
        if(range === '1to10') return p >= 10000 && p < 100000;
        if(range === 'over10') return p >= 100000;
  }

  function filterTrade(btn, value, filterKey) {
    btn.closest('.filter-section').querySelectorAll('.filter-item').forEach(tab => tab.classList.remove('active'));
    btn.classList.add('active');

    if(filterKey === 'type') activeType = value;
    if(filterKey === 'condition') activeCondition = value;
    if(filterKey === 'money') activeMoney = value;

    document.querySelectorAll('#trade-grid .trade-card').forEach(el => {

      const typeMatch = (activeType === 'all' || el.dataset.type === activeType);
      const conditionMatch = (activeCondition === 'all' || el.dataset.condition === activeCondition);
      const moneyMatch = (activeMoney === 'all' || moneyCheck(el.dataset.money, activeMoney));

      el.style.display = (typeMatch && conditionMatch && moneyMatch) ? '' : 'none';
    });
  }
  
</script>
</body>
</html>
