<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">

<%- include('../partials/head', { title: '📍 새 매칭 만들기', pageId: 'page-map-create', active: '' }) %>

  <div class="form-page">
    <div class="form-max">

      <form method="POST" action="/crew/instant-create">

        <div class="form-section">
          <div class="form-section-title">기본 정보</div>

          <!-- 종목: chip 선택 → hidden input에 값 저장 -->
          <div class="field">
            <label class="label">종목</label>
            <div class="chip-group">
              <div class="chip on" data-chip data-value="futsal">⚽ 풋살</div>
              <div class="chip" data-chip data-value="basketball">🏀 농구</div>
              <div class="chip" data-chip data-value="badminton">🏸 배드민턴</div>
              <div class="chip" data-chip data-value="running">🏃 러닝</div>
              <div class="chip" data-chip data-value="tennis">🎾 테니스</div>
              <div class="chip" data-chip data-value="etc">💪 기타</div>
            </div>
            <input type="hidden" name="sport" id="sport-input" value="futsal">
          </div>

          <div class="field">
            <label class="label">매칭 제목</label>
            <input class="input" name="title" placeholder="예: 강남 5:5 풋살 나이트 매칭" required>
          </div>

          <div class="field">
            <label class="label">상세 내용</label>
            <textarea class="input" name="intro" placeholder="매칭에 대한 추가 설명, 준비물, 주의사항 등을 입력하세요"></textarea>
          </div>
        </div>

        <div class="form-section">
          <div class="form-section-title">장소 & 조건</div>

          <div class="input-row mb-12">
            <div class="field" style="margin-bottom:0">
              <label class="label">시/도</label>
              <input class="input" name="state" placeholder="예: 서울특별시" required>
            </div>
            <div class="field" style="margin-bottom:0">
              <label class="label">구/동</label>
              <input class="input" name="city" placeholder="예: 강남구 역삼동" required>
            </div>
          </div>

          <!-- 지도 클릭으로 좌표 입력 (hidden) -->
          <input type="hidden" name="lat" id="lat-input" value="">
          <input type="hidden" name="lng" id="lng-input" value="">

          <div class="field mb-12">
            <label class="label">모집 인원</label>
            <input class="input" name="capacity" type="number" placeholder="10" min="2" required>
          </div>

          <!-- 자동 수락 여부 -->
          <div class="field mb-12">
            <label class="label">참가 신청 방식</label>
            <div class="level-row">
              <div class="lv-btn on" data-accept data-value="enable">자동 수락</div>
              <div class="lv-btn" data-accept data-value="disable">수동 수락</div>
            </div>
            <input type="hidden" name="isAutoAccept" id="accept-input" value="enable">
          </div>
        </div>

        <div style="display:flex;gap:10px;justify-content:flex-end">
          <a href="/crew/instant" class="btn btn-outline">취소</a>
          <button type="submit" class="btn btn-primary btn-lg">매칭 등록하기</button>
        </div>

      </form>

    </div>
  </div>
</div>

</div><!-- /main -->

<script>
document.addEventListener('DOMContentLoaded', () => {

  // ── 종목 chip 선택 → hidden input 업데이트 ──
  document.querySelectorAll('[data-chip]').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('[data-chip]').forEach(c => c.classList.remove('on'));
      chip.classList.add('on');
      document.getElementById('sport-input').value = chip.dataset.value;
    });
  });

  // ── 자동/수동 수락 선택 → hidden input 업데이트 ──
  document.querySelectorAll('[data-accept]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-accept]').forEach(b => b.classList.remove('on'));
      btn.classList.add('on');
      document.getElementById('accept-input').value = btn.dataset.value;
    });
  });

});
</script>
</body>
</html>
