<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>
<!-- ═══════ MAIN ═══════ -->

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<!-- ──────── REGULAR PAGE ──────── -->
<%- include('../partials/head', { title: '🔁 정기 모임', pageId: 'page-regular', active: '', route: '/regular/list' }) %>

  <div class="page-body">
    <div class="section-title">정기모임</div>
    <!-- 정기모임 필터 영역 -->
    <div class="regular-filter-wrap">

      <!-- 필터 종류 버튼 -->
      <div class="filter-header-row">
  
      <div class="regular-filter-tabs">
        <button type="button" class="filter-tab" data-filter="day">요일</button>
        <button type="button" class="filter-tab" data-filter="sport">운동</button>
        <button type="button" class="filter-tab" data-filter="ageRange">연령</button>
        <button type="button" class="filter-tab" data-filter="area">지역</button>
        <button type="button" id="btnRecruitingOnly" class="filter-toggle-btn">✅ 모집 중만 보기</button>
      </div>

      <a href="/regular/create" class="reg-create-btn">
        ＋ 모임 만들기
      </a>

    </div>
      <!-- 초기화 버튼 -->
      <button type="button" id="resetFilterBtn" class="reset-filter-btn">
        초기화
      </button>

      <!-- 옵션 펼침 영역 -->
      <div class="filter-option-panel" id="filterOptionPanel" style="display:none">

        <!-- 옵션 제목 -->
        <div class="filter-option-title" id="filterOptionTitle"></div>

        <!-- 요일 / 운동 / 연령 옵션 영역 -->
        <div class="filter-option-list" id="filterOptionList">

          <!-- 요일 옵션 -->
          <div class="filter-option-group" data-filter-group="day">
            <% Object.entries(CONSTANTS.DAYS).forEach(([key, item]) => { %>
              <button 
                type="button"
                class="filter-option-btn"
                data-filter-type="day"
                data-value="<%= key %>">
                <%= item.short %>
              </button>
            <% }) %>
          </div>

          <!-- 운동 옵션 -->
          <div class="filter-option-group" data-filter-group="sport">
            <% Object.entries(CONSTANTS.SPORTS).forEach(([key, item]) => { %>
              <button 
                type="button"
                class="filter-option-btn"
                data-filter-type="sport"
                data-value="<%= key %>">
                <%= item.kr %>
              </button>
            <% }) %>
          </div>

          <!-- 연령 옵션 -->
          <div class="filter-option-group" data-filter-group="ageRange">
            <% Object.entries(CONSTANTS.AGES).forEach(([key, item]) => { %>
              <button 
                type="button"
                class="filter-option-btn"
                data-filter-type="ageRange"
                data-value="<%= item.v %>">
                <%= item.kr %>
              </button>
            <% }) %>
          </div>

        </div>

        <!-- 지역 선택 영역 -->
        <div class="area-select-box" id="areaSelectBox">

          <!-- 시/도 선택 -->
          <div class="area-row">
            <div class="area-label">시/도</div>

            <div class="city-list" id="cityList">
              <% Object.keys(CONSTANTS.AREAS).forEach((state) => { %>
                <button
                  type="button"
                  class="city-btn"
                  data-state="<%= state %>">
                  <%= state %>
                </button>
              <% }) %>
            </div>
          </div>

          <!-- 구/군 선택 -->
          <div class="area-row">
            <div class="area-label">구/군</div>

            <div class="district-list" id="districtList">
              <p class="district-guide">먼저 시/도를 선택해주세요.</p>

              <% Object.entries(CONSTANTS.AREAS).forEach(([state, districts]) => { %>
                <div class="district-group" data-state="<%= state %>">
                  <% districts.forEach((city) => { %>
                    <button
                      type="button"
                      class="district-btn"
                      data-state="<%= state %>"
                      data-city="<%= city %>">
                      <%= city %>
                    </button>
                  <% }) %>
                </div>
              <% }) %>
            </div>
          </div>

        </div>

      </div>

    </div>
    <div style="display:flex;gap:5px;align-items:center;margin-left:4px">
      </div>

      <div id="reg-filter-panel" class="reg-filter-panel" style="display:none;"></div>

    <div class="regular-grid" id="regularCardList">
      <% regularCrews.forEach(crew => { %>
        <div class="reg-card" data-id="<%= crew._id %>" style="cursor: pointer;">
          <div class="reg-card-head">
              <img 
                  class="reg-crew-profile-img"
                  src="<%= crew.profileImage || '/images/reg-crew/profile/default-profile-image.jpg' %>"
                  alt="정기모임 이미지"
              >
              <div>
                  <div class="reg-card-title"><%= crew.title %></div>
                  <% const dayKorea = { 'mon':'월','tue':'화','wed':'수','thu':'목','fri':'금','sat':'토','sun':'일' }; %>
                  <div class="reg-card-sub">
                      <%= crew.period === 'week' ? '매주' : crew.period === '2week' ? '격주' : '매달' %>
                      <%= crew.day.map(d => dayKorea[d]).join('·') %> ·
                      <%= crew.address.state %> <%= crew.address.city %>
                  </div>
              </div>
              <% const remain = crew.member.capacity - crew.member.memberList.length; %>
              <span class="pill pill-warn" style="margin-left:auto">
                  <%= remain === 0 ? '마감' : remain < 4 ? '마감 임박' : '모집 중' %>
              </span>
          </div>

          <div class="reg-card-body">
            <div class="reg-meta-row">
              <span><%= CONSTANTS.SPORTS[crew.sport] ? CONSTANTS.SPORTS[crew.sport].kr : crew.sport %></span>
              <span>💰 <%= crew.fee %>/회</span>
              <span><%= crew.ageRange %></span>
            </div>

            <div class="reg-progress" 
              data-member="<%= crew.member.memberList.length %>" 
              data-capacity="<%= crew.member.capacity %>">
              <div class="reg-progress-fill"></div>
            </div>

            <div class="reg-progress-label">
              <span><%= crew.member.memberList.length %>/<%= crew.member.capacity %>명</span>

              <% if (crew.member.capacity != crew.member.memberList.length) { %>
                <span><%= crew.member.capacity - crew.member.memberList.length %> 자리남음</span>
              <% } else { %>
                <span>모집 마감</span>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
      <!-- 페이징  -->
      <nav aria-label="page" class="mt-4">
        <ul 
          id="regularPagination" 
          class="pagination justify-content-center"
          data-current-page="<%= currentPage %>"
          data-total-pages="<%= totalPages %>"
        >
        </ul>
      </nav>
    </div>
  </div>
</div>


</div>
<script>
    window.CONSTANTS = <%- JSON.stringify(CONSTANTS) %>;
</script>
<script type="module" src="/js/regularCrew/main.js"></script>
</body>
</html>
