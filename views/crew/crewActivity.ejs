<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 크루 활동 계획</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
<%- include('../partials/head', { title: '⚔️ 크루 활동 기록', pageId: 'page-crew-activity', active: '' }) %>

  <div class="page-body">
    
    <!-- 필터/정렬 -->
    <div id="activity-filter" class="activity-filter-bar">
      <span class="filter-label">정렬</span>
      <button class="sort-btn active" data-sort="latest">최신</button>
      <button class="sort-btn" data-sort="finished">완료</button>
      <button class="sort-btn" data-sort="recruited">모집</button>
      <!-- <button class="sort-btn" data-sort="solo">개인전</button>
      <button class="sort-btn" data-sort="team">팀전</button> -->
      <span class="total-count" id="totalCount">총 <%= crews.schedule.length %>건</span>
      <button class="btn btn-primary btn-sm" onclick="openCreateModal()">＋ 활동</button>
    </div>

    <!-- 게시판 -->
    <div class="activity-list" id="activityList"></div>

  </div>
</div>

<!-- ══ 활동 등록 모달 ══ -->
<div class="2" id="modalCreate">
  <div class="modal-box">
    <div class="modal-head">
      <span class="modal-head-title">📋 활동 등록</span>
    </div>
    <div class="modal-body">
      <div class="field">
        <label class="label">방식</label>
        <div class="type-chip-wrap">
          <button class="type-chip sel-battle" id="chip-team" onclick="selectType('team')">👥 팀전</button>
          <button class="type-chip" id="chip-solo" onclick="selectType('solo')">🏃 개인전</button>
        </div>
      </div>
      <div class="input-row2">
        <div class="field" style="margin-bottom:0">
          <label class="label">날짜</label>
          <input type="date" class="input" id="new-date">
        </div>
        <div class="field" style="margin-bottom:0">
          <label class="label">인원수</label>
          <input type="number" class="input" id="new-count" min="2" max="50" placeholder="예: 10">
        </div>
      </div>
      <br>
      <div class="field">
        <label class="label">장소</label>
        <div class="addr-row">
          <input type="text" class="input" id="new-place" placeholder="주소 검색 후 선택" readonly style="flex:1">
          <button class="addr-search" onclick="searchAddress()">🔍 검색</button>
        </div>
        <input type="text" class="input" id="new-place-detail" placeholder="상세 주소 (동, 층 등)" style="margin-top:6px">
      </div>
      <div class="field">
        <label class="label">내용</label>
        <textarea class="input" id="new-content" placeholder="활동 내용, 조건, 특이사항 등을 입력하세요"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('modalCreate')">취소</button>
      <button class="btn btn-primary" onclick="submitCreate()">등록</button>
    </div>
  </div>
</div>

<!-- 토스트 -->
<div class="activity-toast" id="actToast"></div>

<script>
let currentSort = 'latest';
let currentRange = 'city';
let selType = 'team';

function selectType(t) {
  selType = t;
  document.getElementById('chip-team').className = 'type-chip' + (t==='team' ? ' sel-battle' : '');
  document.getElementById('chip-solo').className = 'type-chip' + (t==='solo' ? ' sel-internal' : '');
}

function getList() {
  const today = new Date(); today.setHours(0,0,0,0);
  const crew = <%- JSON.stringify(crews) %>;
  const schedules = [...crew.schedule];
  if (currentSort === "latest") return schedules.sort((a, b) => new Date(b.date) - new Date(a.date));
  if(currentSort === "finished") {
    return schedules.filter(sched => new Date(sched.date) >= today)
    .sort((a, b) => new Date(b.date) - new Date(a.date));
  }
  if(currentSort === "recruited") {
    return schedules.filter(sched => new Date(sched.date) < today)
    .sort((a, b) => new Date(b.date) - new Date(a.date));
  }
  //if(currentSort === "solo")
  //if(currentSort === "team")

  return crew;
}
const activityFilter = document.getElementById("activity-filter");
activityFilter.addEventListener('click', e => {
  const sortBtn = e.target.closest('.sort-btn');
  if(!sortBtn) return;
  currentSort = sortBtn.dataset.sort;
  document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
  sortBtn.classList.add('active');
  renderList();
});

function fmtDate(str) {
  return new Date(str).toLocaleDateString('ko-KR',{month:'long',day:'numeric',weekday:'short'});
}

const cont = document.getElementById('activityList');
function renderList() {
  const list = getList();
  // console.log(list.schedule.length);
  document.getElementById('totalCount').textContent = `총 ${list.length}건`;
  console.log(list);
  if (!list) {
    cont.innerHTML = 
    `<div class="activity-empty">
      <div class="activity-empty-icon">📭</div>
      <div class="activity-empty-title">등록된 활동이 없어요</div>
      <div class="activity-empty-sub">[＋ 활동] 버튼으로 새 활동을 등록해보세요</div>
    </div>`;
    return;
  }

  cont.innerHTML = list.map((a, index)=> {
    const today = new Date(); today.setHours(0,0,0,0);
    const actDate = new Date(a.date);
    const statusBadge = actDate >= today
      ? `<span class="type-badge type-internal">예정</span>`
      : `<span class="type-badge type-battle">완료</span>`;

    return `<div class="activity-card">
      <div class="activity-row">
        ${statusBadge}
        <div class="activity-main">
          <div class="activity-title">${a.title}</div>
          <div class="activity-meta">
            <span>📅 ${fmtDate(a.date)}</span>
            <span>📍 ${a.address.state} ${a.address.city}</span>
            <span>👥 ${a.participants.length}명</span>
          </div>
          <div class="activity-desc">${a.content}</div>
        </div>
        <button class="btn btn-outline btn-sm">삭제</button>
        <span class="chevron">▼</span>
      </div>
      <div class="apps-panel"></div>
    </div>`;
  }).join('');
}
cont.addEventListener('click', e => {
  const row = e.target.closest('.activity-row');
  if (!row) return;
  row.nextElementSibling.classList.toggle('open');
  row.querySelector('.chevron').classList.toggle('open');
});


function setSort(btn) {
  currentSort = btn.dataset.sort;
  document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderList();
}
function setRange(v) { currentRange = v; renderList(); }

function openCreateModal() {
  document.getElementById('new-date').value = new Date().toISOString().split('T')[0];
  document.getElementById('new-count').value = '';
  document.getElementById('new-place').value = '';
  document.getElementById('new-place-detail').value = '';
  document.getElementById('new-content').value = '';
  selectType('team');
  openModal('modalCreate');
}
function searchAddress() {
  const fakes = ['서울 마포구 망원동 100-1','서울 마포구 합정동 22-5','서울 마포구 상수동 70','서울 마포구 서교동 350'];
  document.getElementById('new-place').value = fakes[Math.floor(Math.random()*fakes.length)];
  showToast('📍 주소가 선택되었습니다');
}
function submitCreate() {
  const date = document.getElementById('new-date').value;
  const count = document.getElementById('new-count').value;
  const place = document.getElementById('new-place').value;
  const detail = document.getElementById('new-place-detail').value;
  const content = document.getElementById('new-content').value;
  if (!date) { showToast('⚠️ 날짜를 입력해주세요'); return; }
  if (!count || count < 2) { showToast('⚠️ 인원수를 입력해주세요 (최소 2명)'); return; }
  if (!place) { showToast('⚠️ 장소를 검색해서 선택해주세요'); return; }
  ACTIVITIES.unshift({
    id:'act_'+Date.now(), crewId:MY_CREW_ID, crewName:'마포 후크슛', crewEmoji:'🏀', crewScore:980,
    date, place, placeDetail:detail, count:parseInt(count), type:selType,
    content:content||'활동 내용 없음', region:'city', createdAt:new Date(), applications:[],
  });
  closeModal('modalCreate'); renderList();
}

function openModal(id) { 
  const el = document.getElementById(id);
  el.style.display = 'flex';
  el.classList.add('open'); 
  document.body.style.overflow='hidden'; 
}
function closeModal(id) { 
  const el = document.getElementById(id);
  el.classList.remove('open');
  el.style.display = 'none';
  document.body.style.overflow=''; 
}
document.querySelectorAll('.modal-overlay2').forEach(el => el.addEventListener('click', e => { if(e.target===el) closeModal(el.id); }));

function showToast(msg) {
  const t = document.getElementById('actToast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

renderList();
</script>
</body>
</html>
