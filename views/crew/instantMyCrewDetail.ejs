<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 번개모임 상세</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
<%- include('../partials/head', { title: '', pageId: 'page-instant-manage-detail', active: '' }) %>

  <div class="page-body">
    <div class="detail-wrap">

      <a href="/instant/list" class="goback-btn">← 번개모임 목록</a>

      <%
        const meetAt = new Date(crew.meetAt);
        const sportKr = CONSTANTS.SPORTS[crew.sport]?.kr || crew.sport;
        const sportEmojiMap = {
            soccer: '⚽', baseball: '⚾', basketball: '🏀',
            bowling: '🎳', tennis: '🎾', badminton: '🏸', tabletennis: '🏓'
          };
        const sportEmoji = sportEmojiMap[crew.sport] || '🏃';
        const members = crew.member.memberList;
        const pendings = crew.member.pendingList.filter(p => p.status === 'pending');
        const confirmedCount = members.filter(m => m.status === 'confirmed').length;
      %>

      <% if (!isHost && !isMember) { %>
        <!-- ── 미가입자 화면 ── -->
        <div class="detail-group">
          <div class="detail-header">
            <div class="detail-sport-icon"><%= sportEmoji %></div>
            <div class="detail-header-info">
              <div class="detail-title"><%= crew.title %></div>
              <div class="detail-sub">
                <%= sportKr %> · <%= crew.address.state %> <%= crew.address.city %>
                <% if (crew.address.detail) { %> · <%= crew.address.detail %><% } %>
              </div>
            </div>
            <div style="display:flex;gap:6px">
              <span class="pill pill-open">참가가능</span>
              <span class="tag tag-outline"><%= crew.isAutoAccept ? '⚡ 자동수락' : '✋ 수동수락' %></span>
            </div>
          </div>

          <% if (crew.intro) { %>
          <div style="padding:14px 0;font-size:14px;color:var(--text-2);line-height:1.7;border-bottom:1px solid var(--border)">
            <%= crew.intro %>
          </div>
          <% } %>

          <div class="popup-meta" style="margin:14px 0">
            <span>📍 <%= crew.address.state %> <%= crew.address.city %></span>
            <span>👥 <%= members.length %>/<%= crew.member.capacity %>명</span>
          </div>

          <div class="popup-host" style="margin:12px 0">
            <div class="popup-host-av"><%= crew.host.name?.charAt(0) %></div>
            <div>
              <div class="popup-host-name"><%= crew.host.name %></div>
              <div class="popup-host-sub"><%= crew.avgReputation > 0 ? '⭐ ' + crew.avgReputation.toFixed(1) : '평점 없음' %></div>
            </div>
          </div>

          <div style="font-size:12px;color:#aaa;margin-bottom:16px">
            ⏰ <%= meetAt.toLocaleString('ko-KR') %>
          </div>

          <button class="btn btn-primary" style="width:100%;padding:14px;font-size:15px" id="btn-apply">참가 신청</button>
        </div>

      <% } else { %>
        <!-- ── 멤버/호스트 화면 ── -->

        <!-- 상단 페이지 탭 -->
        <div style="display:flex;border-bottom:2px solid var(--border);margin-bottom:20px">
          <button class="page-tab active" data-ptab="detail"
            style="padding:12px 24px;font-size:14px;font-weight:700;border:none;background:none;cursor:pointer;
                   border-bottom:2px solid var(--text);margin-bottom:-2px;color:var(--text)">
            📋 모임
          </button>
          <button class="page-tab" data-ptab="chat"
            style="padding:12px 24px;font-size:14px;font-weight:700;border:none;background:none;cursor:pointer;
                   color:var(--text-3)">
            💬 채팅방
          </button>
        </div>

        <!-- 상세페이지 탭 내용 -->
        <div id="sec-detail">
          <div class="detail-group">
            <!-- 헤더 -->
            <div class="detail-header">
              <div class="detail-sport-icon"><%= sportEmoji %></div>
              <div class="detail-header-info">
                <div class="detail-title"><%= crew.title %></div>
                <div class="detail-sub">
                  <%= sportKr %> · <%= crew.address.state %> <%= crew.address.city %>
                  <% if (crew.address.detail) { %> · <%= crew.address.detail %><% } %> ·
                  <%= meetAt.toLocaleDateString('ko-KR', {month:'long', day:'numeric', hour:'2-digit', minute:'2-digit'}) %>
                </div>
              </div>
              <% if(isHost) { %>
              <button class="detail-like-btn" id="delete-open-btn" style="border-color:#ffb3ae">
                <span class="like-icon">🗑</span>
                <span class="like-count" style="color:var(--red)">삭제</span>
              </button>
              <% } %>
            </div>

            <!-- 통계 -->
            <div class="stat-row" style="margin:20px 0">
              <div class="stat-block"><div class="stat-block-label">전체 참여자</div><div class="stat-block-val"><%= members.length %></div></div>
              <div class="stat-block"><div class="stat-block-label">참가 확정</div><div class="stat-block-val green"><%= confirmedCount %></div></div>
              <div class="stat-block"><div class="stat-block-label">모집 현황</div><div class="stat-block-val blue"><%= members.length %> / <%= crew.member.capacity %></div></div>
              <div class="stat-block"><div class="stat-block-label">신청 대기</div><div class="stat-block-val orange"><%= pendings.length %></div></div>
            </div>

            <!-- 내부 탭 (참여자/신청대기) -->
            <div class="crew-tabs">
              <button class="crew-tab active" data-tab="members">
                참여자 목록 <span style="font-size:12px;opacity:0.6"><%= members.length %>명</span>
              </button>
              <% if(isHost) { %>
              <button class="crew-tab" data-tab="apps">
                신청 대기
                <% if (pendings.length > 0) { %>
                  <span class="tab-badge"><%= pendings.length %></span>
                <% } %>
              </button>
              <% } %>
            </div>

            <!-- 참여자 목록 탭 -->
            <div class="tab-section active" id="sec-members">
              <div class="topbar" style="margin-bottom:14px">
                <div class="filter-chips">
                  <button class="filter-chip on" data-filter="all">전체</button>
                  <button class="filter-chip" data-filter="host">모임장</button>
                  <button class="filter-chip" data-filter="confirmed">참가확정</button>
                  <button class="filter-chip" data-filter="noshow">노쇼</button>
                </div>
                <div class="search-wrap">
                  <span style="font-size:14px;color:var(--text-3)">🔍</span>
                  <input type="text" placeholder="이름 검색" id="search-input" />
                </div>
              </div>

              <div class="tbl-card">
                <table>
                  <thead>
                    <tr>
                      <th style="width:200px">멤버</th>
                      <th style="width:70px;white-space:nowrap">역할</th>
                      <th style="width:90px;white-space:nowrap">상태</th>
                      <th style="width:60px;white-space:nowrap">성별</th>
                      <th style="width:60px;white-space:nowrap">나이</th>
                      <th style="width:110px;white-space:nowrap">가입일</th>
                      <th style="width:100px;white-space:nowrap">관리</th>
                    </tr>
                  </thead>
                  <tbody id="member-tbody"></tbody>
                </table>
              </div>

              <!-- 상세 패널 -->
              <div class="detail-panel" id="detail-panel">
                <div class="dp-header">
                  <div class="dp-av" id="dp-av"></div>
                  <div>
                    <div class="dp-name" id="dp-name"></div>
                    <div class="dp-meta">
                      <span id="dp-role-badge"></span>
                      <span id="dp-status-badge"></span>
                    </div>
                  </div>
                  <button class="dp-close" id="dp-close-btn">✕</button>
                </div>
                <div class="dp-grid">
                  <div class="dp-cell"><div class="dp-cell-label">연락처</div><div class="dp-cell-val" id="dp-phone"></div></div>
                  <div class="dp-cell"><div class="dp-cell-label">성별</div><div class="dp-cell-val" id="dp-gender"></div></div>
                  <div class="dp-cell"><div class="dp-cell-label">나이</div><div class="dp-cell-val" id="dp-age"></div></div>
                </div>
                <% if(isHost) { %>
                <div class="dp-actions">
                  <button class="dp-act-btn danger" id="dp-noshow-btn" style="margin-left:auto">노쇼 처리</button>
                  <button class="dp-act-btn danger" id="dp-kick-btn">강퇴</button>
                </div>
                <% } %>
              </div>
            </div>

            <!-- 신청 대기 탭 (호스트만) -->
            <% if(isHost) { %>
            <div class="tab-section" id="sec-apps">
              <% if (pendings.length === 0) { %>
                <div class="empty-state">
                  <div class="empty-state-icon">📭</div>
                  <div class="empty-state-title">신청 대기자가 없어요</div>
                </div>
              <% } else { %>
                <div class="app-list">
                  <% pendings.forEach(p => { %>
                    <% const u = p.user; %>
                    <div class="app-card" id="app-<%= u?._id %>">
                      <div class="app-head">
                        <div class="app-av" style="background:#EEF3FF;color:#003DB3"><%= u?.name?.slice(0,2) || '??' %></div>
                        <div>
                          <div class="app-name"><%= u?.name || '알 수 없음' %></div>
                          <div class="app-sport"><%= u?.gender === 'male' ? '남성' : '여성' %> · <%= u?.age %>세</div>
                        </div>
                        <div class="app-time">
                          <%= new Date(p.requestAt).toLocaleDateString('ko-KR') %>
                          <div class="app-phone"><%= u?.tel || '-' %></div>
                        </div>
                      </div>
                      <div class="app-foot">
                        <button class="app-btn accept">✓ 수락</button>
                        <button class="app-btn reject">✕ 거절</button>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
            <% } %>

          </div>
        </div>

        <!-- 채팅방 탭 내용 -->
        <div id="sec-chat" style="display:none">
          <div class="detail-group">
            <div style="padding:60px 20px;text-align:center;color:var(--text-3)">
              <div style="font-size:48px;margin-bottom:16px">💬</div>
              <div style="font-size:16px;font-weight:700;color:var(--text-2);margin-bottom:8px">아직 채팅방이 없어요</div>
              <div style="font-size:13px;margin-bottom:24px">채팅방을 만들어 멤버들과 소통해보세요!</div>
              <button class="btn btn-primary" id="btn-create-chat" style="padding:12px 32px;font-size:14px">
                💬 채팅방 만들기
              </button>
            </div>
          </div>
        </div>

      <% } %>
    </div>
  </div>
</div>

<!-- 삭제 모달 -->
<div class="modal-overlay" id="modal-delete">
  <div class="modal-box">
    <div class="modal-icon">⚠️</div>
    <div class="modal-title">돌이킬 수 없어요.</div>
    <div class="modal-msg">정말 이 번개모임을 삭제하시겠어요?</div>
    <div class="modal-btn" style="display:flex;gap:8px;width:100%;margin-top:24px">
      <button class="btn btn-outline" id="modal-cancel-btn" style="flex:1;padding:12px">취소</button>
      <button class="btn-yes" id="confirm-delete-btn">삭제하기</button>
    </div>
  </div>
</div>

<script>
const CREW_ID = '<%= crew._id %>';
const IS_HOST = <%= isHost %>;
const IS_MEMBER = <%= isMember %>;
const MEMBERS_DATA = <%- JSON.stringify(members.map(m => ({
    id: m.user?._id?.toString(),
    name: m.user?.name || '알 수 없음',
    tel: m.user?.tel || '-',
    age: m.user?.age || '-',
    gender: m.user?.gender === 'male' ? '남성' : '여성',
    role: m.role,
    status: m.status,
    joinedAt: new Date(m.joinedAt).toLocaleDateString('ko-KR')
}))) %>;
</script>
<script src="/js/handlers/icDetailHandler.js"></script>
</body>
</html>