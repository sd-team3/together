<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 내 번개모임</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
<%- include('../partials/head', { title: '⚡ 내 번개모임', pageId: 'page-instant-manage', active: '' }) %>

  <div class="page-body">

    <div class="my-crew-tabs">
      <a href="/instant/list" class="my-crew-tab active">전체</a>
    </div>

    <% if (crews.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">⚡</div>
        <div class="empty-state-title">아직 만든 번개모임이 없어요</div>
        <div class="empty-state-sub">번개모임을 만들고 같이 운동할 사람들을 찾아보세요!</div>
        <button class="empty-state-btn" id="btn-go-create">번개모임 만들기</button>
      </div>
    <% } else { %>
      <div class="regular-grid" id="crew-grid">
        <% crews.forEach(crew => { %>
          <%
            const now = new Date();
            const meetAt = new Date(crew.meetAt);
            const diffMs = meetAt - now;
            const diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));
            const isPast = diffMs < 0;
            const sportKr = CONSTANTS.SPORTS[crew.sport]?.kr || crew.sport;
            const sportEmojiMap = {
              soccer: '⚽', baseball: '⚾', basketball: '🏀',
              bowling: '🎳', tennis: '🎾', badminton: '🏸', tabletennis: '🏓'
            };
            const sportEmoji = sportEmojiMap[crew.sport] || '🏃';
            const current = crew.member.memberList.length;
            const capacity = crew.member.capacity;
            const pending = crew.member.pendingList.filter(p => p.status === 'pending').length;
            const isFull = current >= capacity;
            const pct = Math.round(current / capacity * 100);
          %>
          <div class="reg-card">
            <div class="reg-card-head">
              <div class="reg-sport-icon"><%= sportEmoji %></div>
              <div>
                <div class="reg-card-title"><%= crew.title %></div>
                <div class="reg-card-sub">
                  <%= meetAt.toLocaleDateString('ko-KR', {month:'long', day:'numeric', hour:'2-digit', minute:'2-digit'}) %> · <%= crew.address.state %> <%= crew.address.city %>
                  <% if(crew.address.detail) { %> · <%= crew.address.detail%> <%}%>
                </div>
              </div>
              <span class="role-badge host">👑모임장</span>
            </div>

            <div class="reg-card-body">
              <div class="reg-meta-row">
                <span><%=sportEmoji%> <%= sportKr %></span>
                <span>👥 <%= current %>/<%= capacity %>명</span>
                <% if (!isPast) { %>
                  <span style="font-family:'DM Mono',monospace;font-weight:700;color:<%= diffDays <= 1 ? '#FF3B30' : diffDays <= 3 ? '#FF6B00' : '#1A5CFF' %>">
                    D<%= diffDays === 0 ? '-DAY' : '-' + diffDays %>
                  </span>
                <% } else { %>
                  <span style="color:#999">종료</span>
                <% } %>
                <% if (pending > 0) { %>
                  <span style="color:#CC4500;font-weight:700">신청 <%= pending %>건</span>
                <% } %>
              </div>

              <div class="reg-progress">
                <div class="reg-progress-fill" style="width:<%= pct %>%"></div>
              </div>
              <div class="reg-progress-label">
                <span><%= current %>/<%= capacity %>명</span>
                <span><%= capacity - current %>자리 남음</span>
              </div>

              <div class="reg-card-actions">
                <% if(crew.host.toString() === currentUserId) { %>
                  <a href="/instant/list/<%= crew._id %>" class="action-btn primary">관리</a>
                  <button class="action-btn danger" type="button" data-delete-id="<%= crew._id %>">삭제</button>
                <%} else { %>
                   <a href="/instant/list/<%= crew._id %>" class="action-btn primary">상세보기</a>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

  </div>
</div>

<div class="modal-overlay" id="modal-delete">
  <div class="modal-box">
    <div class="modal-icon">⚠️</div>
    <div class="modal-title">돌이킬 수 없어요.</div>
    <div class="modal-msg">정말 이 번개모임을 삭제하시겠어요?</div>
    <div class="modal-btn" style="display:flex;gap:8px;width:100%;margin-top:24px">
      <button class="btn btn-outline" id="modal-cancel-btn" style="flex:1;padding:12px">취소</button>
      <button class="btn-yes" id="confirm-delete-btn">삭제하기</button>
    </div>
  </div>
</div>

<script>
let targetId = null;

function closeModal() {
  targetId = null;
  document.getElementById('modal-delete').classList.remove('show');
}

// 번개모임 만들기 버튼 (empty-state일 때만 존재)
document.getElementById('btn-go-create')?.addEventListener('click', () => {
  location.href = '/instant/create';
});

// 삭제 버튼들 — 이벤트 위임
document.getElementById('crew-grid')?.addEventListener('click', e => {
  const btn = e.target.closest('[data-delete-id]');
  if (!btn) return;
  targetId = btn.dataset.deleteId;
  document.getElementById('modal-delete').classList.add('show');
});

// 모달 취소 버튼
document.getElementById('modal-cancel-btn').addEventListener('click', closeModal);

// 모달 오버레이 클릭
document.getElementById('modal-delete').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// 삭제 확인
document.getElementById('confirm-delete-btn').addEventListener('click', async () => {
  if (!targetId) return;
  try {
    const res = await fetch(`/instant/delete/${targetId}`, { method: 'POST' });
    const data = await res.json();
    if (data.success) location.reload();
    else alert(data.message || '삭제에 실패했습니다.');
  } catch (e) {
    alert('서버 오류가 발생했습니다.');
  } finally {
    closeModal();
  }
});
</script>
</body>
</html>