<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 내 정기모임</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="/js/myCrews.js"></script>
<script src="/js/deleteConfirm.js"></script>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
<%- include('../partials/head', { title: '🏅 내 정기모임', pageId: 'page-my-crews', active: '' }) %>

  <div class="page-body">

    <!-- 탭 (호스트 / 크루원) -->
    <div class="my-crew-tabs">
      <a class="my-crew-tab active" onclick="switchTab(this, 'all')">전체</a>
      <a class="my-crew-tab" onclick="switchTab(this, 'host')">👑 내가 만든 모임</a>
      <a class="my-crew-tab" onclick="switchTab(this, 'member')">🙋 참여 중인 모임</a>
    </div>

    <!-- 크루 목록 -->
    <div class="regular-grid" id="crew-grid"></div>

  </div>
</div>

<div class="modal-overlay" id="modal-delete">
  <div class="modal-box">
    <div class="modal-icon">⚠️</div>
    <div class="modal-title">돌이킬 수 없어요.</div>
    <div class="modal-msg">정말 진행하시겠습니까?</div>
    <div class="modal-btn" style="display:flex; gap:8px; width:100%; margin-top:24px">
      <button class="btn btn-outline" style="flex:1;padding:12px" onclick="deleteModal()">취소</button>
      <form id="delete-form" method="POST" style="flex:1;display:flex">
        <button type="submit" class="btn-yes">진행하기</button>
      </form>
    </div>
  </div>
</div>
</body>
</html>
