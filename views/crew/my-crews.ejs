<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 내 정기모임</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
<%- include('../partials/head', { title: '🏅 내 정기모임', pageId: 'page-my-crews', active: '' }) %>

  <div class="page-body">

    <!-- 탭 (호스트 / 크루원) -->
    <div class="my-crew-tabs">
      <button class="my-crew-tab active">전체</button>
      <button class="my-crew-tab">👑 내가 만든 모임</button>
      <button class="my-crew-tab">🙋 참여 중인 모임</button>
    </div>

    <!-- 크루 목록 -->
    <% if (crews.length === 0) { %>
      <!-- 빈 상태 -->
      <div class="empty-state">
        <div class="empty-state-icon">🏃</div>
        <div class="empty-state-title">참여 중인 모임이 없어요</div>
        <div class="empty-state-sub">정기모임에 참가하거나 직접 만들어보세요!<br>같은 스포츠를 즐기는 사람들을 만날 수 있어요.</div>
        <button class="empty-state-btn" onclick="location.href='/4'">모임 둘러보기</button>
      </div>
    <% } else { %>
      <div class="regular-grid" id="crew-grid">
        <% crews.forEach(crew => { %>
          <div class="reg-card" data-role="<%= crew.role %>">

            <!-- 카드 헤더 -->
            <div class="reg-card-head">
              <div class="reg-sport-icon"><%= crew.sportEmoji %></div>
              <div>
                <div class="reg-card-title"><%= crew.title %></div>
                <div class="reg-card-sub">
                  <%= crew.dayLabel %> · <%= crew.address.city %>
                </div>
              </div>
              <!-- 역할 뱃지 -->
              <% if (crew.role === 'host') { %>
                <span class="role-badge host">👑 모임장</span>
              <% } else { %>
                <span class="role-badge member">🙋 크루원</span>
              <% } %>
            </div>

            <!-- 카드 바디 -->
            <div class="reg-card-body">
              <div class="reg-meta-row">
                <span>💰 <%= crew.fee > 0 ? crew.fee.toLocaleString() + '원/회' : '무료' %></span>
                <span>👥 <%= crew.member.memberList.length %>/<%= crew.member.capacity %>명</span>
                <span>📅 <%= crew.periodLabel %></span>
              </div>
              <div class="reg-progress">
                <div class="reg-progress-fill" data-pct="<%= Math.round(crew.member.memberList.length / crew.member.capacity * 100) %>"></div>
              </div>
              <div class="reg-progress-label">
                <span><%= crew.member.memberList.length %>/<%= crew.member.capacity %>명</span>
                <span><%= crew.member.capacity - crew.member.memberList.length %>자리 남음</span>
              </div>

              <!-- 액션 버튼 - role에 따라 분기 -->
              <div class="reg-card-actions">
                <% if (crew.role === 'host') { %>
                  <!-- 호스트 -->
                  <button class="action-btn primary">상세보기</button>
                  <button class="action-btn danger">해산</button>
                <% } else { %>
                  <!-- 크루원 -->
                  <button class="action-btn primary">상세보기</button>
                  <button class="action-btn danger">탈퇴</button>
                <% } %>
              </div>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %>

  </div>
</div>

<script>
// .reg-progress-fill 클래스를 가지면서 data-pct 속성이 있는 요소를 페이지에서 전부 찾음.
document.querySelectorAll('.reg-progress-fill[data-pct]').forEach(el => {
  el.style.width = el.dataset.pct + '%';
});
</script>
</body>
</html>
