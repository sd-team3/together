<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 내 정기모임</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="/js/deleteConfirm.js"></script>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
<%- include('../partials/head', { title: '🏅 내 정기모임', pageId: 'page-my-crews', active: '' }) %>

  <div class="page-body">

    <!-- 탭 (호스트 / 크루원) -->
    <div class="my-crew-tabs">
      <a href="/crew/my-crews" class="my-crew-tab <%= !role || role === 'all' ? 'active' : '' %>">전체</a>
      <a href="/crew/my-crews?role=host" class="my-crew-tab <%= role === 'host' ? 'active' : '' %>">👑 내가 만든 모임</a>
      <a href="/crew/my-crews?role=member" class="my-crew-tab <%= role === 'member' ? 'active' : '' %>">🙋 참여 중인 모임</a>
    </div>

    <!-- 크루 목록 -->
    <% if (crews.length === 0) { %>
      <!-- 빈 상태 -->
      <div class="empty-state">
        <div class="empty-state-icon">🏃</div>
        <div class="empty-state-title">참여 중인 모임이 없어요</div>
        <div class="empty-state-sub">정기모임에 참가하거나 직접 만들어보세요!<br>같은 스포츠를 즐기는 사람들을 만날 수 있어요.</div>
        <button class="empty-state-btn" onclick="location.href='/regular'">모임 둘러보기</button>
      </div>
    <% } else { %>
      <div class="regular-grid" id="crew-grid">
        <% crews.forEach(crew => { %>
          <div class="reg-card" data-role="<%= crew.crewRole %>">

            <!-- 카드 헤더 -->
            <div class="reg-card-head">
              <img src="<%= crew.profileImage %>" class="reg-sport-icon" alt="크루 프사">
              <div>
                <div class="reg-card-title"><%= crew.title %></div>
                <div class="reg-card-sub">
                  <%= crew.dayLabel %> · <%= crew.address.city %>
                </div>
              </div>
              <!-- 역할 뱃지 -->
              <% if (crew.crewRole === 'host') { %>
                <span class="role-badge host">👑 모임장</span>
                <span class="like-font">❤️ <%= crew.reputation %></span>
              <% } else { %>
                <span class="role-badge member">🙋 크루원</span>
                <span class="like-font">❤️ <%= crew.reputation %></span>
              <% } %>
            </div>

            <!-- 카드 바디 -->
            <div class="reg-card-body">
              <div class="reg-meta-row">
                <span>💰 <%= crew.fee > 0 ? crew.fee.toLocaleString() + '원/회' : '무료' %></span>
                <span>👥 <%= crew.member.memberList.length %>/<%= crew.member.capacity %>명</span>
                <span>📅 <%= crew.periodLabel %></span>
              </div>
              <div class="reg-progress">
                <div class="reg-progress-fill" style="width: <%= crew.pct %>"></div> <!-- '<'' 충돌은 EJS 문법을 HTML로 잘못 인식해서 생김. 실제 실행하면 오류 X -->
              </div>
              <div class="reg-progress-label">
                <span><%= crew.member.memberList.length %>/<%= crew.member.capacity %>명</span>
                <span><%= crew.member.capacity - crew.member.memberList.length %>자리 남음</span>
              </div>

              <div class="reg-card-actions">
                <% if (crew.crewRole === 'host') { %>
                  <!-- 호스트 -->
                  <a href="/crew/<%= crew._id %>" class="action-btn primary">상세보기</a>
                  <button class="action-btn danger" style="flex:1" type="button" onclick="confirmDelete('<%= crew._id %>')">해산</button>
                <% } else { %>
                  <!-- 크루원 -->
                  <a href="/crew/<%= crew._id %>" class="action-btn primary">상세보기</a>
                  <button class="action-btn danger" style="flex:1" type="button" onclick="confirmWithdraw('<%= crew._id %>')">탈퇴</button>
                <% } %>
              </div>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %>

  </div>
</div>

<div class="modal-overlay" id="modal-delete">
  <div class="modal-box">
    <div class="modal-icon">⚠️</div>
    <div class="modal-title">돌이킬 수 없어요.</div>
    <div class="modal-msg">정말 진행하시겠습니까?</div>
    <div class="modal-btn" style="display:flex; gap:8px; width:100%; margin-top:24px">
      <button class="btn btn-outline" style="flex:1;padding:12px" onclick="deleteModal()">취소</button>
      <form id="delete-form" method="POST" style="flex:1;display:flex">
        <button type="submit" class="btn-yes">진행하기</button>
      </form>
    </div>
  </div>
</div>
</body>
</html>
