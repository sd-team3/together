<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 크루 활동 계획</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
<%- include('../partials/head', { title: '⚔️ 크루 활동 계획', pageId: 'page-crew-activity', active: '' }) %>

  <div class="page-body">

    <!-- 타이틀 -->
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:6px;">
      <div style="display:flex; align-items:center; gap:10px;">
        <h1 class="page-heading" style="margin-bottom:0">크루 활동 계획</h1>
        <span class="crew-pill"><%= crew.title %></span>
      </div>
      <button class="btn btn-primary" onclick="openCreateModal()">＋ 활동</button>
    </div>
    <p class="page-subheading">내 주변 크루의 활동을 확인하고 대전을 신청해보세요.</p>

    <!-- 필터/정렬 -->
    <div class="activity-filter-bar">
      <span class="filter-label">정렬</span>
      <button class="sort-btn active" data-sort="latest" onclick="setSort(this)">최신순</button>
      <button class="sort-btn" data-sort="score-high" onclick="setSort(this)">점수 높은 순</button>
      <button class="sort-btn" data-sort="score-low" onclick="setSort(this)">점수 낮은 순</button>
      <span class="filter-label" style="margin-left:6px">범위</span>
      <select class="range-select" id="rangeSelect" onchange="setRange(this.value)">
        <option value="city">시 단위 (마포구)</option>
        <option value="state">시/도 단위 (서울)</option>
      </select>
      <span class="total-count" id="totalCount">총 5건</span>
    </div>

    <!-- 게시판 -->
    <div class="activity-list" id="activityList"></div>

  </div>
</div>

<!-- ══ 활동 등록 모달 ══ -->
<div class="modal-overlay" id="modalCreate">
  <div class="modal-box">
    <div class="modal-head">
      <span class="modal-head-title">📋 활동 등록</span>
      <button class="modal-close" onclick="closeModal('modalCreate')">✕</button>
    </div>
    <div class="modal-body">
      <div class="field">
        <label class="label">방식</label>
        <div class="type-chip-wrap">
          <button class="type-chip sel-battle" id="chip-battle" onclick="selectType('battle')">⚔️ 크루 대전</button>
          <button class="type-chip" id="chip-internal" onclick="selectType('internal')">🏃 크루 내전</button>
        </div>
      </div>
      <div class="input-row2">
        <div class="field" style="margin-bottom:0">
          <label class="label">날짜</label>
          <input type="date" class="input" id="new-date">
        </div>
        <div class="field" style="margin-bottom:0">
          <label class="label">인원수</label>
          <input type="number" class="input" id="new-count" min="2" max="50" placeholder="예: 10">
        </div>
      </div>
      <br>
      <div class="field">
        <label class="label">장소</label>
        <div class="addr-row">
          <input type="text" class="input" id="new-place" placeholder="주소 검색 후 선택" readonly style="flex:1">
          <button class="addr-search" onclick="searchAddress()">🔍 검색</button>
        </div>
        <input type="text" class="input" id="new-place-detail" placeholder="상세 주소 (동, 층 등)" style="margin-top:6px">
      </div>
      <div class="field">
        <label class="label">내용</label>
        <textarea class="input" id="new-content" placeholder="활동 내용, 조건, 특이사항 등을 입력하세요"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('modalCreate')">취소</button>
      <button class="btn btn-primary" onclick="submitCreate()">등록</button>
    </div>
  </div>
</div>

<!-- ══ 대전 신청 모달 ══ -->
<div class="modal-overlay" id="modalApply">
  <div class="modal-box">
    <div class="modal-head">
      <span class="modal-head-title">⚔️ 대전 신청</span>
      <button class="modal-close" onclick="closeModal('modalApply')">✕</button>
    </div>
    <div class="modal-body">
      <div class="target-card">
        <div class="target-emoji" id="applyEmoji">🏀</div>
        <div>
          <div class="target-name" id="applyName"></div>
          <div class="target-meta" id="applyMeta"></div>
        </div>
      </div>
      <div class="info-chips" id="applyChips"></div>
      <div class="field">
        <label class="label">신청 메시지 (조율 사항)</label>
        <textarea class="input" id="apply-message" placeholder="예) 인원 조정, 장소 변경 협의 등 희망하는 내용을 입력해주세요"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('modalApply')">취소</button>
      <button class="btn btn-primary" onclick="submitApply()">신청하기</button>
    </div>
  </div>
</div>

<!-- 토스트 -->
<div class="activity-toast" id="actToast"></div>

<script>
const MY_CREW_ID = 'crew_001';

const ACTIVITIES = [
  {
    id: 'act_001', crewId: 'crew_002', crewName: '강남 레이업스', crewEmoji: '🏀', crewScore: 1340,
    date: '2025-07-05', place: '서울 강남구 역삼동 123-4', placeDetail: '역삼 실내 농구장 2층',
    count: 12, type: 'battle', content: '농구 5:5 크루 대전 모집합니다. 실력 중급 이상 크루 환영!',
    region: 'city', createdAt: new Date('2025-06-28T14:30:00'),
    applications: [
      { id: 'app_101', crewId: 'crew_003', crewName: '은평 덩크단', crewEmoji: '🏀', message: '저희도 5:5 가능합니다. 시간 조율 가능한지요?', date: '2025-06-29' },
    ],
  },
  {
    id: 'act_002', crewId: MY_CREW_ID, crewName: '마포 후크슛', crewEmoji: '🏀', crewScore: 980,
    date: '2025-07-12', place: '서울 마포구 망원동 456-7', placeDetail: '망원 공원 농구장',
    count: 10, type: 'battle', content: '주말 오전 크루 대전 파트너 구합니다. 가볍게 즐기는 게임입니다.',
    region: 'city', createdAt: new Date('2025-06-27T09:10:00'),
    applications: [
      { id: 'app_201', crewId: 'crew_004', crewName: '서대문 스매시', crewEmoji: '🏀', message: '7월 12일 오전 10시 가능합니다!', date: '2025-06-28' },
      { id: 'app_202', crewId: 'crew_005', crewName: '용산 블록샷', crewEmoji: '🏀', message: '인원 8명도 괜찮으시면 연락 주세요.', date: '2025-06-29' },
    ],
  },
  {
    id: 'act_003', crewId: 'crew_006', crewName: '홍대 런앤건', crewEmoji: '🏀', crewScore: 2210,
    date: '2025-07-08', place: '서울 마포구 상수동 789', placeDetail: '상수 공용 체육관',
    count: 8, type: 'battle', content: '실력 상관없이 즐겁게 대전할 크루 찾아요. 음료 제공!',
    region: 'city', createdAt: new Date('2025-06-26T18:00:00'), applications: [],
  },
  {
    id: 'act_004', crewId: MY_CREW_ID, crewName: '마포 후크슛', crewEmoji: '🏀', crewScore: 980,
    date: '2025-07-19', place: '서울 마포구 합정동 11-2', placeDetail: '합정 실내체육관',
    count: 14, type: 'internal', content: '크루 내전 일정입니다. 참여 확정 인원 확인 중.',
    region: 'city', createdAt: new Date('2025-06-25T11:20:00'), applications: [],
  },
  {
    id: 'act_005', crewId: 'crew_007', crewName: '성동 픽앤롤', crewEmoji: '🏀', crewScore: 650,
    date: '2025-07-15', place: '서울 성동구 금호동 55', placeDetail: '금호 체육관',
    count: 10, type: 'battle', content: '성동구에서 원정 오실 크루 환영합니다!',
    region: 'state', createdAt: new Date('2025-06-24T16:45:00'), applications: [],
  },
];

let currentSort = 'latest';
let currentRange = 'city';
let pendingApplyId = null;

function getList() {
  let list = ACTIVITIES.filter(a => currentRange === 'state' || a.region === 'city');
  if (currentSort === 'latest') list.sort((a,b) => b.createdAt - a.createdAt);
  else if (currentSort === 'score-high') list.sort((a,b) => b.crewScore - a.crewScore);
  else list.sort((a,b) => a.crewScore - b.crewScore);
  return list;
}

function fmtDate(str) {
  return new Date(str).toLocaleDateString('ko-KR',{month:'long',day:'numeric',weekday:'short'});
}

function renderList() {
  const list = getList();
  document.getElementById('totalCount').textContent = `총 ${list.length}건`;
  const cont = document.getElementById('activityList');

  if (!list.length) {
    cont.innerHTML = `<div class="activity-empty"><div class="activity-empty-icon">📭</div><div class="activity-empty-title">등록된 활동이 없어요</div><div class="activity-empty-sub">[＋ 활동] 버튼으로 새 활동을 등록해보세요</div></div>`;
    return;
  }

  cont.innerHTML = list.map(a => {
    const own = a.crewId === MY_CREW_ID;
    const typeBadge = a.type === 'battle'
      ? `<span class="type-badge type-battle">대전</span>`
      : `<span class="type-badge type-internal">내전</span>`;
    const applyBtn = own
      ? `<button class="apply-btn own" disabled>내 크루</button>`
      : `<button class="apply-btn" onclick="openApply(event,'${a.id}')">⚔️ 신청</button>`;
    const appTag = a.applications.length
      ? `<span class="app-count-tag">${a.applications.length}</span>` : '';
    const ownTag = own ? `<span class="own-tag">내 크루</span>` : '';

    return `<div class="activity-card" id="card-${a.id}">
      <div class="activity-row" onclick="toggleApps('${a.id}')">
        ${typeBadge}
        <div class="activity-main">
          <div class="activity-title">${a.crewName}${appTag} ${ownTag}</div>
          <div class="activity-meta">
            <span>📅 ${fmtDate(a.date)}</span>
            <span>📍 ${a.place.split(' ').slice(2).join(' ')}</span>
            <span>👥 ${a.count}명</span>
          </div>
          <div class="activity-desc">${a.content}</div>
        </div>
        <div class="crew-score">
          <span class="score-val">${a.crewScore.toLocaleString()}</span>
          <span class="score-label">크루 점수</span>
        </div>
        <div style="display:flex;align-items:center;gap:8px">
          ${applyBtn}
          <span class="chevron" id="chev-${a.id}">▼</span>
        </div>
      </div>
      <div class="apps-panel" id="apps-${a.id}">
        ${renderApps(a)}
      </div>
    </div>`;
  }).join('');
}

function renderApps(a) {
  const own = a.crewId === MY_CREW_ID;
  const title = `<div class="apps-panel-title">신청 목록 (${a.applications.length}건)</div>`;
  if (!a.applications.length) return title + `<div class="apps-empty">아직 신청이 없어요</div>`;
  return title + a.applications.map(app => `
    <div class="app-item" id="appcard-${app.id}">
      <div class="app-crew-av">${app.crewEmoji}</div>
      <div class="app-info">
        <div class="app-crew-name">${app.crewName}</div>
        <div class="app-message">${app.message}</div>
      </div>
      <div class="app-date">${app.date}</div>
      ${own ? `<div class="app-actions">
        <button class="app-accept" onclick="handleApp(event,'${app.id}','${a.id}','accept')">✓ 수락</button>
        <button class="app-reject" onclick="handleApp(event,'${app.id}','${a.id}','reject')">✕ 거절</button>
      </div>` : ''}
    </div>`).join('');
}

function toggleApps(id) {
  document.getElementById('apps-'+id).classList.toggle('open');
  document.getElementById('chev-'+id).classList.toggle('open');
}

function setSort(btn) {
  currentSort = btn.dataset.sort;
  document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderList();
}
function setRange(v) { currentRange = v; renderList(); }

let selType = 'battle';
function openCreateModal() {
  document.getElementById('new-date').value = new Date().toISOString().split('T')[0];
  document.getElementById('new-count').value = '';
  document.getElementById('new-place').value = '';
  document.getElementById('new-place-detail').value = '';
  document.getElementById('new-content').value = '';
  selectType('battle');
  openModal('modalCreate');
}
function selectType(t) {
  selType = t;
  document.getElementById('chip-battle').className = 'type-chip' + (t==='battle'?' sel-battle':'');
  document.getElementById('chip-internal').className = 'type-chip' + (t==='internal'?' sel-internal':'');
}
function searchAddress() {
  const fakes = ['서울 마포구 망원동 100-1','서울 마포구 합정동 22-5','서울 마포구 상수동 70','서울 마포구 서교동 350'];
  document.getElementById('new-place').value = fakes[Math.floor(Math.random()*fakes.length)];
  showToast('📍 주소가 선택되었습니다');
}
function submitCreate() {
  const date = document.getElementById('new-date').value;
  const count = document.getElementById('new-count').value;
  const place = document.getElementById('new-place').value;
  const detail = document.getElementById('new-place-detail').value;
  const content = document.getElementById('new-content').value;
  if (!date) { showToast('⚠️ 날짜를 입력해주세요'); return; }
  if (!count || count < 2) { showToast('⚠️ 인원수를 입력해주세요 (최소 2명)'); return; }
  if (!place) { showToast('⚠️ 장소를 검색해서 선택해주세요'); return; }
  ACTIVITIES.unshift({
    id:'act_'+Date.now(), crewId:MY_CREW_ID, crewName:'마포 후크슛', crewEmoji:'🏀', crewScore:980,
    date, place, placeDetail:detail, count:parseInt(count), type:selType,
    content:content||'활동 내용 없음', region:'city', createdAt:new Date(), applications:[],
  });
  closeModal('modalCreate'); renderList();
  showToast(selType==='internal' ? '✅ 내전 활동이 등록되어 스케줄에 저장되었습니다' : '✅ 대전 활동이 등록되었습니다');
}

function openApply(e, id) {
  e.stopPropagation();
  const a = ACTIVITIES.find(x => x.id===id);
  if (!a) return;
  pendingApplyId = id;
  document.getElementById('applyName').textContent = a.crewName;
  document.getElementById('applyMeta').textContent = a.place.split(' ').slice(0,2).join(' ') + ' · 농구';
  document.getElementById('applyChips').innerHTML =
    `<span class="info-chip">📅 ${fmtDate(a.date)}</span>
     <span class="info-chip">📍 ${a.place.split(' ').slice(2).join(' ')}</span>
     <span class="info-chip">👥 ${a.count}명</span>`;
  document.getElementById('apply-message').value = '';
  openModal('modalApply');
}
function submitApply() {
  const msg = document.getElementById('apply-message').value.trim();
  if (!msg) { showToast('⚠️ 신청 메시지를 입력해주세요'); return; }
  const a = ACTIVITIES.find(x => x.id===pendingApplyId);
  if (a) {
    a.applications.push({ id:'app_'+Date.now(), crewId:MY_CREW_ID, crewName:'마포 후크슛', crewEmoji:'🏀', message:msg, date:new Date().toISOString().split('T')[0] });
    renderList();
  }
  closeModal('modalApply');
  showToast('✅ 대전 신청이 완료되었습니다');
}

function handleApp(e, appId, actId, action) {
  e.stopPropagation();
  const a = ACTIVITIES.find(x => x.id===actId);
  if (!a) return;
  if (action==='accept') {
    a.applications = a.applications.filter(x => x.id!==appId);
    renderList();
    setTimeout(() => {
      const p = document.getElementById('apps-'+actId), ch = document.getElementById('chev-'+actId);
      if (p) { p.classList.add('open'); ch.classList.add('open'); }
    }, 50);
    showToast('✅ 신청을 수락했습니다. 스케줄에 저장되었습니다!');
  } else {
    const card = document.getElementById('appcard-'+appId);
    if (card) { card.style.transition='opacity .3s,transform .3s'; card.style.opacity='0'; card.style.transform='translateX(12px)'; }
    setTimeout(() => {
      a.applications = a.applications.filter(x => x.id!==appId);
      renderList();
      setTimeout(() => {
        const p = document.getElementById('apps-'+actId), ch = document.getElementById('chev-'+actId);
        if (p) { p.classList.add('open'); ch.classList.add('open'); }
      }, 50);
    }, 300);
    showToast('❌ 신청을 거절했습니다');
  }
}

function openModal(id) { 
  const el = document.getElementById(id);
  el.style.display = 'flex';
  el.classList.add('open'); 
  document.body.style.overflow='hidden'; 
}
function closeModal(id) { 
  const el = document.getElementById(id);
  el.classList.remove('open');
  el.style.display = 'none';
  document.body.style.overflow=''; 
}
document.querySelectorAll('.modal-overlay').forEach(el => el.addEventListener('click', e => { if(e.target===el) closeModal(el.id); }));

function showToast(msg) {
  const t = document.getElementById('actToast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

renderList();
</script>
</body>
</html>
