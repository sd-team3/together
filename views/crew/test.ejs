<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/head', { title: '정기 모임 만들기', pageId: 'page-regular-create', active: '' }) %>

<button type="button" id="application-btn" data-crew-id="6a02f839646aa928c3a7a8c5">크루 신청하기</button>

<script>

    document.getElementById('application-btn').addEventListener('click', async (e) => {
        // 1. 버튼에 심어둔 crewId 가져오기
        const crewId = e.target.dataset.crewId;
        const crewType = 'regularCrew';

        try {
            // 2. 서버로 POST 요청 보내기
            const response = await fetch('/regular/application', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ crewId: crewId, crewType: crewType }) // 데이터를 JSON으로 변환
            });

            const result = await response.json();

            if (response.ok) {
                alert('신청이 완료되었습니다! 🚀');
            } else {
                alert('신청 실패: ' + result.message);
            }
        } catch (error) {
            console.error('에러 발생:', error);
            alert('서버와 통신 중 오류가 발생했습니다.');
        }
    });

    
</script>


</body>
</html>
