<!-- 정기모임 크루 가입 신청 페이지 -->
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 모임 상세</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
<%- include('../partials/head', { title: `✏️ ${crew.title} - 가입 신청`, pageId: 'page-crew-detail', active: '', route: `/regular/list/${crew._id}` }) %>

  <div class="page-body">
    <div class="detail-wrap">

      <!-- 뒤로가기 -->
      <a href="/regular/list" class="goback-btn">← 목록으로</a>

      <div class="detail-group">

      <!-- 헤더 -->
      <div class="detail-header">
        <img src="<%= crew.profileImage %>" class="detail-sport-icon">
        <div class="detail-header-info">
          <div class="detail-title"><%= crew.title %></div>
          <div class="detail-sub"><%= crew.address.state %> · <%= crew.address.city %></div>
        </div>
      <!-- 좋아요 버튼 -->
       <% if (userId) { %>
        <button class="detail-like-btn" id="like-btn" data-id="<%= crew._id %>" onclick="toggleLike('<%= userId %>')">
          <span class="like-icon">🤍</span>
          <span class="like-count" id="like-count"><%= crew.reputation %></span>
        </button>
       <% } else { %>
        <button class="detail-like-btn" id="like-btn" data-id="<%= crew._id %>" onclick="alert('로그인 먼저 하세요'); return false;">
          <span class="like-icon">🤍</span>
          <span class="like-count" id="like-count"><%= crew.reputation %></span>
        </button>
        <% } %>
      </div>

      <!-- 모임장 -->
      <div class="detail-section">
        <div class="detail-section-title">모임장</div>
        <div class="host-card">
          <div class="host-avatar">
            <!-- <img src="/images/user-profile/<%= crew.host.profileImage %>" alt="호스트 프사"> -->
          </div>
          <div>
            <div class="host-name"><%= crew.host.name %></div>
          </div>
        </div>
      </div>

      <!-- 소개글 -->
      <div class="detail-section">
        <div class="detail-section-title">모임 소개</div>
        <div class="detail-intro"><%= crew.intro %></div>
      </div>

      <!-- 가입 조건 -->
      <div class="detail-section">
        <div class="detail-section-title">가입 조건</div>
        <div class="condition-list">
          <div class="condition-item">
            <span class="cond-label">경기 종목</span>
            <span class="cond-value"><%= crew.sportLabel %></span>
          </div>
          <div class="condition-item">
            <span class="cond-label">활동 요일</span>
            <span class="cond-value"><%= crew.dayLabel %></span>
          </div>
          <div class="condition-item">
            <span class="cond-label">주기</span>
            <span class="cond-value"><%= crew.periodLabel %></span>
          </div>
          <div class="condition-item">
            <span class="cond-label">연령대</span>
            <span class="cond-value"><%= crew.ageLabel %></span>
          </div>
          <div class="condition-item">
            <span class="cond-label">실력</span>
            <span class="cond-value"><%= crew.levelLabel %></span>
          </div>
          <div class="condition-item">
            <span class="cond-label">참가비</span>
            <span class="cond-value"><%= crew.fee > 0 ? crew.fee.toLocaleString() + '원/회' : '무료' %></span>
          </div>
          <div class="condition-item">
            <span class="cond-label">승인</span>
            <span class="cond-value"><%= crew.acceptLabel %></span>
          </div>
        </div>
      </div>

      <!-- 멤버 현황 -->
      <div class="detail-section">
        <div class="detail-section-title">멤버 수</div>
        <div class="member-status">
          <div class="member-status-row">
            <span class="member-count">현재 <%= crew.member.memberList.length %>인 / 최대 <%= crew.member.capacity %>인</span>
          </div>
        </div>
      </div>

      </div>

      <!-- 하단 가입 버튼 -->
      <div class="detail-footer">
        <div class="detail-footer">
          <button class="join-btn" id="join-btn" style="display: none;"></button>
        </div>

        <script>
          document.addEventListener('DOMContentLoaded', () => {
            const userId = '<%= userId || "" %>';
            const crewId = '<%= crew._id %>';
            const joinBtn = document.getElementById('join-btn');

            if (!userId) {
              joinBtn.textContent = '가입 신청하기';
              joinBtn.style.display = 'block';
              joinBtn.onclick = () => {
                alert('로그인 후 이용할 수 있습니다.');
                location.href = '/user/login';
              };
              return;
            }

            fetch(`/regular/relation/${crewId}/${userId}`)
              .then(res => res.json())
              .then(data => {
                joinBtn.style.display = 'block';

                if (data.relation === 'member') {
                  // 이미 멤버인 경우
                  joinBtn.textContent = '이미 가입된 크루입니다';
                  joinBtn.disabled = true;
                  joinBtn.style.cssText = "background-color: #a0a0a0; color: #ffffff; cursor: not-allowed; border: none;";
                
                } else if (data.relation === 'none') {
                  joinBtn.textContent = '가입 신청하기';
                  joinBtn.disabled = false;
                  joinBtn.style.cssText = "";
                  joinBtn.onclick = () => confirmJoin(crewId);
                
                } else {
                  joinBtn.textContent = '3일에 한 번만 신청 가능합니다.';
                  joinBtn.disabled = true;
                  joinBtn.style.cssText = "background-color: #a0a0a0; color: #ffffff; cursor: not-allowed; border: none;";
                }
              })
              .catch(err => {
                console.error("관계 확인 중 에러 발생:", err);
                joinBtn.textContent = '가입 신청하기';
                joinBtn.style.display = 'block';
                joinBtn.onclick = () => confirmJoin(crewId);
              });
          });
        </script>
      </div>
    </div>
  </div>
</div>
<script>
let liked = <%= isLiked === true ? 'true' : 'false' %>;
let likeCount = <%= crew.reputation %>;
</script>
<script src="/js/like.js"></script>

<script>
  async function confirmJoin(crewId) {
    if (!confirm('가입 신청을 하시겠습니까?')) {
      return;
    }

    try {
      const response = await fetch(`/regular/application/${crewId}`, {
        method : 'POST',
        headers : {
          'Content-Type' : 'application/json'
        }
      });

      if (response.status == 201) {
        alert('가입 신청 완료!');
        window.location.reload();
      } else {
        const errorData = await response.json();
        alert(errorData.message || '신청 중 문제가 발생했습니다.');
      }
    } catch (error) {
      console.error('가입 신청 오류 : ' , error);
      alert('서버 오류가 났습니다. 잠시 후 다시 시도해주세요');
    }
  }

</script>
</body>
</html>