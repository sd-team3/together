<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 본인 확인</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>

<%- include('partials/navbar') %>

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<%- include('partials/head', { title: '🔒 본인 확인', pageId: 'page-verify-password', active: '' }) %>

    <!-- 본문 -->
    <div class="verify-wrap">
      <div class="verify-card">

        <div class="verify-icon">🔐</div>
        <div class="verify-title">프로필 수정 전 본인 확인</div>
        <div class="verify-sub">
          개인정보 보호를 위해 현재 비밀번호를 입력해 주세요.<br>
          확인 후 프로필 수정 페이지로 이동합니다.
        </div>

        <!-- 현재 로그인 유저 -->
        <div class="verify-user-row">
          <div class="verify-av">JH</div>
          <div>
            <div class="verify-user-name">홍길동</div>
            <div class="verify-user-email">tes@t.come</div>
          </div>
        </div>
        <form action = "/user/verify-password" method="POST">
        <!-- 비밀번호 입력 -->
        <div class="verify-field">
          <label class="verify-label">현재 비밀번호</label>
          <div class="verify-input-wrap">
            <input type="password" id="inputPassword" name = "password" class="verify-input" placeholder="현재 비밀번호를 입력하세요" autocomplete="current-password">
            <button class="pw-eye-btn" type="button" id="passwordEye">👁️</button>
          </div>
        </div>

        <!-- 에러 메시지 (기본 숨김) -->
        <div class="verify-error-msg" id="verify-error-msg">
          <span>⚠️</span>
          <span>비밀번호가 올바르지 않습니다.</span>
        </div>

        <!-- 확인 버튼 -->
        <button class="verify-btn" type="submit" id="verify-btn">본인 확인 후 프로필 수정하기</button>
        </form>

        <div class="verify-divider">또는</div>

        <!-- <a href="/user/mypage" class=""verify-back>마이 페이지로 돌아가기</a> -->
        <button class="verify-back" type="button" id="backMyPage">← 마이페이지로 돌아가기</button>
        
        <!-- 보안 안내 -->
        <div class="verify-security-note">
          <span class="verify-security-icon">🛡️</span>
          <span>비밀번호를 잊으셨나요? <span class="verify-reset-link" id="reset-link">비밀번호 재설정</span>을 통해 변경하실 수 있습니다.</span>
        </div>

      </div>
    </div>
  </div>
</div><!-- /main -->

<!-- ═══════ MODAL ═══════ -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <div class="modal-icon" id="modal-icon">🎉</div>
    <div class="modal-title" id="modal-title">완료!</div>
    <div class="modal-msg" id="modal-msg">처리가 완료되었습니다.</div>
    <div class="modal-btns">
      <button class="btn btn-outline flex-1" id="modal-close">닫기</button>
      <button class="btn btn-primary flex-1" id="modal-ok">확인</button>
    </div>
  </div>
</div>

</body>
<script>
  const passwordEye = document.getElementById('passwordEye');
  const inputPassword = document.getElementById('inputPassword');
  const backMyPage = document.getElementById('backMyPage');

  passwordEye.addEventListener('mousedown', () => {
    inputPassword.type = 'text';
  });
  passwordEye.addEventListener('mouseup', () => {
    inputPassword.type = 'password';
  });
  backMyPage.addEventListener('click', () => {
    location.href = "/user/mypage";
  });
  
</script>
</html>