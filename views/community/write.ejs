<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>글쓰기 — SPORTMATCH</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
  <%- include('../partials/head', { title: '✏️ 글쓰기', pageId: 'page-community-write', active: '', route: '/community/write' }) %>

  <div class="page-body">
    <div class="write-wrap">

      <!-- 에러 메시지 -->
      <% if (locals.error) { %>
        <div class="write-error-msg">⚠️ <%= error %></div>
      <% } %>

      <!-- file 필드가 있으므로 multipart/form-data 필수 -->
      <form
        action="/community/write"
        method="POST"
        enctype="multipart/form-data"
        class="write-form"
        id="writeForm"
      >

        <!-- ① 카테고리 (enum: question | tip | free) -->
        <div class="form-group">
          <label class="form-label">카테고리 <span class="required">*</span></label>
          <div class="chip-group" style="gap:8px">
            <label class="chip-radio">
              <input type="radio" name="category" value="question"
                <%= locals.old && old.category === 'question' ? 'checked' : '' %>> 질문
            </label>
            <label class="chip-radio">
              <input type="radio" name="category" value="tip"
                <%= locals.old && old.category === 'tip' ? 'checked' : '' %>> 팁/정보
            </label>
            <label class="chip-radio">
              <input type="radio" name="category" value="free"
                <%= (locals.old && old.category === 'free') || !locals.old ? 'checked' : '' %>> 자유
            </label>
          </div>
        </div>

        <!-- ② 제목 (required) -->
        <div class="form-group">
          <label class="form-label" for="title">제목 <span class="required">*</span></label>
          <input
            type="text"
            id="title"
            name="title"
            class="form-control"
            placeholder="제목을 입력하세요"
            maxlength="100"
            value="<%= locals.old ? old.title : '' %>"
            autocomplete="off"
          >
          <div class="char-count"><span id="titleCount">0</span> / 100</div>
        </div>

        <!-- ③ 내용 (required) -->
        <div class="form-group">
          <label class="form-label" for="content">내용 <span class="required">*</span></label>
          <textarea
            id="content"
            name="content"
            class="form-control"
            placeholder="내용을 입력하세요"
            rows="12"
            maxlength="5000"
            style="resize:vertical;line-height:1.7"
          ><%= locals.old ? old.content : '' %></textarea>
          <div class="char-count"><span id="contentCount">0</span> / 5000</div>
        </div>

        <!-- ④ 파일 첨부 (file: String | null) -->
        <div class="form-group">
          <label class="form-label">이미지 첨부 <span class="optional">(선택)</span></label>
          <label class="file-upload-label" id="fileLabel">
            <input
              type="file"
              name="file"
              id="fileInput"
              accept="image/*"
              style="display:none"
            >
            <span class="file-icon">📎</span>
            <span id="fileName">파일을 선택하거나 여기에 드래그하세요</span>
          </label>
          <!-- 미리보기 -->
          <div id="previewWrap" style="display:none;margin-top:10px;position:relative;width:fit-content">
            <img id="previewImg" src="" alt="미리보기"
              style="max-width:100%;max-height:240px;border-radius:8px;border:1px solid var(--border)">
            <button type="button" id="removeFile"
              style="position:absolute;top:6px;right:6px;background:rgba(0,0,0,.55);color:#fff;border:none;border-radius:50%;width:24px;height:24px;cursor:pointer;font-size:14px;line-height:1">✕</button>
          </div>
        </div>

        <!-- 버튼 -->
        <div class="write-actions">
          <a href="/community/list" class="btn btn-ghost">취소</a>
          <button type="submit" class="btn btn-primary" id="submitBtn">등록하기</button>
        </div>

      </form>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  /* ── 글자수 카운터 ── */
  const titleInput   = document.getElementById('title');
  const contentInput = document.getElementById('content');
  const titleCount   = document.getElementById('titleCount');
  const contentCount = document.getElementById('contentCount');

  const updateCount = (input, counter) => counter.textContent = input.value.length;
  titleInput.addEventListener('input',   () => updateCount(titleInput,   titleCount));
  contentInput.addEventListener('input', () => updateCount(contentInput, contentCount));
  updateCount(titleInput,   titleCount);
  updateCount(contentInput, contentCount);

  /* ── 카테고리 chip 스타일 ── */
  const chipRadios = document.querySelectorAll('.chip-radio input[type=radio]');
  const syncChips  = () => chipRadios.forEach(r =>
    r.closest('.chip-radio').classList.toggle('on', r.checked)
  );
  chipRadios.forEach(r => r.addEventListener('change', syncChips));
  syncChips();

  /* ── 파일 첨부 미리보기 ── */
  const fileInput   = document.getElementById('fileInput');
  const fileLabel   = document.getElementById('fileLabel');
  const fileName    = document.getElementById('fileName');
  const previewWrap = document.getElementById('previewWrap');
  const previewImg  = document.getElementById('previewImg');
  const removeFile  = document.getElementById('removeFile');

  fileInput.addEventListener('change', () => {
    const file = fileInput.files[0];
    if (!file) return;
    fileName.textContent = file.name;
    const reader = new FileReader();
    reader.onload = e => {
      previewImg.src = e.target.result;
      previewWrap.style.display = 'block';
    };
    reader.readAsDataURL(file);
  });

  removeFile.addEventListener('click', () => {
    fileInput.value   = '';
    fileName.textContent = '파일을 선택하거나 여기에 드래그하세요';
    previewWrap.style.display = 'none';
    previewImg.src = '';
  });

  /* ── 드래그 앤 드롭 ── */
  fileLabel.addEventListener('dragover', e => { e.preventDefault(); fileLabel.classList.add('drag-over'); });
  fileLabel.addEventListener('dragleave', ()  => fileLabel.classList.remove('drag-over'));
  fileLabel.addEventListener('drop', e => {
    e.preventDefault();
    fileLabel.classList.remove('drag-over');
    const file = e.dataTransfer.files[0];
    if (!file || !file.type.startsWith('image/')) return;
    // DataTransfer를 input에 반영
    const dt = new DataTransfer();
    dt.items.add(file);
    fileInput.files = dt.files;
    fileInput.dispatchEvent(new Event('change'));
  });

  /* ── 제출 유효성 검사 & 중복 방지 ── */
  document.getElementById('writeForm').addEventListener('submit', e => {
    const category = document.querySelector('input[name="category"]:checked');
    const title    = titleInput.value.trim();
    const content  = contentInput.value.trim();

    if (!category) { e.preventDefault(); alert('카테고리를 선택해주세요.'); return; }
    if (!title)    { e.preventDefault(); alert('제목을 입력해주세요.');     return; }
    if (!content)  { e.preventDefault(); alert('내용을 입력해주세요.');     return; }

    const btn = document.getElementById('submitBtn');
    btn.disabled     = true;
    btn.textContent  = '등록 중...';
  });
});
</script>
</body>
</html>
