<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
<%- include('../partials/head', { title: '💬 커뮤니티', pageId: 'page-community', active: '' }) %>

  <div class="page-body">
    <div class="detail-wrap">

      <a href="/community/list/<%= board._id %>" class="goback-btn">← 돌아가기</a>

      <div class="detail-group">
        <div class="detail-section-title">게시글 수정</div>

        <form action="/community/list/<%= board._id %>/edit" method="POST">
          <div style="display:flex;flex-direction:column;gap:12px;margin-top:16px">

            <!-- 제목 -->
            <div>
              <label style="font-size:13px;font-weight:600;color:var(--text-2);margin-bottom:4px;display:block">제목</label>
              <input 
                type="text" 
                name="title" 
                value="<%= board.title %>"
                style="width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-size:14px;background:var(--surface-1);color:var(--text-1);font-family:inherit"
              />
            </div>

            <!-- 내용 -->
            <div>
              <label style="font-size:13px;font-weight:600;color:var(--text-2);margin-bottom:4px;display:block">내용</label>
              <textarea 
                name="content" 
                rows="10"
                style="width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-size:14px;resize:vertical;background:var(--surface-1);color:var(--text-1);font-family:inherit"
              ><%= board.content %></textarea>
            </div>

            <!-- 버튼 -->
            <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:4px">
              <a href="/community/list/<%= board._id %>" class="btn" style="background:var(--surface-2);color:var(--text-2);border:1px solid var(--border)">취소</a>
              <button type="submit" class="btn btn-primary">수정 완료</button>
            </div>

          </div>
        </form>
      </div>

    </div>
  </div>
</div>
</body>
</html>