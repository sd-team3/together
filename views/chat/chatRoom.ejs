<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
<%- include('../partials/navbar') %>
<!-- ═══════ MAIN ═══════ -->

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<!-- ──────── CHAT PAGE ──────── -->
<%- include('../partials/head', { title: '✉️ 채팅', pageId: 'page-chat', active: '' }) %>

  <div class="page-body-wide" style="flex:1">
    <div class="chat-layout" style="flex:1">
      <!-- Room List -->
<div class="chat-rooms">
  <div class="chat-rooms-header">
    <div class="chat-rooms-title">채팅방</div>
  </div>

  <!-- 탭 버튼 -->
  <div style="display:flex;border-bottom:1px solid #eee;">
    <button onclick="location.href='/chatRoom/chatPage?crewType=regular'"
      style="flex:1;padding:10px;border:none;background:none;cursor:pointer;font-weight:600;
      <%= !crewType || crewType === 'regular' ? 'border-bottom:2px solid #000;' : 'color:#aaa;' %>">
      정기모임
    </button>
    <button onclick="location.href='/chatRoom/chatPage?crewType=instant'"
      style="flex:1;padding:10px;border:none;background:none;cursor:pointer;font-weight:600;
      <%= crewType === 'instant' ? 'border-bottom:2px solid #000;' : 'color:#aaa;' %>">
      ⚡ 번개모임
    </button>
  </div>

  <div class="chat-rooms-list">
    <% if (!chatRoomList || chatRoomList.length === 0) { %>
      <div style="padding:40px;text-align:center;color:#999;">
        <div style="font-size:32px;margin-bottom:12px">📭</div>
        <div>채팅방이 없습니다</div>
      </div>
    <% } else { %>
      <% chatRoomList.forEach(room => { %>
        <div class="chat-room-item" data-id="<%= room._id %>" style="cursor:pointer;">
          <div class="cr-av"><%= room.crewType === 'instant' ? '⚡' : '🏃' %></div>
          <div class="cr-info">
            <div class="cr-top">
              <div class="cr-name"><%= room.name %></div>
              <span style="font-size:11px;color:#aaa;"><%= room.crewType === 'instant' ? '번개' : '정기' %></span>
            </div>
            <div class="cr-preview"><%= room.lastMessage?.content %></div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>
      <!-- Chat Area -->
      <div class="chat-area">
        <div class="chat-header">
          <div class="chat-hd-av" id="chatRoomIcon">⚽</div>
          <div>
            <div class="chat-hd-name" id="chatRoomName">
                <%= room ? room.name : '채팅방을 선택하세요' %>
            </div>
            <div class="chat-hd-meta" id="chatRoomMeta">
              <%= room ? '대화 참여중' : '채팅방을 선택하세요' %>
            </div>
          </div>
        </div>

        <div class="chat-msgs" id="chatMessages">
          <% if (!room) { %>
            <div class="chat-date-divider">채팅방을 선택하세요</div>
          <% } else { %>
            <div class="chat-date-divider">오늘</div>
            <% messages.forEach(msg => { %>
              <% if (String(msg.sender._id) === String(currentUserId)) { %>
                <!-- 내가 보낸 메시지 -->
                <div class="msg-row mine">
                  <div class="msg-content">
                    <div class="msg-bubble mine"><%= msg.content %></div>
                    <div class="msg-time"></div>
                  </div>
                </div>
              <% } else { %>
                <!-- 남이 보낸 메시지 -->
                <div class="msg-row">
                  <div class="msg-content">
                    <div class="msg-sender"><%= msg.sender.name %></div>
                    <div class="msg-bubble theirs"><%= msg.content %></div>
                    <div class="msg-time"></div>
                  </div>
                </div>
              <% } %>
            <% }) %>
          <% } %>
        </div>
              
        <div class="chat-input-area">
          <textarea class="chat-input" id="chatInput" rows="1" placeholder="메시지를 입력하세요..." onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendChatMsg()}"></textarea>
          <button class="chat-send-btn" onclick="sendChatMsg()">↑</button>
        </div>
      </div>
        </div>
      </div>
    </div>
  </div>
</div>

</div><!-- /.main -->

<script src="/socket.io/socket.io.js"></script>
<script type="module" src = "/js/chat/api.js"></script>

<script>
  const chatMessages = document.getElementById('chatMessages');
  const chatInput = document.getElementById('chatInput');

  const chatUser = '<%- JSON.stringify(user) %>';
  const roomId = '<%= room ? room._id.toString() : "" %>';

  const parsedUser  = JSON.parse(chatUser);

  let chatSocket = null;

  async function connectSocket(roomId) {
    if (chatSocket) {
      chatSocket.disconnect();
    }

    chatSocket = io('/chat', {
        auth: {
            roomId: roomId,
            userId: parsedUser._id,
            userName: parsedUser.name
        }
    });
    chatSocket.on('connect', () => console.log('소켓연결'));
    chatSocket.on('connect_error', (error) => console.log('소켓 연결 오류', error));
    chatSocket.on('disconnect', (reason) => console.log('소켓 연결 끊김', reason));
    chatSocket.on('join', (data) => inOutMessage(data.chat));
    chatSocket.on('chat message', (data) => renderChatMessage(data));
    chatSocket.on('exit', (data) => inOutMessage(data.chat));
  }

  // 채팅방 클릭 이벤트
  document.addEventListener('click', async function(e) {
    const chat = e.target.closest('.chat-room-item');
    if (!chat) return;

    const chatRoomId = chat.dataset.id;
    console.log("ID : ", chatRoomId);

    try {
      const data = await fetchChatRoomData(chatRoomId);

      if (data && data.success) {
        console.log('messages:', data.messages); // 👈 추가
        renderChatRoomUI(data.room, data.messages ,data.currentUserId);

        window.currentRoomId = data.room._id;
        connectSocket(chatRoomId);
      }
    } catch (error) {
      console.error('채팅방 불러오기 실패')
    }
  });

  async function fetchChatRoomData(roomId) {
    const params = new URLSearchParams();

    if (roomId) {
        params.append('roomId', roomId);
    }
    try {
        const res = await fetch('/chatRoom/chatList/api?' + params.toString());

        if (!res.ok) {
            throw new Error(`서버 응답오류 ( 상태 코드 : ${res.status})`);
        }

        const data = await res.json();

        if (!data.success) {
        throw new Error('데이터 요청 실패');
        }

        return data; 
    } catch (error) {
        console.error('API 통신 에러:', error);
        throw error; 
    }
}

  // 채팅방 UI 재구성
  function renderChatRoomUI(room, messages, currentUserId) {
    const chatRoomName = document.getElementById('chatRoomName');
    if (chatRoomName) {
      chatRoomName.innerText = room.name;
    }

    chatMessages.innerHTML = ''; // 초기화

    if (!messages || messages.length === 0) {
      chatMessages.innerHTML = `<div class="chat-date-divider">메시지를 남기세요!</div>`;
      return;
    }

   chatMessages.insertAdjacentHTML('beforeend', `<div class="chat-date-divider">오늘</div>`);

   messages.forEach(msg => {
    const isMine = String(msg.sender._id) === String(currentUserId);
    let msgHtml = '';

    if (isMine) {
      msgHtml = `
        <div class="msg-row mine">
          <div class="msg-content">
            <div class="msg-bubble mine">${escapeHTML(msg.content)}</div>
            <div class="msg-time">${msg.createdAt}</div>
          </div>
        </div>
      `;
    } else {
      msgHtml = `
        <div class="msg-row">
          <div class="msg-content">
            <div class="msg-sender">${escapeHTML(msg.sender.name)}</div>
            <div class="msg-bubble theirs">${escapeHTML(msg.content)}</div>
            <div class="msg-time">${msg.createdAt}</div>
          </div>
        </div>
      `;
    }
    chatMessages.insertAdjacentHTML('beforeend', msgHtml);
   });
  // escapeHTML : 보안을 위해 쓰는 코드. html에 넣는 거라서 코드 그래도 치면 html에 추가 될 수도 있음 
    
  scrollToBottom();
}

  function sendChatMsg() {
    const msg = chatInput.value.trim();

    if (!msg || !window.currentRoomId) {
      return;
    }
    // 서버에 emit
    chatSocket.emit('chat message', msg);
    // 서버에 보냈으니 비우기
    chatInput.value = '';
  }

  function renderChatMessage(data) {
    const myId = String(data.userId) === String(parsedUser._id);
    const row = document.createElement('div');

    if (myId) {
      row.className = 'msg-row mine';
      row.innerHTML = `
        <div class="msg-content">
          <div class="msg-bubble mine">${escapeHTML(data.chat)}</div>
          <div class="msg-time">방금</div>
        </div>
      `;
    } else {
      row.className = 'msg-row';
      row.innerHTML = `
        <div class="msg-content">
          <div class="msg-sender">${escapeHTML(data.userName || '알 수 없음')}</div>
          <div class="msg-bubble theirs">${escapeHTML(data.chat)}</div>
          <div class="msg-time">방금</div>
        </div>
      `;
    }
    chatMessages.appendChild(row);
    scrollToBottom();
  }


  function inOutMessage(message) {
    const div = document.createElement('div');

    div.textContent = message;

    chatMessages.appendChild(div);
    scrollToBottom();
  }

  function scrollToBottom() {
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }
  // 이건 해킹을 방지하기 위해 쓴 함수
  function escapeHTML(text) {
    return String(text)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  scrollToBottom();
</script>

</body>
</html>
