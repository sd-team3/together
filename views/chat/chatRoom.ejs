<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
<%- include('../partials/navbar') %>
<div class="main">
<%- include('../partials/head', { title: '✉️ 채팅', pageId: 'page-chat', active: '', route: '/chatRoom/chatPage' }) %>

  <div class="page-body-wide" style="flex:1;height:0;overflow:hidden;">
  <div class="chat-layout" style="height:100%;">
      <!-- Room List -->
<div class="chat-rooms">
  <div class="chat-rooms-header">
    <div class="chat-rooms-title">채팅방</div>
  </div>

  <!-- 탭 버튼 -->
  <div style="display:flex;border-bottom:1px solid var(--border);">
    <button onclick="location.href='/chatRoom/chatPage?crewType=regular'"
      style="flex:1;padding:10px;border:none;background:none;cursor:pointer;font-weight:600;color:var(--text);<%= !crewType || crewType === 'regular' ? 'border-bottom:2px solid var(--text);' : 'color:var(--text-3);' %>">
      정기모임
    </button>
    <button onclick="location.href='/chatRoom/chatPage?crewType=instant'"
      style="flex:1;padding:10px;border:none;background:none;cursor:pointer;font-weight:600;color:var(--text);<%= crewType === 'instant' ? 'border-bottom:2px solid var(--text);' : 'color:var(--text-3);' %>">
      번개모임
    </button>
</div>

  <div class="chat-rooms-list">
    <% if (!chatRoomList || chatRoomList.length === 0) { %>
      <div style="padding:40px;text-align:center;color:#999;">
        <div style="font-size:32px;margin-bottom:12px">📭</div>
        <div>채팅방이 없습니다</div>
      </div>
    <% } else { %>
      <% chatRoomList.forEach(room => { %>
        <div class="chat-room-item" data-id="<%= room._id %>" data-last-at="<%= room.lastMessageAt %>" style="cursor:pointer;">
          <div class="cr-av"><%= room.crewType === 'instant' ? '⚡' : '🏃' %></div>
          <div class="cr-info">
            <div class="cr-top">
              <div class="cr-name"><%= room.name %></div>
              <span style="font-size:11px;color:#aaa;"><%= room.crewType === 'instant' ? '번개' : '정기' %></span>
            </div>
            <div class="cr-preview" style="display:flex;justify-content:space-between;align-items:center;">
              <span><%= room.lastMessage?.content %></span>
              <span class="cr-time-ago" style="font-size:11px;color:#aaa;flex-shrink:0;margin-left:8px;"></span>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

      <!-- Chat Area -->
      <div class="chat-area">
        <div class="chat-header">
        <div class="chat-hd-av" id="chatRoomIcon">
          <%= room ? (room.crewType === 'instant' ? '⚡' : '🏃') : '💬' %>
        </div>
        <div style="flex:1;">
          <div class="chat-hd-name" id="chatRoomName">
            <%= room ? room.name : '채팅방을 선택하세요' %>
          </div>
        </div>

        <!-- 알림 버튼 -->
        <button id="muteBtn" data-muted="<%= room && room.isMuted ? 'true' : 'false' %>"
          style="border:none;background:none;cursor:pointer;font-size:20px;padding:4px 8px;"
          onclick="toggleMute()">
          <%= room && room.isMuted ? '🔇' : '🔔' %>
        </button>
      </div>

        <div class="chat-msgs" id="chatMessages" style="height:calc(100vh - 120px);overflow-y:auto;">
          <% if (!room) { %>
            
          <% } else { %>
            <div class="chat-date-divider">오늘</div>
            <% messages.forEach(msg => { %>
              <% if (msg.sender && String(msg.sender._id) === String(currentUserId)) { %>
                <div class="msg-row mine">
                  <div class="msg-content">
                    <div class="msg-bubble mine"><%= msg.content %></div>
                    <div class="msg-time"></div>
                  </div>
                </div>
              <% } else { %>
                <div class="msg-row">
                  <div class="msg-content">
                    <div class="msg-sender"><%= msg.sender ? msg.sender.name : '알 수 없음' %></div>
                    <div class="msg-bubble theirs"><%= msg.content %></div>
                    <div class="msg-time"></div>
                  </div>
                </div>
              <% } %>
            <% }) %>
          <% } %>
        </div>
              
        <div class="chat-input-area">
          <textarea class="chat-input" id="chatInput" rows="1" 
            placeholder="<%= room ? '메시지를 입력하세요...' : '채팅방이 선택되지 않았습니다' %>"
            <%= room ? '' : 'disabled' %>
            onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendChatMsg()}"></textarea>
          <button class="chat-send-btn" id="chatSendBtn" onclick="sendChatMsg()">↑</button>
        </div>
      </div>
    </div>
  </div>
</div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script type="module" src="/js/regularCrew/api.js"></script>

<!-- EJS 변수를 JS에서 사용하기 위해 전역 객체로 전달 -->
<script>
  window.CHAT_DATA = {
    user: <%- JSON.stringify(user) %>,
    roomId: '<%= room ? room._id.toString() : "" %>'
  };
</script>

<script src="/js/handlers/chatHandler.js"></script>

</body>
</html>
