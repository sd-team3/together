<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SPORTMATCH — 내 친구 목록</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main">
<%- include('../partials/head', { title: '👥 내 친구 목록', pageId: 'page-friends', active: '' }) %>

  <div class="friends-page-body">

    <!-- 탭 -->
    <div class="friends-tab-row">
      <button class="friend-tab on" data-tab="all">전체 <span class="friend-count" id="count-all"></span></button>
      <button class="friend-tab" data-tab="favorite">⭐ 즐겨찾기 <span class="friend-count" id="count-fav"></span></button>
      <button class="friend-tab" data-tab="pending">받은 신청 <span class="friend-count" id="count-pending"><%= pendingRequests.length %></span></button>
      <button class="friend-tab" data-tab="sent">보낸 신청 <span class="friend-count" id="count-sent"><%= sentRequests.length %></span></button>
    </div>

    <!-- 받은 친구 신청 목록 -->
    <div id="pending-list" class="friends-list-wrap hidden">
      <% if (pendingRequests.length === 0) { %>
        <div class="friend-empty">
          <div class="friend-empty-icon">📭</div>
          <div class="friend-empty-title">받은 친구 신청이 없어요</div>
        </div>
      <% } %>
      <% pendingRequests.forEach(req => { %>
        <%
          const u = req.sender;
          const profileImg = u.profileImage && u.profileImage !== 'default-profile-image.jpg'
            ? `/images/user-profile/${u.profileImage}`
            : '/images/user-profile/default-profile-image.jpg';
        %>
        <div class="friend-card" data-request-id="<%= req._id %>">
          <div class="friend-av">
            <img src="<%= profileImg %>" alt="profile">
          </div>
          <div class="friend-info">
            <div class="friend-name"><%= u.name %></div>
            <div class="friend-meta"><%= u.gender === 'male' ? '남성' : '여성' %> · <%= u.age %>세</div>
          </div>
          <div class="friend-actions">
            <button class="btn-accept" data-id="<%= req._id %>" data-sender-id="<%= u._id %>">수락</button>
            <button class="btn-reject" data-id="<%= req._id %>">거절</button>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- 보낸 친구 신청 목록 -->
    <div id="sent-list" class="friends-list-wrap hidden">
      <% if (sentRequests.length === 0) { %>
        <div class="friend-empty">
          <div class="friend-empty-icon">📤</div>
          <div class="friend-empty-title">보낸 친구 신청이 없어요</div>
        </div>
      <% } %>
      <% sentRequests.forEach(req => { %>
        <%
          const u = req.receiver;
          const profileImg = u.profileImage && u.profileImage !== 'default-profile-image.jpg'
            ? `/images/user-profile/${u.profileImage}`
            : '/images/user-profile/default-profile-image.jpg';
        %>
        <div class="friend-card" data-receiver-id="<%= u._id %>">
          <div class="friend-av">
            <img src="<%= profileImg %>" alt="profile">
          </div>
          <div class="friend-info">
            <div class="friend-name"><%= u.name %></div>
            <div class="friend-meta"><%= u.gender === 'male' ? '남성' : '여성' %> · <%= u.age %>세</div>
          </div>
          <div class="friend-actions">
            <button class="btn-cancel-sent" data-id="<%= req._id %>">취소</button>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- 검색 -->
    <div class="friend-search-wrap" id="search-bar">
      <input type="text" id="friend-search" class="friend-search-input" placeholder="이름으로 검색">
    </div>

    <!-- 친구 목록 -->
    <div id="friend-list" class="friends-list-wrap">
      <% if (friends.length === 0) { %>
        <div class="friend-empty">
          <div class="friend-empty-icon">👥</div>
          <div class="friend-empty-title">아직 친구가 없어요</div>
          <div class="friend-empty-sub">매칭에서 친구를 추가해보세요!</div>
        </div>
      <% } %>
      <% friends.forEach(f => { %>
        <%
          const u = f.user;
          const profileImg = u.profileImage && u.profileImage !== 'default-profile-image.jpg'
            ? `/images/user-profile/${u.profileImage}`
            : '/images/user-profile/default-profile-image.jpg';
        %>
        <div class="friend-card" data-id="<%= u._id %>" data-name="<%= u.name %>" data-fav="<%= f.isFavorite %>">
          <div class="friend-av">
            <img src="<%= profileImg %>" alt="profile">
          </div>
          <div class="friend-info">
            <div class="friend-name"><%= u.name %></div>
            <div class="friend-meta"><%= u.gender === 'male' ? '남성' : '여성' %> · <%= u.age %>세</div>
          </div>
          <div class="friend-actions">
            <button class="btn-fav <%= f.isFavorite ? 'active' : '' %>" data-id="<%= u._id %>" title="즐겨찾기">
              <%= f.isFavorite ? '⭐' : '☆' %>
            </button>
            <button class="btn-remove" data-id="<%= u._id %>" data-name="<%= u.name %>">삭제</button>
          </div>
        </div>
      <% }) %>
    </div>

  </div>
</div>

<!-- 삭제 확인 모달 -->
<div id="remove-modal" class="friend-modal-overlay">
  <div class="friend-modal-box">
    <div class="friend-modal-icon">🗑️</div>
    <div class="friend-modal-title" id="remove-modal-name"></div>
    <div class="friend-modal-desc">정말 친구를 삭제할까요?<br>이 작업은 되돌릴 수 없어요.</div>
    <div class="friend-modal-btns">
      <button id="remove-cancel-btn" class="friend-modal-cancel">취소</button>
      <button id="remove-confirm-btn" class="friend-modal-confirm">삭제</button>
    </div>
  </div>
</div>

<% if (user) { %>
<script src="/socket.io/socket.io.js"></script>
<script type="module">
  import { initFriendSocket } from '/js/handlers/friendHandler.js';
  import { initProfileModal } from '/js/components/profileModal.js';
  const userData = <%- JSON.stringify(user) %>;
  window.addEventListener('DOMContentLoaded', () => {
    const socket = io('/noti', { auth: { userId: userData._id } });
    initProfileModal(socket, userData._id);
    initFriendSocket(socket);
  });
</script>
<% } %>
</body>
</html>