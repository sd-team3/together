<link rel="stylesheet" href="/css/style.css"/>
<head>
  <script src="/js/handlers/headerHandler.js" defer></script>
  <script src="/js/handlers/notiHandler.js" defer></script>
</head>
<div class="page <%= typeof active !== 'undefined' ? active : '' %>" id="<%= pageId %>" style="display:flex;flex-direction:column;flex:1">
  
  <div class="topbar">
    
    <div><div class="topbar-title"><%= typeof title !== 'undefined' ? title : '타이틀 없음' %></div></div>
    
    <div class="topbar-actions">
      <span class="auth-state-btns">
        <button class="btn btn-ghost btn-sm" id="noti-btn">알림</button>
      <%
        if(user) {
          %><div id="login" style="display: none;">true</div>
            <button class="btn btn-outline btn-sm" id="mypage-btn">마이페이지</button>
            <button class="btn btn-outline btn-sm" id="logout-btn">로그아웃</button><%
        } else {
          %><div id="login" style="display: none;">false</div>
            <button class="btn btn-outline btn-sm" id="login-btn">로그인</button>
            <button class="btn btn-outline btn-sm" id="signup-btn">회원가입</button><%
        }
      %>
      </span>
      <div id="noti-popup">
        <%
          if(user) { 
            %><div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                  <strong>알림</strong>
                  <button class="btn btn-outline btn-sm" id="removeNoti">모두 삭제</button>
                </div>

                <div id="noti-list" style="display:flex;flex-direction:column;gap:8px;max-height:400px;overflow-y:auto">
                  <div id="noti-list">
                    <div class="noti-item" id="noti-${noti._id}">
                      <div class="noti-body">
                        <div class="noti-title"><strong>${noti.title}</strong></div>
                        <div class="noti-meta">${noti.content} · 오늘 20:00</div>
                        <div class="noti-time">${notiTime}</div>
                      </div>
                    </div>
                  </div>
                </div>

              </div><%
          } else {
            %><div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                  <strong>알림</strong>
                </div>
                <div style="border:1px solid var(--border);text-align:center;padding:48px 0;color:var(--text-3)">
                  로그인을 해주세요
                </div>
              </div><%
          } 
        %>
      </div>

      
