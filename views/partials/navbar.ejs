<style>
.user-av{
  width:40px;
  height:40px;
  border-radius:50%;
  overflow:hidden;
  display:flex;
  align-items:center;
  justify-content:center;
  background:var(--surface);
  border:1px solid var(--border);
}

.user-av img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}
  .toast-noti {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: #222;
    color: #fff;
    padding: 12px 18px;
    border-radius: 12px;
    font-size: 14px;
    z-index: 9999;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    animation: toast-in 0.3s ease;
    max-width: 300px;
  }
  .toast-noti .toast-title {
    font-weight: 600;
    margin-bottom: 4px;
    font-size: 13px;
    color: #aaa;
  }
  .toast-noti .toast-content {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  @keyframes toast-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<nav class="sidenav">
  <div class="sidenav-logo">
    <div>
      <div class="logo-mark">SPORTMATCH <span style="display:inline-block;vertical-align:middle;width:7px;height:7px;border-radius:50%;background:var(--accent);margin-left:3px;margin-bottom:2px"></span></div>
      <div class="logo-sub">생활 스포츠 매칭</div>
    </div>
  </div>
  <div class="sidenav-menu">
    <div class="nav-section-label">홈</div>
    <button class="nav-item" onclick="location.href='/'">
      <span class="nav-icon">🏠</span> 홈 피드
    </button>
    </button>

    <div class="nav-section-label">매칭</div>
    <button class="nav-item" onclick="location.href='/instant/list'">
      <span class="nav-icon">📍</span> 지도 매칭
    </button>
    <button class="nav-item" onclick="location.href='/regular/list'">
      <span class="nav-icon">🔁</span> 정기 모임
    </button>
    <button class="nav-item" onclick="location.href='/regular/my'">
      <span class="nav-icon">👥</span> 내가 참여한 모임
    </button>

    <div class="nav-section-label">커뮤니티</div>
    <button class="nav-item" onclick="location.href='/community'">
      <span class="nav-icon">💬</span> 커뮤니티
    </button>
    <button class="nav-item" onclick="location.href='/ranking'">
      <span class="nav-icon">🏆</span> 랭킹
    </button>
    <button class="nav-item" onclick="location.href='/friends'">
      <span class="nav-icon">👥</span> 내 친구 목록
    </button>

    <div class="nav-section-label">기타</div>
    <button class="nav-item" onclick="location.href='/notifications'">
      <span class="nav-icon">🔔</span> 알림
    </button>
    <button class="nav-item" onclick="location.href='/trade'">
      <span class="nav-icon">🛒</span> 중고 거래
    </button>
    <button class="nav-item" data-page="chat" onclick="location.href='/chatRoom/chatPage'">
      <span class="nav-icon">✉️</span> 채팅
    </button>
    <button class="nav-item" onclick="location.href='/user/setting'">
      <span class="nav-icon">⚙️</span> 설정
    </button>
  </div>
  <div class="sidenav-footer">

<% if (user) { %>

<%
const profileImg =
  user?.profileImage &&
  user.profileImage !== 'undefined' &&
  user.profileImage !== 'null' &&
  user.profileImage !== null
    ? `/images/user-profile/${user.profileImage}`
    : '/images/user-profile/default-profile-image.jpg';
%>

<!-- 로그인 상태 -->
<div class="user-chip" onclick="location.href='/user/profile'">

  <div class="user-av">
    <img src="<%= profileImg %>" alt="profile">
  </div>

  <div>
    <div class="user-name"><%= user.name %></div>

    <div class="user-level">
      📍 
      <%= 
        user.address && user.address.state && user.address.city
        ? `${user.address.state} ${user.address.city}`
        : '지역 미설정'
      %>
    </div>
  </div>

</div>

<% } else { %>

<!-- 비로그인 상태 -->
<a  href="/user/login" class="user-chip"
     onclick="openAuthModal('login')"
     style="background:var(--bg);border:1px solid var(--border); text-decoration: none;">

  <div class="user-av"
       style="background:linear-gradient(135deg,var(--border-strong),var(--text-3));font-size:18px">
    👤
  </div>

  <div>
    <div class="user-name" style="color:var(--text-2);font-size:12.5px">
      로그인이 필요합니다
    </div>
    <div class="user-level" style="color:var(--primary);font-weight:600">
      탭하여 로그인 →
    </div>
  </div>

</a>

<% } %>

</div>
</nav>


