<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
    <title>SPORTMATCH - 로그인</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700&family=Bebas+Neue&family=Oswald:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="/css/layouts/auth2-layout.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>
    <div class="auth-container">

        <div class="auth-visual">
            <div class="logo">
                SPORTMATCH <div class="logo-dot"></div>
            </div>

            <div class="visual-content">
                <h1 class="visual-title">Welcome<br>Back.</h1>
                <p class="visual-desc">
                    스포츠로 연결되는 새로운 즐거움,<br>
                    오늘도 최고의 매치를 찾아보세요.
                </p>
            </div>
            
            <div style="font-size: 13px; opacity: 0.6;">
                © 2024 SPORTMATCH. All rights reserved.
            </div>
        </div>

        <div class="auth-form-side">

            <div class="form-header">
                <h2 class="form-title">로그인</h2>
                <p class="form-subtitle">계정 정보를 입력하여 접속하세요.</p>

                <% if (errorMessage) { %>
                    <p style="color:red; font-size:13px; margin-top:10px;">
                        <%= errorMessage %>
                    </p>
                <% } %>
            </div>

            <!-- 자동완성 완전 차단 -->
            <form action="/user/login" method="post" autocomplete="off">

                <!-- 크롬 자동완성 방지 -->
                <input type="text" name="fake_user" style="display:none">
                <input type="password" name="fake_pass" style="display:none">

                <div class="form-group">
                    <label class="label">이메일 주소</label>
                    <input type="email"
                           name="email"
                           class="input"
                           placeholder="example@sportmatch.com"
                           autocomplete="off"
                           required />
                </div>

                <div class="form-group">
                    <label class="label">비밀번호</label>
                    <input type="password"
                           name="password"
                           class="input"
                           placeholder="••••••••"
                           autocomplete="new-password"
                           required />
                </div>

                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                    <label style="display:flex; align-items:center; gap:8px; font-size:13px;">
                        <!-- 필요하면 나중에 활성화 -->
                        <!-- <input type="checkbox" /> 로그인 상태 유지 -->
                    </label>
                </div>

                <button type="submit" class="btn btn-primary">로그인</button>
            </form>

            <!-- 소셜 로그인 -->
            <div class="social-login">

                <a href="/auth/google" class="social-btn google">
                    <i class="fa-brands fa-google"></i>
                    Google로 로그인
                </a>

                <a href="/auth/naver" class="social-btn naver">
                    <span class="naver-icon">N</span>
                    Naver로 로그인
                </a>

            </div>

            <div class="form-footer">
                계정이 없으신가요?
                <a href="/user/signup" class="link">회원가입 하기</a>
            </div>

        </div>

    </div>
</body>
</html>