<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
    <title>SPORTMATCH - 회원가입</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/css/layouts/auth1-layout.css">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700&family=Bebas+Neue&family=Oswald:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
    <div class="auth-container">
        <div class="auth-visual">
            <div class="logo">
                SPORTMATCH <div class="logo-dot"></div>
            </div>
            <div class="visual-content">
                <h1 class="visual-title">Join the<br>Match.</h1>
                <p class="visual-desc">스포츠로 연결되는 새로운 즐거움,<br>오늘도 최고의 매치를 찾아보세요.</p>
            </div>
            <div style="font-size: 12px; opacity: 0.6;">© 2026 SPORTMATCH. All rights reserved.</div>
        </div>

        <div class="auth-form-side">
            <div class="form-header">
                <div class="form-header-top">
                    <div>
                        <h2 class="form-title">회원가입</h2>
                        <p class="form-subtitle">SPORTMATCH의 멤버가 되어보세요.</p>
                    </div>
                    <!-- ✅ 프로필 이미지 -->
                    <div class="avatar-section">
                        <div class="avatar-preview-wrap">
                            <div class="avatar-preview">
                                <img id="avatar-img" src="/images/user-profile/default-profile-image.jpg" alt="프로필" />
                            </div>
                            <button type="button" class="avatar-remove-btn" onclick="resetAvatar()">✕</button>
                            <label class="avatar-edit-label" for="avatar-file">✏️</label>
                            <input type="file" id="avatar-file" name="uploadFile" accept="image/*" style="display:none">
                            <input type="hidden" id="removeImage" name="removeImage" value="false">
                        </div>
                    </div>
                </div>
            </div>
            <% const isSocialLogin = !!socialUser; %>
            <form action="/user/signup" method="post" id="signup">
                <div class="form-group">
                    <label class="label">이름 <span class="req">*</span></label>
                    <input type="text" class="input" name="name" id="name" value="<%= socialUser?.name || '' %>" required />
                    <div id="nameFeedBack"></div>
                </div>

                <div class="input-row">
                    <div class="form-group">
                        <label class="label">나이 <span class="req">*</span></label>
                        <input type="number" class="input" name="age" id="age" />
                        <div id="ageFeedBack"></div>
                    </div>
                    <div class="form-group">
                        <label class="label">전화번호 <span class="req">*</span></label>
                        <input type="tel" class="input" name="tel" id="tel" value="010-"  />
                        <div id="telFeedBack"></div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="label">성별 <span class="req">*</span></label>
                    <div class="gender-group">
                        <label class="gender-item">
                            <input type="radio" name="gender" value="male"  />
                            <span>남성</span>
                        </label>
                        <label class="gender-item">
                            <input type="radio" name="gender" value="female" />
                            <span>여성</span>
                        </label>
                    </div>
                    <div id="genderFeedBack"></div>
                </div>
                <div class="form-group">
                    <label class="label">이메일 <span class="req">*</span></label>
                    <div class="email-input-group">
                        <input type="email" class="input" name="email" id="emailInput" autocomplete="new-password" value="<%= socialUser?.email || '' %>" <%= socialUser ? 'readonly' : '' %> required />
                        <% if (!isSocialLogin) { %>
                        <button type="button" id="emailCheckBtn">중복확인</button>
                        <% } %>
                    </div>
                    <div id="emailFeedBack"></div>
                </div>

                <% if (!socialUser) { %>
                <div class="form-group">
                    <label class="label">비밀번호 <span class="req">*</span></label>

                    <div class="input-icon-wrap">
                        <input
                            type="password"
                            class="input"
                            name="password"
                            id="pw"
                            autocomplete="new-password"
                            placeholder="영문, 숫자, 특수문자 조합 8자 이상"
                            
                        />
                        <button type="button" class="input-eye" tabindex="-1">👁</button>
                    </div>

                    <div class="pw-strength">
                        <div class="pw-bars">
                            <div class="pw-bar" id="bar1"></div>
                            <div class="pw-bar" id="bar2"></div>
                            <div class="pw-bar" id="bar3"></div>
                            <div class="pw-bar" id="bar4"></div>
                        </div>

                        <div class="pw-label" id="pw-label">
                            비밀번호를 입력하세요
                        </div>
                    </div>
                    <div id="pwFeedBack"></div>
                </div>

                <div class="form-group">
                    <label class="label">비밀번호 확인 <span class="req">*</span></label>

                    <div class="input-icon-wrap">
                        <input type="password" class="input" name="password2" id="pw2" placeholder="비밀번호 확인"  />
                        <button type="button" class="input-eye" tabindex="-1">👁</button>
                    </div>
                    <div id="pw2FeedBack"></div>
                </div>
                <% } %>

                <div class="form-group">
                    <label class="label">주소 <span class="req">*</span></label>
                    <div class="address-wrap">
                        <input type="text" class="input" name="zipcode" id="zipcode" placeholder="우편번호" readonly />
                        <button type="button" class="btn-search" id="addrSearchBtn">주소 검색</button>
                    </div>
                    <input type="text" class="input" name="address" id="address" placeholder="기본 주소" style="margin-bottom:8px" readonly  />
                    <input type="hidden" name="state" id="state" />
                    <input type="hidden" name="city" id="city" />
                    <input type="hidden" name="road" id="road" />
                    <input type="text" class="input" name="addressDetail" id="addressDetail" placeholder="상세 주소 입력(선택)" >
                    <div id="addrFeedBack"></div>
                </div>

                <div class="agree-section">
                    <label class="agree-all">
                        <input type="checkbox" id="agreeAll">
                        전체 동의합니다
                    </label>
                    <label class="agree-item">
                        <input type="checkbox" id="agree1" class="agree-check">
                        <span>[필수] 서비스 이용약관 동의</span>
                        <a href="#" onclick="return false">보기</a>
                    </label>
                    <label class="agree-item">
                        <input type="checkbox" id="agree2" class="agree-check">
                        <span>[필수] 개인정보 수집·이용 동의</span>
                        <a href="#" onclick="return false">보기</a>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary">회원가입 완료</button>

                <% if (socialUser) { %>
                    <a href="/user/signup/cancel-social" class="btn btn-secondary">
                        소셜 가입 취소
                    </a>
                <% } %>
            </form>

            <div class="form-footer">
                이미 계정이 있으신가요? <a href="/user/login" class="link">로그인 하기</a>
            </div>
        </div>
    </div>

    <div class="success-overlay" id="successOverlay">
        <div class="success-box">
            <div class="success-icon" style="font-size: 40px; margin-bottom: 10px;">🎉</div>
            <div class="success-title" style="font-size: 24px; font-weight: 700; margin-bottom: 5px;">가입 완료!</div>
            <div class="success-msg" style="margin-bottom: 25px;"><span id="success-name" style="font-weight:700"></span>님 환영합니다!</div>
            <button class="btn btn-primary" onclick="location.href='/'">매칭 찾으러 가기 →</button>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <script type="module">
import { addrSearch } from '/js/modules/addrSearch.js';

function togglePw(id, btn) {
    const inp = document.getElementById(id);
    if (!inp) return;

    inp.type = inp.type === 'password' ? 'text' : 'password';
    btn.textContent = inp.type === 'password' ? '👁' : '🙈';
}

function setFeedback(el, msg, type) {
    if (!el) return;
    el.textContent = msg;
    el.className = 'feedback-text ' + (type === 'success' ? 'success' : 'error');
}

function formatPhone(inp) {
    if (!inp) return;

    let v = inp.value.replace(/\D/g, '');
    if (!v.startsWith('010')) v = '010' + v.replace(/^010/, '');
    if (v.length >= 11) v = v.slice(0, 11);
    if (v.length >= 8) v = v.slice(0, 3) + '-' + v.slice(3, 7) + '-' + v.slice(7);
    else if (v.length >= 4) v = v.slice(0, 3) + '-' + v.slice(3);

    inp.value = v;
}

function checkPwStrength(pw) {
    const bars = [
        document.getElementById('bar1'),
        document.getElementById('bar2'),
        document.getElementById('bar3'),
        document.getElementById('bar4')
    ];

    const label = document.getElementById('pw-label');

    if (!label || bars.includes(null)) return;

    bars.forEach(b => b.className = 'pw-bar');

    if (!pw) {
        label.textContent = '비밀번호를 입력하세요';
        return;
    }

    const hasSpecial = /[!@#$%^&*(),.?":{}|<>]/.test(pw);
    const hasNum = /[0-9]/.test(pw);
    const hasUpper = /[A-Z]/.test(pw);

    const strength =
        pw.length >= 12 && hasSpecial && (hasNum || hasUpper) ? 4 :
        pw.length >= 10 && (hasSpecial || hasNum) ? 3 :
        pw.length >= 8 ? 2 : 1;

    const colors = ['weak', 'weak', 'medium', 'strong', 'strong'];

    for (let i = 0; i < strength; i++) {
        if (bars[i]) bars[i].classList.add(colors[strength]);
    }

    label.textContent =
        strength >= 4 ? '매우 강함' :
        strength === 3 ? '강함' :
        strength === 2 ? '보통' : '약함';
}

function toggleAll(cb) {
    document.querySelectorAll('.agree-check')
        .forEach(c => c.checked = cb.checked);
}

async function searchAddress() {
    try {
        const data = await addrSearch();

        document.getElementById('zipcode').value = data.zonecode;
        document.getElementById('address').value = data.roadAddress;
        document.getElementById('state').value = data.sido;
        document.getElementById('city').value = data.sigungu;
        document.getElementById('road').value = data.roadname;

        setFeedback(document.getElementById('addrFeedBack'), '', '');
        document.getElementById('addressDetail').focus();

        showToast('주소가 입력되었습니다. 상세 주소를 작성해주세요.');
    } catch (error) {
        showToast('주소 검색 중 오류가 발생했습니다.');
        console.log(error);
    }
}

function showToast(msg) {
    const t = document.getElementById('toast');
    if (!t) return;

    t.textContent = msg;
    t.classList.add('show');

    setTimeout(() => t.classList.remove('show'), 2000);
}
async function handleSignup(e) {
    e.preventDefault();

    const isSocial = <%- JSON.stringify(isSocialLogin) %>;

    const form = e.target;

    // =========================
    // email (서버: notEmpty + isEmail)
    // =========================
    const email = form.email.value.trim();
    if (!email) {
        showToast('이메일은 필수입니다.');
        return;
    }
    if (!/^\S+@\S+\.\S+$/.test(email)) {
        showToast('유효한 이메일을 입력하세요.');
        return;
    }

    // =========================
    // name (서버 동일)
    // =========================
    const name = form.name.value.trim();
    if (!/^[가-힣]{2,5}$/.test(name)) {
        showToast('이름은 2~5자 한글로 입력하세요.');
        return;
    }

    // =========================
    // age
    // =========================
    const age = Number(form.age.value);
    if (!age || age < 1 || age > 120) {
        showToast('올바른 나이를 입력하세요.');
        return;
    }

    // =========================
    // tel (서버 기준: 010-0000-0000)
    // =========================
    const tel = form.tel.value.trim();
    if (!/^010-\d{4}-\d{4}$/.test(tel)) {
        showToast('전화번호는 010-0000-0000 형식입니다.');
        return;
    }

    // =========================
    // gender
    // =========================
    const gender = form.gender.value;
    if (!['male', 'female'].includes(gender)) {
        showToast('성별을 선택해주세요.');
        return;
    }

    // =========================
    // 일반회원만 password 검사
    // =========================
    if (!isSocial) {
        const pw = form.password.value;
        const pw2 = form.password2.value;

        const pwRegex =
            /^(?=.*[a-zA-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$/;

        if (!pwRegex.test(pw)) {
            showToast('비밀번호는 영문, 숫자, 특수문자 포함 8자 이상입니다.');
            return;
        }

        if (pw !== pw2) {
            showToast('비밀번호가 일치하지 않습니다.');
            return;
        }
    }

    // =========================
    // 주소
    // =========================
    if (!form.zipcode.value) {
        showToast('주소를 입력해주세요.');
        return;
    }

    // =========================
    // 약관
    // =========================
    if (!agree1.checked || !agree2.checked) {
        showToast('약관에 동의해주세요.');
        return;
    }

    // =========================
    // 서버 전송 (그대로 유지)
    // =========================
    try {
        const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form)
        });

        if (!response.ok) {
            const msg = await response.text();
            console.error(msg);
            showToast('회원가입 실패');
            return;
        }

        document.getElementById('success-name').textContent = name;
        document.getElementById('successOverlay').classList.add('show');

    } catch (err) {
        console.error(err);
        showToast('서버 연결 실패');
    }
}

/* =========================
   EMAIL
========================= */
const emailInput = document.getElementById('emailInput');
const emailCheckBtn = document.getElementById('emailCheckBtn');
const emailFeedBack = document.getElementById('emailFeedBack');

let isChecked = false;
let isDuplicate = false;

/* =========================
   PASSWORD (핵심 수정 부분)
========================= */
const pwInput = document.getElementById('pw');
const pw2Input = document.getElementById('pw2');
const pwFeedBack = document.getElementById('pwFeedBack');
const pw2FeedBack = document.getElementById('pw2FeedBack');

/* ====== PW 이벤트 (안전하게만 실행) ====== */
if (pwInput) {
    pwInput.addEventListener('input', function () {
        checkPwStrength(this.value);
        this.classList.remove('input-error', 'input-success');
        setFeedback(pwFeedBack, '', '');
    });
}

if (pw2Input) {
    pw2Input.addEventListener('input', function () {
        const pw = pwInput ? pwInput.value : '';

        if (!this.value) {
            this.classList.remove('input-error', 'input-success');
            setFeedback(pw2FeedBack, '', '');
            return;
        }

        if (this.value === pw) {
            this.classList.add('input-success');
            this.classList.remove('input-error');
            setFeedback(pw2FeedBack, '비밀번호가 일치합니다', 'success');
        } else {
            this.classList.add('input-error');
            this.classList.remove('input-success');
            setFeedback(pw2FeedBack, '비밀번호가 일치하지 않습니다', 'error');
        }
    });
}

/* =========================
   TEL
========================= */
const telInput = document.getElementById('tel');
const telFeedBack = document.getElementById('telFeedBack');

if (telInput) {
    telInput.addEventListener('input', function () {
        if (!this.value.startsWith('010')) this.value = '010-';

        formatPhone(this);

        const telVal = this.value.replace(/\D/g, '');

        if (telVal.length === 11) {
            this.classList.add('input-success');
            this.classList.remove('input-error');
            setFeedback(telFeedBack, '', '');
        } else {
            this.classList.add('input-error');
            this.classList.remove('input-success');
            setFeedback(telFeedBack, '전화번호를 올바르게 입력해주세요', 'error');
        }
    });
}

/* =========================
   EVENTS (나머지)
========================= */
document.getElementById('addrSearchBtn')?.addEventListener('click', searchAddress);
document.getElementById('agreeAll')?.addEventListener('change', function () { toggleAll(this); });

document.querySelectorAll('.input-eye').forEach(btn => {
    btn.addEventListener('click', function () {
        const input = this.closest('.input-icon-wrap')?.querySelector('input');
        if (input) togglePw(input.id, this);
    });
});

document.getElementById('signup')?.addEventListener('submit', handleSignup);

</script>
</body>
</html>