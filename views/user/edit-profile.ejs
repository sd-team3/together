<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 프로필 수정</title>

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>

<body>

<%- include('../partials/navbar') %>

<div class="main">

<%- include('../partials/head', {
  title: '✏️ 프로필 수정',
  pageId: 'page-edit-profile',
  active: ''
}) %>

<div class="page-body" style="overflow-y:auto">
<div class="edit-wrap">

<form id="editForm" action="/user/edit-profile" method="POST" enctype="multipart/form-data">

<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
  <div class="error-box" style="color:red; margin-bottom:10px;">
    <%= errorMessage %>
  </div>
<% } %>

<!-- ① 프로필 이미지 -->
<div>
  <div class="edit-section-title">프로필 이미지</div>

  <div class="avatar-section">
    <div class="avatar-preview-wrap">
    <%
const img =
  user?.profileImage &&
  user.profileImage !== 'undefined' &&
  user.profileImage !== 'null' &&
  user.profileImage !== null
    ? `/images/user-profile/${user.profileImage}`
    : '/images/user-profile/default-profile-image.jpg';
%>

<div class="avatar-preview">
  <img id="avatar-img" src="<%= img %>" alt="">
</div>
    <button type="button" class="avatar-remove-btn" onclick="resetAvatar()">✕</button>
    <label class="avatar-edit-label" for="avatar-file">✏️</label>
    <input type="file" id="avatar-file" name="uploadFile" accept="image/*" style="display:none">
    <input type="hidden" id="removeImage" name="removeImage" value="false">
    </div>
  </div>
</div>

<!-- ② 기본 정보 -->
<div>
  <div class="edit-section-title">기본 정보</div>

  <div class="edit-card">
    <div class="form-grid-2">

      <div class="edit-field field-full">
        <label class="edit-label">이메일 🔒</label>
        <input type="email" class="edit-input readonly-field"
               value="<%= user.email %>" readonly>
      </div>

      <div class="edit-field">
        <label class="edit-label">이름</label>
        <input type="text" name="name" class="edit-input"
               value="<%= user.name %>">
      </div>

      <div class="edit-field">
        <label class="edit-label">나이</label>
        <input type="number" name="age" class="edit-input"
               value="<%= user.age %>">
      </div>

      <div class="edit-field">
    <label class="edit-label">성별</label>

    <input 
        type="text" 
        class="edit-input readonly-field"
        value="<%= user.gender === 'male' ? '남성' : user.gender === 'female' ? '여성' : '' %>"
        readonly
    >

    
    <input type="hidden" name="gender" value="<%= user.gender %>">
</div>

      <div class="edit-field field-full">
  <label class="edit-label">전화번호</label>

  <div style="display:flex; gap:8px;">
   <input type="text" name="tel1" class="edit-input" style="width:80px;"
       maxlength="3"
       value="<%= user.tel ? user.tel.split('-')[0] : '' %>">

<input type="text" name="tel2" class="edit-input" style="width:100px;"
       maxlength="4"
       value="<%= user.tel ? user.tel.split('-')[1] : '' %>">

<input type="text" name="tel3" class="edit-input" style="width:100px;"
       maxlength="4"
       value="<%= user.tel ? user.tel.split('-')[2] : '' %>">
  </div>
</div>

    </div>
  </div>
</div>

<!-- ③ 주소 -->
<div>
  <div class="edit-section-title">주소</div>

  <div class="edit-card">

    <!-- 우편번호 -->
    <div class="edit-field field-full">
      <label class="edit-label">우편번호</label>

      <div style="display:flex; gap:8px;">
        <input type="text" id="zipcode" name="zonecode" value="<%= user.address?.zipcode || '' %>" class="edit-input" readonly>

        <button type="button" id="addr-btn">🔍 검색</button>
      </div>
    </div>

    <!-- 기본 주소 -->
    <div class="edit-field field-full">
      <label class="edit-label">기본 주소</label>
      <input type="text" id="road" name="road" class="edit-input"
        value="<%= user.address?.road || '' %>"
        readonly>
    </div>

    <!-- 상세 주소 -->
    <div class="edit-field field-full">
      <label class="edit-label">상세 주소</label>
      <input type="text" name="detail" class="edit-input"
        value="<%= user.address?.detail || '' %>">
    </div>


  </div>
</div>

<!-- ④ 비밀번호 -->
<div>
  <div class="edit-section-title">비밀번호 변경(선택)</div>

  <div class="edit-card">

    <div class="edit-field field-full">
      <label class="edit-label">현재 비밀번호</label>
      <input type="password" name="currentPassword" class="edit-input">
    </div>
    <div id="pw-error" class="error-box" style="display:none; color:red; margin-top:8px;">
    비밀번호가 같습니다
</div>
    <div class="edit-field">
      <label class="edit-label">새 비밀번호</label>
      <input type="password" name="newPassword" class="edit-input">
    </div>

  </div>
</div>

<!-- ⑤ 저장 -->
<div class="edit-actions">
  <button type="submit" class="edit-save-btn">💾 저장</button>
</div>

</form>

<!-- 모달 -->
<div id="modal" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div id="modal-msg"></div>
    <button onclick="closeModal()">확인</button>
  </div>
</div>

</div>
</div>
</div>

<script>
let redirectAfterClose = false;

//이미지
const fileInput = document.getElementById("avatar-file");
const avatarImg = document.getElementById("avatar-img");
const defaultImg = "/images/user-profile/default-profile-image.jpg";

let imageChanged = false;

function resetAvatar() {
    const avatarImg = document.getElementById("avatar-img");
    const fileInput = document.getElementById("avatar-file");
    const removeImage = document.getElementById("removeImage");

    avatarImg.src = defaultImg;
    fileInput.value = "";

    // 핵심: 서버에 삭제 요청
    removeImage.value = "true";

    imageChanged = true;
}



fileInput.addEventListener("change", (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();

    reader.onload = (event) => {
        avatarImg.src = event.target.result;
    };

    reader.readAsDataURL(file);

    document.getElementById("removeImage").value = "false";
    imageChanged = true;
});

// 기존 값 저장
const norm = (v) => (v ?? "").toString().trim();

const originalUser = {
    name: norm("<%= user.name %>"),
    age: norm("<%= user.age %>"),
    tel: norm("<%= user.tel %>"),
    road: norm("<%= user.address?.road %>"),
    detail: norm("<%= user.address?.detail %>")
};

// 모달 열기
function openModal(msg, shouldRedirect = false) {
    document.getElementById("modal-msg").innerText = msg;
    document.getElementById("modal").style.display = "flex";
    redirectAfterClose = shouldRedirect;
}

// 모달 닫기
function closeModal() {
    document.getElementById("modal").style.display = "none";

    if (redirectAfterClose) {
        window.location.href = "/user/profile";
    }
}

// 변경된 항목 찾기
function getChangedFields(form) {
    const changes = [];

    if (imageChanged) {
    changes.push("프로필 이미지");
}
    

    if (norm(form.name.value) !== originalUser.name) {
        changes.push("이름");
    }

    if (norm(form.age.value) !== originalUser.age) {
        changes.push("나이");
    }

    const tel =
        norm(form.tel1.value) +
        norm(form.tel2.value) +
        norm(form.tel3.value);

    const currentTel = norm(tel);
    const originalTel = originalUser.tel;

    if (currentTel && currentTel !== originalTel) {
        changes.push("전화번호");
    }

    if (norm(form.road.value) !== originalUser.road) {
        changes.push("주소");
    }

    if (norm(form.detail.value) !== originalUser.detail) {
        changes.push("상세주소");
    }

    if (norm(form.newPassword.value) !== "") {
        changes.push("비밀번호");
    }

    return changes;
}

// 폼 제출
document.getElementById("editForm").addEventListener("submit", async (e) => {
  
    e.preventDefault();

    const form = e.target;

    const currentPassword = form.currentPassword.value.trim();
    const newPassword = form.newPassword.value.trim();

// 비밀번호 유효성 검사
    let errors = [];
    //DOM 가져오기
const pwErrorBox = document.getElementById("pw-error");

// 기본 숨김
pwErrorBox.style.display = "none";

// 비밀번호
if (currentPassword && !newPassword) {
    errors.push("새 비밀번호를 입력하세요");
}

if (!currentPassword && newPassword) {
    errors.push("현재 비밀번호를 입력하세요");
}

// 같은 비밀번호 체크
if (currentPassword && newPassword && currentPassword === newPassword) {
    pwErrorBox.style.display = "block";
    errors.push("비밀번호 동일");
}

if (newPassword) {
    const passwordRegex = /^(?=.*[A-Za-z])(?=.*\d)(?=.*[!@#$%^&*()_+{}\[\]:;<>,.?~\-]).{8,}$/;

    if (!passwordRegex.test(newPassword)) {
        errors.push("비밀번호는 영문, 숫자, 특수문자를 포함한 8자 이상이어야 합니다");
    }
}

    




// 이름
const name = form.name.value.trim();

// 이름 비어있으면
if (name === "") {
    errors.push("이름을 입력하세요");
}

// 길이 체크
if (name.length > 9) {
    errors.push("이름은 9자 이하로 입력하세요");
}

// 나이
const age = form.age.value.trim();
if (age !== "") {
    const ageNum = Number(age);

    if (isNaN(ageNum) || ageNum < 1 || ageNum > 99) {
        errors.push("나이는 1~99세까지만 입력 가능합니다");
    }
}

// 전화번호 
const tel1 = form.tel1.value.trim();
const tel2 = form.tel2.value.trim();
const tel3 = form.tel3.value.trim();

let tel = "";

// 하나라도 입력했으면 검사
if (tel1 || tel2 || tel3) {

    // 010 고정
    if (tel1 !== "010") {
        errors.push("전화번호는 010으로 시작해야 합니다");
    }

    // 중간자리 (4자리)
    if (!/^\d{4}$/.test(tel2)) {
        errors.push("전화번호 가운데 자리는 4자리 숫자입니다");
    }

    // 마지막 자리 (4자리)
    if (!/^\d{4}$/.test(tel3)) {
        errors.push("전화번호 마지막 자리는 4자리 숫자입니다");
    }

    // 검증 통과 시만 조합
    tel = tel1 + tel2 + tel3;
}
//주소
const road = form.road.value.trim();
if (road === "") {
    errors.push("주소를 입력하세요");
}

//상세주소
const detail = form.detail.value.trim();

if (detail === "") {
    errors.push("상세주소를 입력하세요");
}

// 에러 한 번에 출력
if (errors.length > 0) {
    openModal(errors.join("\n"));
    return;
}

    const changes = getChangedFields(form);

    const formData = new FormData(form);
    if (tel !== "") {
    formData.set("tel", tel);
}


    try {
        const res = await fetch("/user/edit-profile", {
            method: "POST",
            body: formData
        });

        const data = await res.json();

        if (!res.ok) {
            openModal(data.message || "에러 발생");
            return;
        }

        //변경된 항목 표시
        if (changes.length === 0) {
            openModal("변경된 내용이 없습니다");
        } else {
            openModal(`변경 완료!\n(${changes.join(", ")} 수정됨)`, true);
        }

    } catch (err) {
        openModal("서버 오류 발생");
    }
});
</script>
<script type="module">
import { addrSearch } from "/js/modules/addrSearch.js";
import kakaoMap from "/js/modules/mapLoader.js";

const btn = document.getElementById("addr-btn");

btn?.addEventListener("click", async () => {
    try {
        console.log("클릭됨");

        const data = await addrSearch();
        const road = data.roadAddress;
        const zipcode = data.zipcode;

        document.getElementById("zipcode").value = zipcode;
        document.getElementById("road").value = road;
        document.querySelector("input[name='detail']").focus();

        await kakaoMap.loadMapByADDR(road);

    } catch (err) {
        console.error(err);
        alert("주소 검색 실패");
    }
});
</script>

</body>
</html>