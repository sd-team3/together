<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>회원정보 수정</title>
</head>
<body>

<h2>회원정보 수정</h2>

<!-- 🔴 에러 메시지 -->
<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
    <p style="color:red;"><%= errorMessage %></p>
<% } %>

<!-- 🔴 validation 에러 -->
<% if (typeof errors !== 'undefined' && errors) { %>
    <% Object.values(errors).forEach(err => { %>
        <p style="color:red;"><%= err %></p>
    <% }) %>
<% } %>

<form action="/user/edit-profile" method="POST" enctype="multipart/form-data">

    <!-- 이름 -->
    <div>
        <label>이름</label><br>
        <input type="text" name="name"
            value="<%= 
                (typeof user !== 'undefined' && user && user.name ? user.name : '') 
            %>">
    </div>
    <div>
    <label>나이</label><br>
    <input type="number" name="age"
        value="<%= (user && user.age) ? user.age : '' %>">
</div>

<div>
    <label>전화번호</label><br>
    <input type="text" name="tel"
        value="<%= (user && user.tel) ? user.tel : '' %>">
</div>

    <!-- 주소 (🔥 분리해서 보내야 함) -->
    <div>
        <label>시/도</label><br>
        <input type="text" name="state"
            value="<%= (user && user.address && user.address.state) ? user.address.state : '' %>">
    </div>

    <div>
        <label>시/군/구</label><br>
        <input type="text" name="city"
            value="<%= (user && user.address && user.address.city) ? user.address.city : '' %>">
    </div>

    <div>
        <label>도로명</label><br>
        <input type="text" name="road"
            value="<%= (user && user.address && user.address.road) ? user.address.road : '' %>">
    </div>

    <!-- 프로필 이미지 -->
    <div>
        <label>프로필 이미지</label><br>
        <input type="file" name="uploadFile">
    </div>

    <hr>

    <h3>비밀번호 변경 (선택)</h3>

    <div>
        <label>현재 비밀번호</label><br>
        <input type="password" name="currentPassword">
    </div>

    <div>
        <label>새 비밀번호</label><br>
        <input type="password" name="newPassword">
    </div>

    <br>
    <button type="submit">수정하기</button>

</form>

<br>
<a href="/user/profile">← 마이페이지로 돌아가기</a>

</body>
</html>