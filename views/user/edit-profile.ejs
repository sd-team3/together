<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 프로필 수정</title>

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
</head>

<body>

<%- include('../partials/navbar') %>

<div class="main">

<%- include('../partials/head', {
  title: '✏️ 프로필 수정',
  pageId: 'page-edit-profile',
  active: ''
}) %>

<div class="page-body" style="overflow-y:auto">
<div class="edit-wrap">

<form id="editForm" action="/user/edit-profile" method="POST" enctype="multipart/form-data" autocomplete="off">

<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
  <div class="error-box" style="color:red; margin-bottom:10px;">
    <%= errorMessage %>
  </div>
<% } %>

<!-- ① 프로필 이미지 -->
<div>
  <div class="edit-section-title">프로필 이미지</div>

  <div class="avatar-section">
    <div class="avatar-preview-wrap">
    <%
      const img =
        user?.profileImage &&
        user.profileImage !== 'undefined' &&
        user.profileImage !== 'null' &&
        user.profileImage !== null
          ? `/images/user-profile/${user.profileImage}`
          : '/images/user-profile/default-profile-image.jpg';
    %>
      <div class="avatar-preview">
        <img id="avatar-img" src="<%= img %>" alt="">
      </div>
      <button type="button" class="avatar-remove-btn" id="avatar-remove-btn">✕</button>
      <label class="avatar-edit-label" for="avatar-file">✏️</label>
      <input type="file" id="avatar-file" name="uploadFile" accept="image/*" style="display:none">
      <input type="hidden" id="removeImage" name="removeImage" value="false">
    </div>
  </div>
</div>

<!-- ② 기본 정보 -->
<div>
  <div class="edit-section-title">기본 정보</div>

  <div class="edit-card">
    <div class="form-grid-2">

      <div class="edit-field field-full">
        <label class="edit-label">이메일 🔒</label>
        <input type="email" class="edit-input readonly-field"
               value="<%= user.email %>" readonly>
      </div>

      <div class="edit-field">
        <label class="edit-label">이름</label>
        <input type="text" name="name" id="name" class="edit-input"
               value="<%= user.name %>">
        <div id="nameFeedBack"></div>
      </div>

      <div class="edit-field">
        <label class="edit-label">나이</label>
        <input type="number" name="age" id="age" class="edit-input"
               value="<%= user.age %>">
        <div id="ageFeedBack"></div>
      </div>

      <div class="edit-field">
        <label class="edit-label">성별</label>
        <input
          type="text"
          class="edit-input readonly-field"
          value="<%= user.gender === 'male' ? '남성' : user.gender === 'female' ? '여성' : '' %>"
          readonly
        >
        <input type="hidden" name="gender" value="<%= user.gender %>">
      </div>

      <div class="edit-field field-full">
        <label class="edit-label">전화번호</label>
        <input
          type="tel"
          name="tel"
          id="tel"
          class="edit-input"
          maxlength="13"
          value="<%= user.tel || '' %>"
          placeholder="010-0000-0000"
        />
        <div id="telFeedBack"></div>
      </div>

    </div>
  </div>
</div>

<!-- ③ 주소 -->
<div>
  <div class="edit-section-title">주소</div>

  <div class="edit-card">

    <div class="edit-field field-full">
      <label class="edit-label">우편번호</label>
      <div style="display:flex; gap:8px;">
        <input type="text" id="zipcode" name="zonecode" value="<%= user.address?.zipcode || '' %>" class="edit-input" readonly>
        <button type="button" id="addr-btn">🔍 검색</button>
      </div>
      <div id="addrFeedBack"></div>
    </div>

    <div class="edit-field field-full">
    <label class="edit-label">기본 주소</label>
    <input type="text" id="road" name="road" class="edit-input"
      value="<%= (user.address?.state || '') + ' ' + (user.address?.city || '') + ' ' + (user.address?.road || '') %>"
      readonly>
    
    <input type="hidden" id="state" name="state" value="<%= user.address?.state || '' %>">
    <input type="hidden" id="city"  name="city"  value="<%= user.address?.city  || '' %>">
  </div>

    <div class="edit-field field-full">
      <label class="edit-label">상세 주소</label>
      <input type="text" name="detail" id="detail" class="edit-input"
        value="<%= user.address?.detail || '' %>" readonly>
    </div>

  </div>
</div>

<% if (user.provider === 'local') { %>

<!-- ④ 비밀번호 -->
<div>
  <div class="edit-section-title">비밀번호 변경(선택)</div>

  <div class="edit-card">

    <div class="edit-field field-full">
      <label class="edit-label">현재 비밀번호</label>
      <div class="input-icon-wrap">
        <input type="password" name="currentPassword" id="currentPassword" class="edit-input" readonly>
        <button type="button" class="input-eye" tabindex="-1">👁</button>
      </div>
      <div id="currentPwFeedBack"></div>
    </div>

    <div class="edit-field field-full">
      <label class="edit-label">새 비밀번호</label>
      <div class="input-icon-wrap">
        <input type="password" name="newPassword" id="newPassword" class="edit-input" readonly>
        <button type="button" class="input-eye" tabindex="-1">👁</button>
      </div>
      <div class="pw-strength">
        <div class="pw-bars">
          <div class="pw-bar" id="bar1"></div>
          <div class="pw-bar" id="bar2"></div>
          <div class="pw-bar" id="bar3"></div>
          <div class="pw-bar" id="bar4"></div>
        </div>
        
      </div>
      <div id="newPwFeedBack"></div>
    </div>

  </div>
</div>

<% } %>

<!-- ⑤ 저장 -->
<div class="edit-actions">
  <button type="submit" class="edit-save-btn">💾 저장</button>
</div>

</form>

<!-- 모달: 저장 완료 알림 전용 -->
<div id="modal" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div id="modal-msg" style="white-space:pre-line;"></div>
    <button id="modal-confirm-btn">확인</button>
  </div>
</div>

        </div>
    </div>
</div>

<script>
  window.EDIT_PROFILE_DATA = {
    name  : '<%= user.name %>',
    age   : '<%= user.age %>',
    tel   : '<%= user.tel %>',
    road  : '<%= user.address?.road %>',
    detail: '<%= user.address?.detail %>'
  };
</script>

<script type="module" src="/js/handlers/edit-Profile.js"></script>

</body>
</html>
