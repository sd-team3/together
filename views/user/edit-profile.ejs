<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>회원정보 수정</title>
</head>
<body>

<h2>회원정보 수정</h2>

<!-- 🔴 에러 메시지 -->
<% if (errorMessage) { %>
    <p style="color:red;"><%= errorMessage %></p>
<% } %>

<% if (errors) { %>
    <% Object.values(errors).forEach(err => { %>
        <p style="color:red;"><%= err %></p>
    <% }) %>
<% } %>

<form action="/user/edit-profile" method="POST" enctype="multipart/form-data">

    <!-- 이름 -->
    <div>
        <label>이름</label><br>
        <input type="text" name="name"
            value="<%= user?.name || oldInput?.name || '' %>">
    </div>

    <!-- 주소 -->
    <div>
        <label>주소</label><br>
        <input type="text" name="address"
            value="<%= user?.address || oldInput?.address || '' %>">
    </div>

    <!-- 프로필 이미지 -->
    <div>
        <label>프로필 이미지</label><br>
        <input type="file" name="uploadFile">
    </div>

    <hr>

    <h3>비밀번호 변경 (선택)</h3>

    <!-- 현재 비밀번호 -->
    <div>
        <label>현재 비밀번호</label><br>
        <input type="password" name="currentPassword">
    </div>

    <!-- 새 비밀번호 -->
    <div>
        <label>새 비밀번호</label><br>
        <input type="password" name="newPassword">
    </div>

    <br>
    <button type="submit">수정하기</button>

</form>

<br>
<a href="/user/profile">← 마이페이지로 돌아가기</a>

</body>
</html>