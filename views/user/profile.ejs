<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
<%- include('../partials/navbar') %>
<!-- ═══════ MAIN ═══════ -->

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<!-- ──────── MY PAGE ──────── -->
<%- include('../partials/head', { title: '👤 마이페이지', pageId: 'page-mypage', active: '' }) %>

  <div class="page-body">
    <div class="mypage-layout">
      <!-- Profile Card -->
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="profile-card">
          <div class="profile-banner"></div>
          <div class="profile-av-wrap">
            <% if(user.provider === 'google' || user.provider === 'naver') { %>
                <img src="<%= user.profileImage %>" class="profile-big-av">
            <% } else { %> 
                <img src="/images/user-profile/<%= user.profileImage %>" class="profile-big-av">
            <% } %>
          </div>
          <div class="profile-info">
            <div class="profile-name"><%= user.name %></div>
            <div class="profile-handle"><%= user.email %></div>
            <div class="profile-badges">
              <div class="profile-badge">🎂 <%= user.age %> 세</div>
              <div class="profile-badge">👤 <%= user.gender === 'male' ? '남성' : '여성' %></div> 
              <div class="profile-badge">🏠 <%= user.address.state %> <%= user.address.city %></div>
              <div class="profile-badge">⚡ <%= user.sports %>축구</div>
            </div>
          </div>
          <div class="profile-divider"></div>
          <div class="profile-stat-row">
            <div class="ps-item"><span class="ps-val"><%= user.matchCount %>10</span><span class="ps-label">참여한 경기</span></div>
            <div class="ps-item"><span class="ps-val">3</span><span class="ps-label">참여중인 모임</span></div>
            <div class="ps-item"><span class="ps-val">12</span><span class="ps-label">매너 순위</span></div>
          </div>
          <div class="rank-info-box">
            <div style="font-size:12px;opacity:.6;letter-spacing:1px;margin-bottom:3px">매너점수</div>
            <div style="font-family:'DM Mono',monospace;font-size:36px;font-weight:700;letter-spacing:-2px;line-height:1"><%= user.mannerPoint %>10점</div>
          </div>
        </div>
        <div class="card" style="overflow:hidden">
          <div class="mypage-nav">
            <button class="mypage-nav-item"><span>📅</span> 모임 일정</button>
            <button class="mypage-nav-item"><span>⭐</span> 프로필 수정</button>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="mypage-main">
        <!-- Upcoming Schedule -->
        <div class="mypage-card">
          <div class="mypage-card-header"><div class="mypage-card-title">📅 정기 모임</div>
          <% if(regCrew.length > 4) { %>
          <button type="button" id="seeAllBtn" class="mypage-card-action">전체보기</div>
          <button type="button" id="see4Btn" class="mypage-card-action" style="display: none">접기</div>
          <% } %>
        </div>
          <div class="mypage-card-body">
            <% if(regCrew.length === 0 || !regCrew) { %>
                <div class="no-data-container">
                  <div class="no-data-item">🔍</div>
                  <p class="no-data-item" style="font-weight: 700;">아직 가입한 모임이 없어요</p>
                  <p class="no-data-item">나와 취향이 맞는 정기 모임을 찾아보세요!</p>
                  <!-- 정기 크루 경로 확인 전까지 보류 -->
                  <a href="" class="no-data-button">모임 둘러보기</a> 
                </div>
            <% } else { %>
            <% regCrew.forEach((crew, index) => { %>
              <div class="schedule-item <%= index > 4 ? 'schedule-hidden' : '' %>">
                  <% if(crew.day[0] === '미정') { %>
                  <div class="sched-time">
                    <%= crew.day[0] %> --:-- </div>
                  <% } else {%>
                  <div class="sched-time">
                    <%= crew.day[0] %> 12:30</div>
                  <% } %>
                  <div class="sched-dot" style="background:var(--primary)"></div>

                  <div class="sched-info">
                      <div class="sched-title-row">
                          <span class="sched-title"><%= crew.title %></span>
                          <span class="sched-owner">👑 <%= crew.host.name %></span>
                      </div>
                      <div class="sched-sub">📌 <%= crew.address.state %> <%= crew.address.city %> </div>
                  </div>
                  <div class="sched-manage">
                      <div class="manage-top">
                          <% if (crew.day[0] === '미정') {%> 
                            <span class="sched-days" style="color: red">미정</span>
                          <% } else { %>
                            <span class="sched-days">매주 <%= crew.day.join(', ');%></span>
                          <% } %>
                          <span class="sched-count">👤 <%= crew.member.memberList.length %>/<%= crew.member.capacity %></span>
                      </div>
                      <div class="manage-bottom">
                          <span class="sched-joined">참여 중</span>
                          <button class="btn-leave">탈퇴</button>
                      </div>
                  </div>
              </div>
              <% });}%>
          </div>
        </div>

        <!-- ----------------------------------------------------------------------------- -->
        <div class="mypage-card">
          <div class="mypage-card-header"><div class="mypage-card-title">🕒 실시간 모임</div><div class="mypage-card-action">전체보기</div></div>
          <div class="mypage-card-body">

            <div class="schedule-item">
                <div class="sched-time">오늘 20:00</div>
                <div class="sched-dot" style="background:var(--red)"></div>
                <div class="sched-info">
                    <div class="sched-title-row">
                        <span class="sched-title">성수 5:5 풋살 매칭</span>
                        <span class="sched-owner">👑 감비아</span>
                    </div>
                    <div class="sched-sub">📌 성수 실내풋살장</div>
                </div>

                <div class="sched-manage">
                    <div class="manage-top">
                        <span class="sched-days">D-10</span>
                        <span class="sched-count">👤 5/10</span>
                    </div>
                    <div class="manage-action">
                        <button class="btn-leave">탈퇴</button>
                    </div>
                </div>
            </div>

          </div>
        </div>
        </div>
      </div>
    </div>
  </div>
</div>


</div><!-- /main -->

<div class="map-popup-overlay" id="map-popup" onclick="if(event.target===this)closeMapPopup()">
  <div class="map-popup">
    <button class="popup-close" onclick="closeMapPopup()">✕</button>
    <div class="popup-sport" id="pp-sport">⚽</div>
    <div class="popup-title" id="pp-title">강남 풋살파크 5:5 매칭</div>
    <div class="popup-meta">
      <span id="pp-loc">📍 강남구 역삼동</span>
      <span id="pp-time">⏰ 오늘 19:30</span>
      <span id="pp-members">👥 6/10명</span>
      <span>💰 <span id="pp-price">10,000원</span></span>
    </div>
    <div class="flex gap-6 mb-16">
      <span class="tag tag-outline" id="pp-level">중급</span>
      <span class="tag tag-green">실내</span>
    </div>
    <div class="popup-host">
      <div class="popup-host-av">K</div>
      <div><div class="popup-host-name">강남킬러 <span style="color:var(--text-3);font-weight:400">⭐ 4.9</span></div><div class="popup-host-sub">47경기 · 매너 우수</div></div>
    </div>
    <div class="popup-btns">
      <button class="btn btn-primary flex-1" onclick="closeMapPopup();showModal('🎉 참가 신청 완료!','매칭에 참가 신청이 완료되었습니다!<br>당일 30분 전 알림을 드립니다.',null)">참가 신청</button>
      <button class="btn btn-outline" onclick="closeMapPopup()">공유 🔗</button>
    </div>
  </div>
</div>

<script>
  const seeAllBtn = document.getElementById('seeAllBtn');
  const see4Btn = document.getElementById('see4Btn');

  seeAllBtn.addEventListener('click', () => {
    seeAllBtn.style.display = 'none';
    see4Btn.style.display = 'inline-block';

    const scheduleHidden = document.querySelectorAll('schedule-hidden');
    schedule-hidden.forEach(item => item.style.display = 'flex');
  });
  
  see4Btn.addEventListener('click', () => {
    see4Btn.style.display = 'none';
    seeAllBtn.style.display = 'inline-block';
    
    const scheduleHidden = document.querySelectorAll('schedule-hidden');
    schedule-hidden.forEach(item => item.style.display = 'none');
  });


</script>

</body>
</html>
