<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
<%- include('../partials/navbar') %>
<!-- ═══════ MAIN ═══════ -->

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<!-- ──────── MY PAGE ──────── -->
<%- include('../partials/head', { title: '👤 마이페이지', pageId: 'page-mypage', active: '', route: '/user/profile' }) %>

  <div class="page-body">
    <div class="mypage-layout">
      <!-- Profile Card -->
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="profile-card">
          <div class="profile-banner"></div>
          <div class="profile-av-wrap">
            <img src="<%= user.profileImage ? '/images/user-profile/' + user.profileImage : '/images/user-profile/default-profile-image.jpg'%>" class="profile-big-av">
          </div>
          <div class="profile-info">
            <div class="profile-name"><%= user.name %></div>
            <div class="profile-handle"><%= user.email %></div>
            <div class="profile-badges">
              <div class="profile-badge">🎂 <%= user.age %> 세</div>
              <div class="profile-badge">👤 <%= user.gender === 'male' ? '남성' : '여성' %></div> 
              <div class="profile-badge">🏠 <%= user.address.state %> <%= user.address.city %></div>
              <div class="profile-badge">👥 <%= user.crews.length %> 개 정기크루</div>
              <div class="profile-badge">🤝 <%= user.sports %>명</div>
            </div>
          </div>
          <div class="profile-divider"></div>
          <div class="profile-stat-row">
            <div class="ps-item"><span class="ps-val">
              <%= regularActs.length + instantActs.length %>
            </span>
              <span class="ps-label">총 활동</span></div>
            <div class="ps-item">
              <span class="ps-val"><%= regularActs.length %></span>
              <span class="ps-label">정기 활동</span>
            </div>
            <div class="ps-item"><span class="ps-val"><%= instantActs.length %></span>
              <span class="ps-label">실시간 활동</span>
            </div>
          </div>
          <div class="rank-info-box">
            <div style="font-size:12px;opacity:.6;letter-spacing:1px;margin-bottom:3px">명예 점수</div>
            <div style="font-family:'DM Mono',monospace;font-size:36px;font-weight:700;letter-spacing:-2px;line-height:1"><%= user.honor %>점</div>
          </div>
        </div>
        <div class="card" style="overflow:hidden">
          <div class="mypage-nav">
            <button id="regular-tab" class="mypage-nav-item active"><span>📅</span> 정기 모임</button>
            <button id="instant-tab" class="mypage-nav-item"><span>⚡</span> 실시간 모임</button>
            <a href="/user/edit-profile" class="mypage-nav-item"><span>⭐</span> 프로필 수정</a>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="mypage-main">
      <div id="regular-section">
        <div class="mypage-card" style="margin-bottom: 16px;">
          <div class="mypage-card-header">
          <div class="mypage-card-title">📅 정기 활동 일정</div>
        </div>
        <div id="regular-calendar" class="regular-calendar"></div>
      </div>

        <!-- Upcoming Schedule -->
        <div id="regular-card" class="mypage-card">
          <div class="mypage-card-header"><div class="mypage-card-title">📅 정기 활동 목록 </div>
          <% const now = new Date() %>
          <% const upcomingRegularActs = regularActs.filter(act => new Date(act.startTime) >= now) %>
          <% if(upcomingRegularActs.length > 4) { %>
          <button type="button" id="regular-all-btn" class="mypage-card-action">전체보기</button>
          <button type="button" id="regular-four-btn" class="mypage-card-action" style="display: none">접기</button>
          <% } %>
        </div>
          <div class="mypage-card-body">
            <% if(upcomingRegularActs.length === 0 || !upcomingRegularActs) { %>
                <div class="no-data-container">
                  <div class="no-data-item">🔍</div>
                  <p class="no-data-item" style="font-weight: 700;">정기 모임에서 가입한 활동이 없어요</p>
                  <p class="no-data-item">나의 정기 모임에서 활동을 확인해보세요!</p>
                  <a href="/regular/my" class="no-data-button">정기 모임 활동 확인하기</a>
                </div>
            <% } else { %>
            <% upcomingRegularActs.forEach((act, index) => { %>
              <% const startTime = new Date(act.startTime) %>
                <div class="schedule-item 
                            <%= index === 3 ? 'schedule-item-last' : '' %>
                            <%= index > 3 ? 'schedule-item-hidden' : '' %>">
                    <div class="sched-time">
                      <%= startTime.toDateString() === now.toDateString() ? '오늘' : ' '%> 
                      <%= startTime.toLocaleDateString('ko-KR', { month: 'long', day: 'numeric', weekday: 'short' })%>
                    </div>
                    <div class="sched-dot" style="background:var(--primary)"></div>

                    
                    <div class="sched-info">
                        <div class="sched-title-row">
                            <span class="sched-title"><%= act.crewId.title %></span>
                            <% if(act.content) { %>
                                <span class="sched-title" style="font-weight: 400;"> - <%= act.content %></span>
                            <% } %>
                            <span class="sched-owner">
                              👑 <%= act.crewId.host.name %> 
                              <%= String(user.id) === String(act.crewId.host._id) ? "(나)" : "" %>
                            </span>
                        </div>
                        <div class="sched-sub">📌 <%= act.location.state %> <%= act.location.city %> </div>
                    </div>

                    <div class="sched-manage">
                        <div class="manage-top">
                              <span class="sched-days"><%= startTime.toLocaleDateString('ko-KR', { weekday: 'short' })%></span>
                            <span class="sched-count">👤 <%= act.attender.length %>/<%= act.capacity %></span>
                        </div>
                        <div class="manage-bottom">
                        <% if (act.gameType === 'solo') { %>
                          <span class="sched-joined" style="color: #22C55E">개인전</span>
                        <% } else if(act.gameType === 'team') { %>
                          <span class="sched-joined" style="color: #F97316">팀전</span>
                        <% } else { %>
                          <span class="sched-joined"><%= act.gameType %></span>
                        <% } %>
                        </div>
                    </div>
                  </div>
                <% });%>
              <% }%>
          </div>
        </div>
        </div>
        
        <div id="instant-section" style="display: none">
        <div class="mypage-card" style="margin-bottom: 16px;">
            <div class="mypage-card-header">
                <div class="mypage-card-title">⚡ 실시간 활동 달력</div>
            </div>

            <div class="calendar-month-header">
                <button id="prev-month-btn" class="calendar-arrow">◀</button>
                <span id="year-month"></span>
                <button id="next-month-btn" class="calendar-arrow">▶</button>
            </div>

            <div id="instant-calendar" class="monthly-calendar"></div>
        </div>

        <div id="instant-card" class="mypage-card">
          <div class="mypage-card-header">
            <div class="mypage-card-title">⚡ 실시간 활동 목록</div>
            <% const upcomingInstantActs = instantActs.filter(act => new Date(act.startTime) >= now) %>
            <% if(upcomingInstantActs.length > 4) { %>
            <button type="button" id="instant-all-btn" class="mypage-card-action">전체보기</button>
            <button type="button" id="instant-four-btn" class="mypage-card-action" style="display: none">접기</button>
            <% } %>
          </div>
          <div class="mypage-card-body">
            <% if(upcomingInstantActs.length === 0 || !upcomingInstantActs) { %>
                  <div class="no-data-container">
                    <div class="no-data-item">🔍</div>
                    <p class="no-data-item" style="font-weight: 700;">아직 가입한 실시간 모임이 없어요</p>
                    <p class="no-data-item">나와 취향이 맞는 실시간 모임을 지도에서 찾아보세요!</p>
                    <a href="/instant/list" class="no-data-button">모임 둘러보기</a>
                  </div>
              <% } else { %>
                <% upcomingInstantActs.forEach((act, index) => { %>
                  <% const startTime = new Date(act.startTime) %>
                <div class="schedule-item 
                            <%= index === 3 ? 'schedule-item-last' : '' %>
                            <%= index > 3 ? 'schedule-item-hidden' : '' %>">
                  <div class="sched-time">
                    <%= startTime.toDateString() === now.toDateString() ? '오늘' : ' '%> 
                    <%= startTime.toLocaleDateString('ko-KR', { month: 'long', day: 'numeric', weekday: 'short' })%>
                  </div>
                  <div class="sched-dot" style="background:var(--red)"></div>
                  <div class="sched-info">
                      <div class="sched-title-row">
                          <span class="sched-title"><%= act.crewId.title %></span>
                          <% if(act.content) { %>
                              <span class="sched-title" style="font-weight: 400;"> - <%= act.content %></span>
                          <% } %>
                          <span class="sched-owner">
                            👑 <%= act.crewId.host.name %>
                                <%= String(user.id) === String(act.crewId.host._id) ? "(나)" : "" %>
                          </span>
                      </div>
                      <div class="sched-sub">📌 <%= act.location.state %> <%= act.location.city %></div>
                  </div>

                  <div class="sched-manage">
                      <div class="manage-top">
                          <span class="sched-days">
                            <%= startTime.setHours(0, 0, 0, 0) - now.setHours(0, 0, 0, 0) < 0 ? 'D +' : 'D -' %>
                            <%= Math.abs((startTime.setHours(0, 0, 0, 0) - now.setHours(0, 0, 0, 0))/86400000) %>
                          </span>
                          <span class="sched-count">👤 <%= act.attender.length %>/<%= act.capacity %></span>
                      </div>
                  </div>
              </div>
            <% });%>
            <% } %>

          </div>
          </div>
        </div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<div id="calendar-modal" class="calendar-modal">
    <div class="calendar-modal-content">
        <div class="calendar-modal-header">
            <span id="modal-title"></span>
            <button id="modal-close-btn">✕</button>
        </div>
        <div id="modal-body"></div>
    </div>
</div>

<script id="profile-data" type="application/json">
{
    "regularActs": <%- JSON.stringify(regularActs) %>,
    "instantActs": <%- JSON.stringify(instantActs) %>
}
</script>
<script src="/js/handlers/profile.js"></script>
</body>
</html>
