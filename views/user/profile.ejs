<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPORTMATCH — 생활 스포츠 매칭 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
<%- include('../partials/navbar') %>
<!-- ═══════ MAIN ═══════ -->

<!-- ═══════ MAIN ═══════ -->
<div class="main">

<!-- ──────── MY PAGE ──────── -->
<%- include('../partials/head', { title: '👤 마이페이지', pageId: 'page-mypage', active: '' }) %>

  <div class="page-body">
    <div class="mypage-layout">
      <!-- Profile Card -->
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="profile-card">
          <div class="profile-banner"></div>
          <div class="profile-av-wrap">
            <% if(user.provider === 'google' || user.provider === 'naver') { %>
                <img src="<%= user.profileImage %>" class="profile-big-av">
            <% } else { %> 
                <img src="/images/user-profile/<%= user.profileImage %>" class="profile-big-av">
            <% } %>
          </div>
          <div class="profile-info">
            <div class="profile-name"><%= user.name %></div>
            <div class="profile-handle"><%= user.email %></div>
            <div class="profile-badges">
              <div class="profile-badge">🎂 <%= user.age %> 세</div>
              <div class="profile-badge">👤 <%= user.gender === 'male' ? '남성' : '여성' %></div> 
              <div class="profile-badge">🏠 <%= user.address.state %> <%= user.address.city %></div>
              <div class="profile-badge">⚡ <%= user.sports %>축구</div>
            </div>
          </div>
          <div class="profile-divider"></div>
          <div class="profile-stat-row">
            <div class="ps-item"><span class="ps-val"><%= user.matchCount %>10</span><span class="ps-label">참여한 경기</span></div>
            <div class="ps-item"><span class="ps-val">
              <% const regularCrewCount = regCrew.reduce((sum, crew) => sum + crew.schedule.length, 0) %>
              <%= regularCrewCount + instantCrew.length %></span><span class="ps-label">참여중인 모임</span>
            </div>
            <div class="ps-item"><span class="ps-val">12</span><span class="ps-label">매너 순위</span></div>
          </div>
          <div class="rank-info-box">
            <div style="font-size:12px;opacity:.6;letter-spacing:1px;margin-bottom:3px">매너점수</div>
            <div style="font-family:'DM Mono',monospace;font-size:36px;font-weight:700;letter-spacing:-2px;line-height:1"><%= user.mannerPoint %>10점</div>
          </div>
        </div>
        <div class="card" style="overflow:hidden">
          <div class="mypage-nav">
            <a href="/user/profile" class="mypage-nav-item"><span>📅</span> 모임 일정</a>
            <a href="/user/edit-profile" class="mypage-nav-item"><span>⭐</span> 프로필 수정</a>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="mypage-main">
<div class="mypage-card">
    <div class="mypage-card-header">
        <div class="mypage-card-title">📅 정기 모임 일정</div>
    </div>

    <div class="regular-calendar">

        <div class="regular-day">
            <div class="regular-day-header">
                <span class="regular-day-name">월</span>
                <span class="regular-day-date">06.01</span>
            </div>

            <div class="regular-event">
                <div class="regular-time">19:00</div>
                <div class="regular-title">풋살 정기전</div>
            </div>

            <div class="regular-event">
                <div class="regular-time">21:00</div>
                <div class="regular-title">야간 축구</div>
            </div>
        </div>

        <div class="regular-day"></div>

        <div class="regular-day">
            <div class="regular-day-header">
                <span class="regular-day-name">수</span>
                <span class="regular-day-date">06.03</span>
            </div>

            <div class="regular-event">
                <div class="regular-time">20:00</div>
                <div class="regular-title">정기 경기</div>
            </div>
        </div>

        <div class="regular-day regular-today">
            <div class="regular-day-header">
                <span class="regular-day-name">목</span>
                <span class="regular-day-date">06.04</span>
            </div>
        </div>

        <div class="regular-day"></div>
        <div class="regular-day"></div>
        <div class="regular-day"></div>

    </div>
</div>

        <!-- Upcoming Schedule -->
        <div id="regular-card" class="mypage-card">
          <div class="mypage-card-header"><div class="mypage-card-title">📅 계획중인 정기 모임 </div>
          <% if(regularCrewCount > 4) { %>
          <button type="button" id="regularSeeAllBtn" class="mypage-card-action">전체보기</button>
          <button type="button" id="regularSee4Btn" class="mypage-card-action" style="display: none">접기</button>
          <% } %>
        </div>
          <div class="mypage-card-body">
            <% if(regularCrewCount === 0 || !regCrew) { %>
                <div class="no-data-container">
                  <div class="no-data-item">🔍</div>
                  <p class="no-data-item" style="font-weight: 700;">아직 가입한 모임이 없어요</p>
                  <p class="no-data-item">나와 취향이 맞는 정기 모임을 찾아보세요!</p>
                  <a href="/regular/list" class="no-data-button">모임 둘러보기</a>
                </div>
            <% } else { %>
            <% let scheduleCounter = 0 %>
            <% regCrew.forEach(crew => { %>
              <% crew.schedule.forEach(sched => { %>
                <div class="schedule-item 
                            <%= scheduleCounter === 3 ? 'schedule-item-last' : '' %>
                            <%= scheduleCounter > 3 ? 'schedule-item-hidden' : '' %>">
                    <% if(crew.day[0] === '미정') { %>
                    <div class="sched-time"> <%= crew.day[0] %> --:-- </div>
                    <% } else {%>
                    <div class="sched-time"> 
                      <%= crew.day[0] %> <%= sched.date.toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit' }) %>
                    </div>
                    <% } %>
                    <div class="sched-dot" style="background:var(--primary)"></div>

                    <div class="sched-info">
                        <div class="sched-title-row">
                            <span class="sched-title"><%= crew.title %></span>
                            <span class="sched-title" style="font-weight: 400;"> - <%= sched.title %></span>
                            <span class="sched-owner">
                              👑 <%= crew.host.name %> 
                              <%= String(user.id) === String(crew.host._id) ? "(나)" : "" %>
                            </span>
                        </div>
                        <div class="sched-sub">📌 <%= sched.address.state %> <%= sched.address.city %> </div>
                    </div>

                    <div class="sched-manage">
                        <div class="manage-top">
                            <% if (crew.day[0] === '미정') {%> 
                              <span class="sched-days" style="color: red">미정</span>
                            <% } else { %>
                              <span class="sched-days">매주 <%= crew.day.join(', ');%></span>
                            <% } %>
                            <span class="sched-count">👤 <%= sched.participants.length %>/<%= crew.member.capacity %></span>
                        </div>
                        <div class="manage-bottom">
                        <% if (sched.status === '마감') { %>
                          <span class="sched-joined" style="color: yellow"><%= sched.status %></span>
                        <% } else if(sched.status === '종료') { %>
                          <span class="sched-joined" style="color: red"><%= sched.status %></span>
                        <% } else if(sched.status === '취소') { %>
                          <span class="sched-joined" style="color: gray"><%= sched.status %></span>
                        <% } else { %>
                          <span class="sched-joined"><%= sched.status %></span>
                        <% } %>
                        </div>
                    </div>
                </div>
                <% scheduleCounter++ %>
                <% });%>
              <% });}%>
          </div>
        </div>

<div class="mypage-card">
    <div class="mypage-card-header">
        <div class="mypage-card-title">⚡ 실시간 모임 캘린더</div>
    </div>

    <div class="calendar-month-header">
        <button class="calendar-arrow">◀</button>
        <span>2026년 6월</span>
        <button class="calendar-arrow">▶</button>
    </div>

    <div class="monthly-calendar">

        <!-- 요일 -->
        <div class="calendar-weekday sunday">일</div>
        <div class="calendar-weekday">월</div>
        <div class="calendar-weekday">화</div>
        <div class="calendar-weekday">수</div>
        <div class="calendar-weekday">목</div>
        <div class="calendar-weekday">금</div>
        <div class="calendar-weekday saturday">토</div>

        <!-- 첫째주 -->
        <div class="calendar-cell empty"></div>

        <div class="calendar-cell">
            <div class="calendar-date">1</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">2</div>
            <div class="calendar-event">⚽ 풋살</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">3</div>
        </div>

        <div class="calendar-cell today">
            <div class="calendar-date">4</div>
            <div class="calendar-event">⚡ 번개경기</div>
            <div class="calendar-event">🏃 러닝</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">5</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">6</div>
        </div>

        <!-- 둘째주 -->
        <div class="calendar-cell">
            <div class="calendar-date">7</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">8</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">9</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">10</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">11</div>
            <div class="calendar-event">⚽ 축구</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">12</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">13</div>
        </div>

        <!-- 셋째주 -->
        <div class="calendar-cell">
            <div class="calendar-date">14</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">15</div>
            <div class="calendar-event">🏆 친선전</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">16</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">17</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">18</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">19</div>
        </div>

        <div class="calendar-cell">
            <div class="calendar-date">20</div>
        </div>
        <div class="calendar-cell">
            <div class="calendar-date">21</div>
        </div>
        <div class="calendar-cell">
            <div class="calendar-date">22</div>
        </div>
        <div class="calendar-cell">
            <div class="calendar-date">23</div>
        </div>
        <div class="calendar-cell">
            <div class="calendar-date">24</div>
        </div>
        <div class="calendar-cell">
            <div class="calendar-date">25</div>
        </div>
        <div class="calendar-cell">
            <div class="calendar-date">26</div>
        </div>
        <div class="calendar-cell">
            <div class="calendar-date">27</div>
        </div>
        <div class="calendar-cell">
            <div class="calendar-date">28</div>
        </div>
        <div class="calendar-cell">
            <div class="calendar-date">29</div>
        </div>
        <div class="calendar-cell">
            <div class="calendar-date">30</div>
        </div>

    </div>
</div>

        <div id="instant-card" class="mypage-card">
          <div class="mypage-card-header">
            <div class="mypage-card-title">🕒 실시간 모임</div>
            <% if(instantCrew.length > 4) { %>
            <button type="button" id="instantSeeAllBtn" class="mypage-card-action">전체보기</button>
            <button type="button" id="instantSee4Btn" class="mypage-card-action" style="display: none">접기</button>
            <% } %>
          </div>
          <div class="mypage-card-body">
            <% if(instantCrew.length === 0 || !instantCrew) { %>
                  <div class="no-data-container">
                    <div class="no-data-item">🔍</div>
                    <p class="no-data-item" style="font-weight: 700;">아직 가입한 모임이 없어요</p>
                    <p class="no-data-item">나와 취향이 맞는 실시간 모임을 찾아보세요!</p>
                    <a href="/instant/instant" class="no-data-button">모임 둘러보기</a>
                  </div>
              <% } else { %>
                <% instantCrew.forEach((crew, index) => { %>
                  <% const now = new Date() %>
                <div class="schedule-item 
                            <%= index === 3 ? 'schedule-item-last' : '' %>
                            <%= index > 3 ? 'schedule-item-hidden' : '' %>">
                  <div class="sched-time">
                    <%= crew.meetAt.toDateString() === now.toDateString() ? '오늘' : ' '%> 
                    <%= crew.meetAt.toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit' })%>
                  </div>
                  <div class="sched-dot" style="background:var(--red)"></div>
                  <div class="sched-info">
                      <div class="sched-title-row">
                          <span class="sched-title"><%= crew.title %></span>
                          <span class="sched-owner">
                            👑 <%= crew.host.name %>
                                <%= String(user.id) === String(crew.host._id) ? "(나)" : "" %>
                          </span>
                      </div>
                      <div class="sched-sub">📌 <%= crew.address.state %> <%= crew.address.city %></div>
                  </div>

                  <div class="sched-manage">
                      <div class="manage-top">
                          <span class="sched-days">
                            <%= crew.meetAt.setHours(0, 0, 0, 0) - now.setHours(0, 0, 0, 0) < 0 ? 'D +' : 'D -' %>
                            <%= Math.abs((crew.meetAt.setHours(0, 0, 0, 0) - now.setHours(0, 0, 0, 0))/86400000) %>
                          </span>
                          <span class="sched-count">👤 <%= crew.member.memberList.length %>/<%= crew.member.capacity %></span>
                      </div>
                  </div>
              </div>
            <% });%>
            <% } %>

          </div>
        </div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
<script>
  const regularSeeAllBtn = document.getElementById('regularSeeAllBtn');
  const regularSee4Btn = document.getElementById('regularSee4Btn');
  const instantSeeAllBtn = document.getElementById('instantSeeAllBtn');
  const instantSee4Btn = document.getElementById('instantSee4Btn');

  if(regularSeeAllBtn) regularSeeAllBtn.addEventListener('click', () => seeBtn(true, "regular"));
  if(regularSee4Btn) regularSee4Btn.addEventListener('click', () =>  seeBtn(false, "regular"));
  if(instantSeeAllBtn) instantSeeAllBtn.addEventListener('click', () => seeBtn(true, "instant"));
  if(instantSee4Btn) instantSee4Btn.addEventListener('click', () =>  seeBtn(false, "instant"));

  function seeBtn(bool, crew) {
    if(crew === 'regular') {
      regularSeeAllBtn.style.display = bool ? 'none' : 'inline-block';
      regularSee4Btn.style.display = !bool ? 'none' : 'inline-block';
    } else if(crew === 'instant') {
      instantSeeAllBtn.style.display = bool ? 'none' : 'inline-block';
      instantSee4Btn.style.display = !bool ? 'none' : 'inline-block';
    } else return;

    let mainCard = null;
    if(crew === 'regular') mainCard = document.querySelector('#regular-card');
    else if(crew === 'instant') mainCard = document.querySelector('#instant-card');
    else return;
    
    const scheduleItem = mainCard.querySelectorAll('.schedule-item');
    const scheduleHidden = mainCard.querySelectorAll('.schedule-item-hidden');

    scheduleHidden.forEach(item => item.classList.toggle('show', bool));
    scheduleItem.forEach(item => item.classList.remove('schedule-item-last'));

    const lastSchedule = scheduleItem[scheduleItem.length - 1]
    if(lastSchedule && bool) lastSchedule.classList.add('schedule-item-last');
    else scheduleItem[3].classList.add('schedule-item-last');
  }
</script>

</body>
</html>
